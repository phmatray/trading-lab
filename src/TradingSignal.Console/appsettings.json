{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "LmStudio": {
    "Endpoint": "http://localhost:1234/v1",
    "ModelId": "qwen2.5-14b-instruct",
    "TimeoutSeconds": 60,
    "MaxFewShot": 3,
    "MaxOutputTokens": 4096,
    "ModelFamily": "instruct",
    "ReasoningEffort": "medium"
  },
  "Market": {
    "Symbol": "BTCUSDT",
    "Interval": "1h",
    "HistoryDays": 730
  },
  "Fees": {
    "TakerBps": 10
  },
  "WalkForward": {
    "AdaptationDays": 180,
    "TestDays": 30,
    "StepDays": 30,
    "EvaluationHorizonCandles": 1
  },
  "Adaptation": {
    "EnableThreshold": true,
    "EnableMetaModel": true
  },
  "Output": {
    "DataCacheDir": "./data-cache",
    "DbPath": "./runs/predictions.db",
    "LlmCachePath": "./runs/llm-cache.db",
    "ReportPath": "./runs/report.json"
  }
}
