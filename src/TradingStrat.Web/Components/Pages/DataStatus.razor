@page "/data/status"
@using TradingStrat.Web.Components.Base
@inherits BaseComponent
@rendermode InteractiveServer

<PageTitle>Data Status - TradingStrat</PageTitle>

<div class="space-y-6">
    <!-- Breadcrumb Navigation -->
    <BreadcrumbNav Breadcrumbs="@_breadcrumbs" />

    <!-- Page Header -->
    <PageHeader Title="Data Status"
                Description="Overview of historical data coverage and quality">
        <Actions>
            <Button Variant="@ButtonVariant.Secondary"
                    OnClick="@LoadDataStatusAsync"
                    IsLoading="@_isLoading"
                    Text="Refresh"
                    LoadingText="Refreshing...">
                <LeadingIcon>
                    <Icon Size="@IconSize.Medium" CustomClasses="mr-2">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                    </Icon>
                </LeadingIcon>
            </Button>
            <Button Variant="@ButtonVariant.Primary"
                    OnClick="@NavigateToDataManagement"
                    Text="Fetch Data">
                <LeadingIcon>
                    <Icon Size="@IconSize.Medium" CustomClasses="mr-2">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </Icon>
                </LeadingIcon>
            </Button>
        </Actions>
    </PageHeader>

    @if (_isLoading)
    {
        <div class="flex items-center justify-center py-12">
            <div class="text-center">
                <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-trading-blue dark:border-dark-accent-blue"></div>
                <p class="mt-4 text-gray-600 dark:text-dark-text-secondary">Loading data status...</p>
            </div>
        </div>
    }
    else if (_errorMessage != null)
    {
        <div class="card bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-800">
            <p class="text-red-800 dark:text-red-400">@_errorMessage</p>
        </div>
    }
    else if (_dataStatus != null)
    {
        <!-- Summary Stats -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="card">
                <p class="text-sm font-medium text-gray-600 dark:text-dark-text-secondary">Total Tickers</p>
                <p class="mt-2 text-3xl font-bold text-gray-900 dark:text-dark-text-primary">@_dataStatus.TotalTickers</p>
            </div>
            <div class="card">
                <p class="text-sm font-medium text-gray-600 dark:text-dark-text-secondary">Total Records</p>
                <p class="mt-2 text-3xl font-bold text-gray-900 dark:text-dark-text-primary">@_dataStatus.TotalRecords.ToString("N0")</p>
            </div>
            <div class="card">
                <p class="text-sm font-medium text-gray-600 dark:text-dark-text-secondary">Average Coverage</p>
                <p class="mt-2 text-3xl font-bold text-gray-900 dark:text-dark-text-primary">@_dataStatus.AverageCoveragePercentage.ToString("F1")%</p>
            </div>
        </div>

        @if (_dataStatus.TickerStatuses.Any())
        {
            <!-- Data Coverage Table -->
            <div class="card">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-dark-text-primary mb-4">
                    Ticker Coverage Details
                </h2>
                <DataCoverageTable TickerStatuses="@_dataStatus.TickerStatuses" />
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div class="card text-center py-12">
                <svg class="w-16 h-16 mx-auto text-gray-400 dark:text-dark-text-muted mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
                </svg>
                <h3 class="text-lg font-medium text-gray-900 dark:text-dark-text-primary mb-2">No Data Available</h3>
                <p class="text-gray-600 dark:text-dark-text-secondary mb-6">
                    You haven't fetched any historical data yet. Start by importing data for your favorite tickers.
                </p>
                <Button Variant="@ButtonVariant.Primary"
                        OnClick="@NavigateToDataManagement"
                        Text="Get Started"></Button>
            </div>
        }
    }
</div>
