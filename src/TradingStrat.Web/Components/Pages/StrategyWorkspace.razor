@page "/workspace"
@rendermode InteractiveServer
@using TradingStrat.Domain.Entities
@using TradingStrat.Web.Services.State
@using TradingStrat.Web.Components.Pages.Workspace
@using TradingStrat.Web.Components.UI.Typography
@using TradingStrat.Web.Components.UI.Buttons

<PageTitle>Strategy Workspace - TradingStrat</PageTitle>

<div class="space-y-6">
    <!-- Breadcrumb Navigation -->
    <BreadcrumbNav Breadcrumbs="@_breadcrumbs" />

    <!-- Page Header -->
    <PageHeader Title="Strategy Workspace"
                Description="Unified workflow for Define → Test → Optimize → Deploy" />

    <!-- Progress Indicator -->
    @if (!string.IsNullOrEmpty(_progressMessage))
    {
        <div class="mb-6 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg">
            <div class="flex items-center gap-3">
                <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-blue-600 dark:border-blue-400"></div>
                <TradingStrat.Web.Components.UI.Typography.Text Class="text-sm text-blue-800 dark:text-blue-400">@_progressMessage</TradingStrat.Web.Components.UI.Typography.Text>
            </div>
        </div>
    }

    <!-- Tab Navigation -->
    <div class="mb-6 border-b border-gray-200 dark:border-dark-border">
        <nav class="flex gap-8">
            <button @onclick="() => SetActiveTab(0)"
                    class="@GetTabClass(0) py-4 border-b-2 font-medium text-sm transition-colors">
                <span class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"></path>
                    </svg>
                    Define
                </span>
            </button>

            <button @onclick="() => SetActiveTab(1)"
                    class="@GetTabClass(1) py-4 border-b-2 font-medium text-sm transition-colors"
                    disabled="@(WorkspaceState.State.CurrentStrategy is null)">
                <span class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                    </svg>
                    Test
                </span>
            </button>

            <button @onclick="() => SetActiveTab(2)"
                    class="@GetTabClass(2) py-4 border-b-2 font-medium text-sm transition-colors"
                    disabled="@(WorkspaceState.State.CurrentStrategy is null)">
                <span class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
                    </svg>
                    Optimize
                </span>
            </button>

            <button @onclick="() => SetActiveTab(3)"
                    class="@GetTabClass(3) py-4 border-b-2 font-medium text-sm transition-colors"
                    disabled="@(WorkspaceState.State.TestResult is null)">
                <span class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
                    </svg>
                    Deploy
                </span>
            </button>
        </nav>
    </div>

    <!-- Tab Content -->
    <div class="tab-content">
        @if (_activeTab == 0)
        {
            <TabDefine OnStrategyCreated="HandleStrategyCreated" />
        }
        else if (_activeTab == 1)
        {
            <TabTest Strategy="WorkspaceState.State.CurrentStrategy"
                     OnTestComplete="HandleTestComplete" />
        }
        else if (_activeTab == 2)
        {
            <TabOptimize Strategy="WorkspaceState.State.CurrentStrategy"
                         OnOptimizationComplete="HandleOptimizationComplete" />
        }
        else if (_activeTab == 3)
        {
            <TabDeploy Strategy="WorkspaceState.State.CurrentStrategy"
                       TestResult="WorkspaceState.State.TestResult" />
        }
    </div>

    <!-- Quick Actions Footer -->
    <div class="mt-8 p-4 bg-gray-50 dark:bg-dark-bg-tertiary rounded-lg border border-gray-200 dark:border-dark-border">
        <div class="flex items-center justify-between">
            <div class="text-sm text-gray-600 dark:text-dark-text-secondary">
                @if (WorkspaceState.State.CurrentStrategy is not null)
                {
                    <span class="font-medium">Current Strategy:</span>
                    <span class="ml-2">@WorkspaceState.State.CurrentStrategy.Name</span>
                }
                else
                {
                    <span>No strategy selected. Create or load a strategy to begin.</span>
                }
            </div>
            <TradingStrat.Web.Components.UI.Buttons.Button
                OnClick="ClearWorkspace"
                Plain="true"
                Class="text-sm">
                Clear Workspace
            </TradingStrat.Web.Components.UI.Buttons.Button>
        </div>
    </div>
</div>
