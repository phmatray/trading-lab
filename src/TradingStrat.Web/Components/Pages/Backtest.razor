@page "/backtest"
@rendermode InteractiveServer
@inherits BaseDataPage<BacktestFormModel, BacktestResult>

<PageTitle>Backtest - TradingStrat</PageTitle>

<div class="space-y-6">
    <!-- Breadcrumb Navigation -->
    <BreadcrumbNav Breadcrumbs="@_breadcrumbs" />

    <!-- Page Header -->
    <PageHeader Title="Strategy Backtest"
                Description="Test trading strategies on historical data and analyze performance metrics." />

    <ProgressIndicator IsVisible="ProgressService.IsProcessing"
                       CurrentMessage="ProgressService.CurrentMessage"
                       Progress="ProgressService.CurrentProgress" />

    <AlertMessage Message="@ErrorMessage" Type="AlertType.Error" />
    <AlertMessage Message="@SuccessMessage" Type="AlertType.Success" />

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Configuration Form -->
        <div class="lg:col-span-1 space-y-6">
            <div class="card">
                <h2 class="text-xl font-semibold text-gray-900 dark:text-dark-text-primary mb-4">Configuration</h2>

                <EditForm Model="@FormModel" OnValidSubmit="@HandleSubmitAsync" class="space-y-4">
                    <DataAnnotationsValidator />

                    <FormInputGroup Label="Ticker Symbol"
                                    ValidationFor="@(() => FormModel.Ticker)">
                        <InputText id="ticker" @bind-Value="FormModel.Ticker"
                                   @oninput="@(async (ChangeEventArgs e) => { FormModel.Ticker = e.Value?.ToString() ?? string.Empty; await OnFormFieldChanged(); })"
                                   class="@TailwindStyles.InputText" />
                    </FormInputGroup>

                    <FormInputGroup Label="Initial Capital"
                                    ValidationFor="@(() => FormModel.InitialCapital)">
                        <InputNumber id="capital" @bind-Value="FormModel.InitialCapital"
                                     @oninput="@(async () => await OnFormFieldChanged())"
                                     class="@TailwindStyles.InputNumber" />
                    </FormInputGroup>

                    <DateRangeInput @bind-StartDate="FormModel.StartDate"
                                    @bind-EndDate="FormModel.EndDate" />

                    <button type="submit" disabled="@ProgressService.IsProcessing" class="btn-primary w-full">
                        @if (ProgressService.IsProcessing)
                        {
                            <span>Running Backtest...</span>
                        }
                        else
                        {
                            <span>Run Backtest</span>
                        }
                    </button>
                </EditForm>
            </div>

            <StrategyForm @ref="_strategyForm"
                          SelectedStrategy="@GetStrategyKey(FormModel.StrategyType)"
                          SelectedStrategyChanged="@OnStrategyTypeChanged"
                          ParametersChanged="@OnStrategyParametersChanged" />
        </div>

        <!-- Results -->
        <div class="lg:col-span-2 space-y-6">
            @if (Result != null)
            {
                <div class="card">
                    <h2 class="text-xl font-semibold text-gray-900 dark:text-dark-text-primary mb-4">
                        @Result.StrategyName
                    </h2>
                    <p class="text-gray-600 dark:text-dark-text-secondary mb-4">@Result.StrategyDescription</p>
                    <div class="text-sm text-gray-500 dark:text-dark-text-secondary">
                        <p>Period: @Result.StartDate.ToString("yyyy-MM-dd") to @Result.EndDate.ToString("yyyy-MM-dd")</p>
                        <p>Initial Capital: @Result.InitialCapital.ToString("C2")</p>
                    </div>
                </div>

                <MetricsGrid Metrics="@Result.Metrics" />

                <StrategyAnalysisPanel
                    Ticker="@Result.Ticker"
                    StrategyType="@GetStrategyType(Result.StrategyName)"
                    StrategyParameters="@Result.StrategyParameters" />

                <EquityChart EquityCurve="@Result.EquityCurve" />

                <TradeTable Trades="@Result.Trades" />

                <div class="card">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-dark-text-primary mb-4">Quick Actions</h3>
                    <div class="flex flex-wrap gap-3">
                        <button @onclick="CreatePortfolioFromStrategy" class="btn-secondary">
                            <svg class="w-4 h-4 mr-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                            </svg>
                            Create Portfolio
                        </button>
                        <button @onclick="CompareWithOthers" class="btn-secondary">
                            <svg class="w-4 h-4 mr-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                            </svg>
                            Compare Strategies
                        </button>
                        <button @onclick="OptimizeParameters" class="btn-secondary">
                            <svg class="w-4 h-4 mr-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                            </svg>
                            Optimize Parameters
                        </button>
                        <button @onclick="ViewInArchive" class="btn-secondary">
                            <svg class="w-4 h-4 mr-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
                            </svg>
                            View in Archive
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="text-center py-12">
                        <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                        </svg>
                        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-dark-text-primary">No backtest results</h3>
                        <p class="mt-1 text-sm text-gray-500 dark:text-dark-text-secondary">Configure your strategy and run a backtest to see results here.</p>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (Result != null)
    {
        <TradingViewWidget Ticker="@Result.Ticker" />
    }
</div>
