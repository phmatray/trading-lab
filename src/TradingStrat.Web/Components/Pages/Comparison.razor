@page "/comparison"
@rendermode InteractiveServer
@using TradingStrat.Web.Components.UI.Typography
@inherits BaseDataPage<ComparisonFormModel, ParameterOptimizationResult>

<PageTitle>A/B Comparison - TradingStrat</PageTitle>

<div class="space-y-6">
    <PageHeader Title="A/B Strategy Comparison"
                Description="Compare two strategy variants side-by-side with detailed performance metrics." />

    <ProgressIndicator IsVisible="ProgressService.IsProcessing"
                       CurrentMessage="@ProgressService.CurrentMessage"
                       Progress="ProgressService.CurrentProgress" />

    <FormWrapper ErrorMessage="@ErrorMessage">
        <!-- Configuration -->
    <div class="card">
        <Heading Level="2" Class="text-xl font-semibold text-gray-900 dark:text-dark-text-primary mb-4">Test Configuration</Heading>

        <EditForm Model="@FormModel" OnValidSubmit="@HandleSubmitAsync" class="space-y-6">
            <DataAnnotationsValidator />

            <!-- Common Settings -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <TickerInput @bind-Value="FormModel.Ticker"
                                 Label="Ticker Symbol *"
                                 For="@(() => FormModel.Ticker)"
                                 OnInputChanged="@(async () => await OnFormFieldChanged())" />
                </div>

                <FormInputGroup Label="Initial Capital"
                                ValidationFor="@(() => FormModel.InitialCapital)">
                    <InputNumber id="capital" @bind-Value="FormModel.InitialCapital"
                                 @oninput="@(async () => await OnFormFieldChanged())"
                                 class="@TailwindStyles.InputNumber" />
                </FormInputGroup>

                <div class="flex items-end">
                    <TradingStrat.Web.Components.Shared.Button Type="@TradingStrat.Web.Components.Shared.ButtonType.Submit"
                            Variant="@ButtonVariant.Primary"
                            FullWidth="@true"
                            IsLoading="@ProgressService.IsProcessing"
                            Text="Run Comparison"
                            LoadingText="Comparing..."></TradingStrat.Web.Components.Shared.Button>
                </div>
            </div>

            <!-- Strategy Variants -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Variant A -->
                <div class="border-2 border-blue-200 dark:border-blue-800 rounded-lg p-4 bg-white dark:bg-dark-elevated">
                    <Heading Level="3" Class="text-lg font-semibold mb-4 text-blue-700 dark:text-blue-400">Variant A</Heading>
                    <StrategyForm @ref="_strategyFormA"
                                  SelectedStrategy="@GetStrategyKey(FormModel.StrategyTypeA)"
                                  SelectedStrategyChanged="@OnStrategyTypeAChanged"
                                  ParametersChanged="@OnStrategyParametersAChanged" />
                </div>

                <!-- Variant B -->
                <div class="border-2 border-green-200 dark:border-green-800 rounded-lg p-4 bg-white dark:bg-dark-elevated">
                    <Heading Level="3" Class="text-lg font-semibold mb-4 text-green-700 dark:text-green-400">Variant B</Heading>
                    <StrategyForm @ref="_strategyFormB"
                                  SelectedStrategy="@GetStrategyKey(FormModel.StrategyTypeB)"
                                  SelectedStrategyChanged="@OnStrategyTypeBChanged"
                                  ParametersChanged="@OnStrategyParametersBChanged" />
                </div>
            </div>
        </EditForm>
    </div>

    <!-- Results -->
    @if (Result is not null && Result.Comparison is not null)
    {
        var comparison = Result.Comparison;

        <!-- Winner Announcement -->
        @if (comparison.Winner > 0)
        {
            <div class="card bg-gradient-to-r from-yellow-50 to-orange-50 dark:from-yellow-900/20 dark:to-orange-900/20 border-yellow-200 dark:border-yellow-800">
                <div class="text-center">
                    <Heading Level="2" Class="text-2xl font-bold text-gray-900 dark:text-dark-text-primary mb-2">
                        🏆 Winner: @(comparison.Winner == 1 ? "Variant A" : "Variant B")
                    </Heading>
                    <p class="text-gray-600 dark:text-dark-text-secondary">
                        @(comparison.Winner == 1 ? comparison.VariantA.Description : comparison.VariantB.Description)
                    </p>
                    <p class="text-sm text-gray-500 dark:text-dark-text-secondary mt-2">
                        Execution Time: @Result.ExecutionTime.TotalSeconds.ToString("F2") seconds
                    </p>
                </div>
            </div>
        }

        <!-- Side-by-Side Metrics -->
        <div class="card">
            <Heading Level="2" Class="text-xl font-semibold text-gray-900 dark:text-dark-text-primary mb-4">Performance Comparison</Heading>

            <div class="overflow-x-auto">
                <table class="min-w-full">
                    <thead class="bg-gray-50 dark:bg-dark-elevated">
                        <tr>
                            <th class="px-4 py-3 text-left text-sm font-medium text-gray-500 dark:text-dark-text-secondary">Metric</th>
                            <th class="px-4 py-3 text-center text-sm font-medium text-blue-700 dark:text-blue-400">Variant A</th>
                            <th class="px-4 py-3 text-center text-sm font-medium text-green-700 dark:text-green-400">Variant B</th>
                            <th class="px-4 py-3 text-center text-sm font-medium text-gray-500 dark:text-dark-text-secondary">Difference</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-dark-border">
                        @foreach ((string key, MetricComparison metricComparison) in comparison.Ranking.MetricBreakdown)
                        {
                            <tr class="bg-white dark:bg-dark-card">
                                <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-dark-text-primary">@key</td>
                                <td class="px-4 py-3 text-center text-sm">
                                    <span class="font-semibold text-gray-900 dark:text-dark-text-primary">@StrategyUIFormatter.FormatMetricValue(key, metricComparison.VariantAValue)</span>
                                    <span class="text-xs text-blue-600 dark:text-blue-400 ml-1">(@metricComparison.VariantAPoints.ToString("F1") pts)</span>
                                </td>
                                <td class="px-4 py-3 text-center text-sm">
                                    <span class="font-semibold text-gray-900 dark:text-dark-text-primary">@StrategyUIFormatter.FormatMetricValue(key, metricComparison.VariantBValue)</span>
                                    <span class="text-xs text-green-600 dark:text-green-400 ml-1">(@metricComparison.VariantBPoints.ToString("F1") pts)</span>
                                </td>
                                <td class="px-4 py-3 text-center text-sm @(metricComparison.Difference > 0 ? "metric-positive" : "metric-negative")">
                                    @(metricComparison.Difference > 0 ? "+" : "")@StrategyUIFormatter.FormatMetricValue(key, metricComparison.Difference)
                                    (@(metricComparison.PercentageDifference > 0 ? "+" : "")@metricComparison.PercentageDifference.ToString("F1")%)
                                </td>
                            </tr>
                        }
                        <tr class="bg-gray-50 dark:bg-dark-elevated font-bold">
                            <td class="px-4 py-3 text-sm text-gray-900 dark:text-dark-text-primary">Total Score</td>
                            <td class="px-4 py-3 text-center text-blue-700 dark:text-blue-400">@comparison.Ranking.VariantAScore.ToString("F1")</td>
                            <td class="px-4 py-3 text-center text-green-700 dark:text-green-400">@comparison.Ranking.VariantBScore.ToString("F1")</td>
                            <td class="px-4 py-3 text-center text-gray-900 dark:text-dark-text-primary">-</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Detailed Results Tabs -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Variant A Results -->
            <div class="space-y-4">
                <div class="card border-2 border-blue-200 dark:border-blue-800">
                    <Heading Level="3" Class="text-lg font-semibold text-blue-700 dark:text-blue-400 mb-4">Variant A: @comparison.VariantA.Description</Heading>
                    <MetricsGrid Metrics="@comparison.ResultA.Metrics" />
                </div>
                <StrategyAnalysisPanel
                    Ticker="@comparison.ResultA.Ticker"
                    StrategyType="@GetStrategyType(comparison.ResultA.StrategyName)"
                    StrategyParameters="@comparison.ResultA.StrategyParameters" />
                <div class="card border-2 border-blue-200 dark:border-blue-800">
                    <EquityChart EquityCurve="@comparison.ResultA.EquityCurve" />
                </div>
            </div>

            <!-- Variant B Results -->
            <div class="space-y-4">
                <div class="card border-2 border-green-200 dark:border-green-800">
                    <Heading Level="3" Class="text-lg font-semibold text-green-700 dark:text-green-400 mb-4">Variant B: @comparison.VariantB.Description</Heading>
                    <MetricsGrid Metrics="@comparison.ResultB.Metrics" />
                </div>
                <StrategyAnalysisPanel
                    Ticker="@comparison.ResultB.Ticker"
                    StrategyType="@GetStrategyType(comparison.ResultB.StrategyName)"
                    StrategyParameters="@comparison.ResultB.StrategyParameters" />
                <div class="card border-2 border-green-200 dark:border-green-800">
                    <EquityChart EquityCurve="@comparison.ResultB.EquityCurve" />
                </div>
            </div>
        </div>

        <!-- Trade Tables -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="border-2 border-blue-200 dark:border-blue-800 rounded-lg p-4 bg-white dark:bg-dark-card">
                <Heading Level="3" Class="text-lg font-semibold text-blue-700 dark:text-blue-400 mb-4">Variant A Trades</Heading>
                <TradeTable Trades="@comparison.ResultA.Trades" MaxDisplayTrades="10" />
            </div>
            <div class="border-2 border-green-200 dark:border-green-800 rounded-lg p-4 bg-white dark:bg-dark-card">
                <Heading Level="3" Class="text-lg font-semibold text-green-700 dark:text-green-400 mb-4">Variant B Trades</Heading>
                <TradeTable Trades="@comparison.ResultB.Trades" MaxDisplayTrades="10" />
            </div>
        </div>

        <TradingViewWidget Ticker="@comparison.Ticker" />
    }
    else if (!ProgressService.IsProcessing)
    {
        <EmptyState Icon="chart"
                    Title="No comparison results"
                    Description="Configure two strategy variants and run a comparison to see results here." />
    }
    </FormWrapper>
</div>
