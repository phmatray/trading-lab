@page "/portfolio/{portfolioId:int}/rebalance"
@rendermode InteractiveServer

@using TradingStrat.Web.Components.UI.Typography
<PageTitle>Portfolio Rebalancing - TradingStrat</PageTitle>

<div class="space-y-6">
    <!-- Breadcrumb Navigation -->
    <BreadcrumbNav Breadcrumbs="@_breadcrumbs" />

    <PageHeader Title="Portfolio Rebalancing"
                Description="@(_portfolio?.Name)"
                OnBack="NavigateBack" />

    <ProgressIndicator IsVisible="ProgressService.IsProcessing"
                       CurrentMessage="@ProgressService.CurrentMessage"
                       Progress="ProgressService.CurrentProgress" />

    <FormWrapper ErrorMessage="@_errorMessage" WarningMessage="@_warningMessage">
        @if (_isLoading)
        {
            <LoadingState Message="Loading portfolio..." />
        }
        else if (_portfolio is null)
        {
            <EmptyState Icon="alert"
                        Title="Portfolio not found"
                        Description="The portfolio you're looking for doesn't exist.">
                <Actions>
                    <TradingStrat.Web.Components.Shared.Button Variant="@ButtonVariant.Primary"
                            OnClick="@NavigateBack"
                            Text="Back to Dashboard"></TradingStrat.Web.Components.Shared.Button>
                </Actions>
            </EmptyState>
        }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Configuration Form -->
            <div class="lg:col-span-1 space-y-6">
                <div class="card">
                    <Heading Level="2" Class="text-xl font-semibold text-gray-900 dark:text-dark-text-primary mb-4">Target Allocation</Heading>

                    @if (_snapshot is not null)
                    {
                        <div class="mb-4 p-3 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg">
                            <p class="text-sm text-blue-800 dark:text-blue-300 font-medium">Current Allocation</p>
                            @foreach (var position in _snapshot.Positions)
                            {
                                <p class="text-xs text-blue-700 dark:text-blue-400">
                                    @position.Ticker: @position.AllocationPercentage.ToString("F1")%
                                </p>
                            }
                            <p class="text-xs text-blue-700 dark:text-blue-400">
                                Cash: @((_snapshot.Cash / _snapshot.TotalValue * 100).ToString("F1"))%
                            </p>
                        </div>
                    }

                    <EditForm Model="@_formModel" OnValidSubmit="@HandleCalculateRebalancing" class="space-y-4">
                        <DataAnnotationsValidator />

                        <div class="space-y-3">
                            <label class="block text-sm font-medium text-gray-700 dark:text-dark-text-primary">Target Allocations</label>

                            @foreach (var allocation in _formModel.TargetAllocations)
                            {
                                <div class="flex space-x-2">
                                    <InputText @bind-Value="allocation.Ticker"
                                               placeholder="Ticker"
                                               class="flex-1 rounded-lg border-gray-300 dark:border-dark-border bg-white dark:bg-dark-elevated text-gray-900 dark:text-dark-text-primary focus:border-trading-blue dark:focus:border-dark-accent-blue focus:ring-trading-blue dark:focus:ring-dark-accent-blue" />
                                    <InputNumber @bind-Value="allocation.Percentage"
                                                 placeholder="%"
                                                 class="w-20 rounded-lg border-gray-300 dark:border-dark-border bg-white dark:bg-dark-elevated text-gray-900 dark:text-dark-text-primary focus:border-trading-blue dark:focus:border-dark-accent-blue focus:ring-trading-blue dark:focus:ring-dark-accent-blue" />
                                    <button type="button" @onclick="() => RemoveAllocation(allocation)" class="px-3 py-2 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                        </svg>
                                    </button>
                                </div>
                            }

                            <button type="button" @onclick="AddAllocation" class="w-full px-4 py-2 bg-gray-100 dark:bg-dark-elevated text-gray-700 dark:text-dark-text-primary rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
                                + Add Position
                            </button>
                        </div>

                        <div>
                            <label for="cash-percentage" class="block text-sm font-medium text-gray-700 dark:text-dark-text-primary mb-1">
                                Cash Percentage: @_formModel.CashPercentage.ToString("F1")%
                            </label>
                            <input type="range" id="cash-percentage" @bind="_formModel.CashPercentage" @bind:event="oninput"
                                   min="0" max="100" step="0.1"
                                   class="w-full h-2 bg-gray-200 dark:bg-dark-elevated rounded-lg appearance-none cursor-pointer" />
                        </div>

                        <div>
                            <label for="commission-percentage" class="block text-sm font-medium text-gray-700 dark:text-dark-text-primary mb-1">Commission Percentage</label>
                            <InputNumber id="commission-percentage" @bind-Value="_formModel.CommissionPercentage"
                                         class="w-full rounded-lg border-gray-300 dark:border-dark-border bg-white dark:bg-dark-elevated text-gray-900 dark:text-dark-text-primary focus:border-trading-blue dark:focus:border-dark-accent-blue focus:ring-trading-blue dark:focus:ring-dark-accent-blue" />
                        </div>

                        <div>
                            <label for="minimum-commission" class="block text-sm font-medium text-gray-700 dark:text-dark-text-primary mb-1">Minimum Commission</label>
                            <InputNumber id="minimum-commission" @bind-Value="_formModel.MinimumCommission"
                                         class="w-full rounded-lg border-gray-300 dark:border-dark-border bg-white dark:bg-dark-elevated text-gray-900 dark:text-dark-text-primary focus:border-trading-blue dark:focus:border-dark-accent-blue focus:ring-trading-blue dark:focus:ring-dark-accent-blue" />
                        </div>

                        <div class="p-3 bg-gray-50 dark:bg-dark-elevated rounded-lg">
                            <p class="text-sm text-gray-600 dark:text-dark-text-secondary">
                                Total Allocation: @GetTotalAllocation().ToString("F1")%
                            </p>
                            @if (Math.Abs(GetTotalAllocation() - 100m) > 0.01m)
                            {
                                <p class="text-xs text-red-600 dark:text-red-400 mt-1">
                                    Warning: Allocations must sum to 100%
                                </p>
                            }
                        </div>

                        <TradingStrat.Web.Components.Shared.Button Type="@ButtonType.Submit"
                                Variant="@ButtonVariant.Primary"
                                FullWidth="@true"
                                IsLoading="@_isCalculating"
                                Text="Calculate Rebalancing Plan"
                                LoadingText="Calculating..."></TradingStrat.Web.Components.Shared.Button>
                    </EditForm>
                </div>
            </div>

            <!-- Results -->
            <div class="lg:col-span-2 space-y-6">
                @if (_plan is not null)
                {
                    <!-- Summary Cards -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="card">
                            <Heading Level="3" Class="text-sm font-medium text-gray-500 dark:text-dark-text-secondary mb-2">Required Cash</Heading>
                            <p class="text-2xl font-bold text-gray-900 dark:text-dark-text-primary">@_plan.RequiredCash.ToString("C2")</p>
                        </div>

                        <div class="card">
                            <Heading Level="3" Class="text-sm font-medium text-gray-500 dark:text-dark-text-secondary mb-2">Available Cash</Heading>
                            <p class="text-2xl font-bold text-gray-900 dark:text-dark-text-primary">@_plan.AvailableCash.ToString("C2")</p>
                        </div>

                        <div class="card">
                            <Heading Level="3" Class="text-sm font-medium text-gray-500 dark:text-dark-text-secondary mb-2">Status</Heading>
                            <div class="flex items-center space-x-2">
                                @if (_plan.IsExecutable)
                                {
                                    <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                    <span class="text-xl font-bold text-green-600 dark:text-green-400">Executable</span>
                                }
                                else
                                {
                                    <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                    <span class="text-xl font-bold text-red-600 dark:text-red-400">Not Executable</span>
                                }
                            </div>
                        </div>
                    </div>

                    @if (!_plan.IsExecutable)
                    {
                        <div class="card bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-800">
                            <div class="flex items-center space-x-3">
                                <svg class="w-6 h-6 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                </svg>
                                <p class="text-sm text-red-800 dark:text-red-300">
                                    Insufficient cash to execute this rebalancing plan. You need an additional @((_plan.RequiredCash - _plan.AvailableCash).ToString("C2")).
                                </p>
                            </div>
                        </div>
                    }

                    <!-- Rebalancing Signals Table -->
                    <div class="card">
                        <Heading Level="2" Class="text-xl font-semibold text-gray-900 dark:text-dark-text-primary mb-4">Rebalancing Actions</Heading>

                        <div class="overflow-x-auto">
                            <table class="min-w-full divide-y divide-gray-200 dark:divide-dark-border">
                                <thead class="bg-gray-50 dark:bg-dark-elevated">
                                    <tr>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Ticker</th>
                                        <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Action</th>
                                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Current Qty</th>
                                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Target Qty</th>
                                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Delta</th>
                                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Current %</th>
                                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Target %</th>
                                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Estimated Cost</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white dark:bg-dark-surface divide-y divide-gray-200 dark:divide-dark-border">
                                    @foreach (var signal in _plan.Signals)
                                    {
                                        var actionClass = signal.Action switch
                                        {
                                            RebalancingAction.Buy => "bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300",
                                            RebalancingAction.Sell => "bg-orange-100 dark:bg-orange-900/30 text-orange-800 dark:text-orange-300",
                                            _ => "bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-300"
                                        };

                                        <tr class="hover:bg-gray-50 dark:hover:bg-dark-elevated transition-colors">
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-dark-text-primary">
                                                @signal.Ticker
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-center">
                                                <span class="px-3 py-1 rounded-full text-xs font-medium @actionClass">
                                                    @signal.Action
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-dark-text-primary text-right">
                                                @signal.CurrentQuantity
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-dark-text-primary text-right">
                                                @signal.TargetQuantity
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-right">
                                                <span class="@(signal.QuantityDelta > 0 ? "text-blue-600 dark:text-blue-400" : signal.QuantityDelta < 0 ? "text-orange-600 dark:text-orange-400" : "text-gray-600 dark:text-gray-400") font-medium">
                                                    @signal.QuantityDelta.ToString("+0;-0;0")
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-dark-text-primary text-right">
                                                @signal.CurrentAllocation.ToString("F1")%
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-dark-text-primary text-right">
                                                @signal.TargetAllocation.ToString("F1")%
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-right">
                                                <span class="@(signal.EstimatedCost > 0 ? "text-red-600 dark:text-red-400" : signal.EstimatedCost < 0 ? "text-green-600 dark:text-green-400" : "text-gray-600 dark:text-gray-400") font-medium">
                                                    @signal.EstimatedCost.ToString("C2")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="bg-gray-50 dark:bg-dark-elevated">
                                    <tr>
                                        <td colspan="7" class="px-6 py-4 text-sm font-medium text-gray-900 dark:text-dark-text-primary">
                                            Total Estimated Commissions
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900 dark:text-dark-text-primary text-right">
                                            @_plan.Signals.Sum(s => Math.Abs(s.EstimatedCost) - Math.Abs(s.QuantityDelta) * (s.EstimatedCost / (s.QuantityDelta == 0 ? 1 : s.QuantityDelta))).ToString("C2")
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="text-center py-12">
                            <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                            </svg>
                            <Heading Level="3" Class="mt-2 text-sm font-medium text-gray-900 dark:text-dark-text-primary">No rebalancing plan</Heading>
                            <p class="mt-1 text-sm text-gray-500 dark:text-dark-text-secondary">Configure your target allocations and calculate a rebalancing plan.</p>
                        </div>
                    </div>
                }
            </div>
        </div>
        }
    </FormWrapper>
</div>

