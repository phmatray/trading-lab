@page "/data"
@rendermode InteractiveServer
@using TradingStrat.Web.Services.State
@using Microsoft.Extensions.Options
@using TradingStrat.Application.Configuration
@using TradingStrat.Web.Models
@using TradingStrat.Web.Utilities
@inject IDataFetchingUseCase DataFetchingUseCase
@inject ProgressService ProgressService
@inject UserPreferencesService PreferencesService
@inject FormStateService FormState
@inject IDataFreshnessService DataFreshnessService
@inject IOptions<TradingConfiguration> Configuration
@implements IDisposable

<PageTitle>Data Management - TradingStrat</PageTitle>

<div class="space-y-6">
    <PageHeader Title="Data Management"
                Description="Fetch and manage historical market data from Yahoo Finance." />

    <ProgressIndicator IsVisible="ProgressService.IsProcessing"
                       CurrentMessage="ProgressService.CurrentMessage"
                       Progress="ProgressService.CurrentProgress" />

    <FormWrapper ErrorMessage="@_errorMessage" SuccessMessage="@_successMessage">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Form -->
        <div class="card">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-dark-text-primary mb-4">Fetch Historical Data</h2>

            <EditForm Model="@_formModel" OnValidSubmit="@HandleFetchData" class="space-y-4">
                <DataAnnotationsValidator />

                <div>
                    <TickerInput @bind-Value="_formModel.Ticker"
                                 Label="Ticker Symbol *"
                                 For="@(() => _formModel.Ticker)"
                                 OnInputChanged="@(async () => await OnFormFieldChanged())" />
                </div>

                <FormInputGroup Label="ISIN"
                                IsOptional="true"
                                HelpText="International Securities Identification Number for ticker resolution">
                    <InputText id="isin" @bind-Value="_formModel.ISIN"
                               @oninput="@(async (ChangeEventArgs e) => { _formModel.ISIN = e.Value?.ToString(); await OnFormFieldChanged(); })"
                               class="@TailwindStyles.InputText" />
                </FormInputGroup>

                <DateRangeInput @bind-StartDate="_formModel.StartDate"
                                @bind-EndDate="_formModel.EndDate" />

                <button type="submit" disabled="@ProgressService.IsProcessing" class="btn-primary w-full">
                    @if (ProgressService.IsProcessing)
                    {
                        <span>Fetching Data...</span>
                    }
                    else
                    {
                        <span>Fetch Data</span>
                    }
                </button>
            </EditForm>
        </div>

        <!-- Results -->
        <DataSummaryCard Summary="@_result" />
    </div>

        @if (_result != null)
        {
            <TradingViewWidget Ticker="@_result.Ticker" />
        }

        @if (_result != null)
        {
            <AiDataAnalysisPanel DataSummary="_result" />
        }
    </FormWrapper>
</div>

@code {
    private const string FORM_KEY = "data-fetch-form";

    private DataFetchFormModel _formModel = new();
    private DataSummaryResult? _result;
    private string? _errorMessage;
    private string? _successMessage;

    protected override async Task OnInitializedAsync()
    {
        ProgressService.OnProgressChanged += StateHasChanged;

        // Try to restore saved form state
        DataFetchFormModel? savedForm = await FormState.GetFormStateAsync<DataFetchFormModel>(FORM_KEY);
        if (savedForm != null)
        {
            _formModel = savedForm;
        }
        else
        {
            // Initialize from user preferences
            Models.State.UserPreferences prefs = await PreferencesService.GetPreferencesAsync();
            _formModel = DataFetchFormModel.FromPreferences(prefs, Configuration.Value);
        }

        // Check data freshness for default ticker
        string ticker = _formModel.Ticker ?? "AAPL";
        await DataFreshnessService.CheckAndNotifyAsync(ticker);
    }

    private async Task OnFormFieldChanged()
    {
        await FormState.SaveFormStateAsync(FORM_KEY, _formModel);
    }

    private async Task HandleFetchData()
    {
        _errorMessage = null;
        _successMessage = null;
        _result = null;

        ProgressService.Reset();

        var progress = new Progress<string>(message =>
        {
            InvokeAsync(() => ProgressService.UpdateProgress(message));
        });

        try
        {
            var command = new FetchDataCommand(
                _formModel.Ticker,
                _formModel.ISIN,
                _formModel.StartDate,
                _formModel.EndDate
            );

            _result = await DataFetchingUseCase.ExecuteAsync(command, progress);
            _successMessage = $"Successfully fetched {_result.NewRecords} new records for {_result.Ticker}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error fetching data: {ex.Message}";
        }
        finally
        {
            await InvokeAsync(() => ProgressService.Reset());
        }
    }

    public void Dispose()
    {
        ProgressService.OnProgressChanged -= StateHasChanged;
    }
}
