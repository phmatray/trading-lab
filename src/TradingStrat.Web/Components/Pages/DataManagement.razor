@page "/data"
@rendermode InteractiveServer
@using TradingStrat.Web.Services.State
@using Microsoft.Extensions.Options
@using TradingStrat.Application.Configuration
@inject IDataFetchingUseCase DataFetchingUseCase
@inject ProgressService ProgressService
@inject UserPreferencesService PreferencesService
@inject FormStateService FormState
@inject IOptions<TradingConfiguration> Configuration
@implements IDisposable

<PageTitle>Data Management - TradingStrat</PageTitle>

<div class="space-y-6">
    <div class="card">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-dark-text-primary mb-2">Data Management</h1>
        <p class="text-gray-600 dark:text-dark-text-secondary">Fetch and manage historical market data from Yahoo Finance.</p>
    </div>

    <ProgressIndicator IsVisible="ProgressService.IsProcessing"
                       CurrentMessage="ProgressService.CurrentMessage"
                       Progress="ProgressService.CurrentProgress" />

    <AlertMessage Message="@_errorMessage" Type="AlertType.Error" />
    <AlertMessage Message="@_successMessage" Type="AlertType.Success" />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Form -->
        <div class="card">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-dark-text-primary mb-4">Fetch Historical Data</h2>

            <EditForm Model="@_formModel" OnValidSubmit="@HandleFetchData" class="space-y-4">
                <DataAnnotationsValidator />

                <div>
                    <label for="ticker" class="block text-sm font-medium text-gray-700 dark:text-dark-text-primary mb-1">Ticker Symbol *</label>
                    <InputText id="ticker" @bind-Value="_formModel.Ticker"
                               @oninput="@(async (ChangeEventArgs e) => { _formModel.Ticker = e.Value?.ToString() ?? string.Empty; await OnFormFieldChanged(); })"
                               class="w-full rounded-lg border-gray-300 dark:border-dark-border bg-white dark:bg-dark-elevated text-gray-900 dark:text-dark-text-primary focus:border-trading-blue dark:focus:border-dark-accent-blue focus:ring-trading-blue dark:focus:ring-dark-accent-blue" />
                    <ValidationMessage For="@(() => _formModel.Ticker)" class="text-sm text-red-600 dark:text-dark-danger mt-1" />
                </div>

                <div>
                    <label for="isin" class="block text-sm font-medium text-gray-700 dark:text-dark-text-primary mb-1">ISIN (Optional)</label>
                    <InputText id="isin" @bind-Value="_formModel.ISIN"
                               @oninput="@(async (ChangeEventArgs e) => { _formModel.ISIN = e.Value?.ToString(); await OnFormFieldChanged(); })"
                               class="w-full rounded-lg border-gray-300 dark:border-dark-border bg-white dark:bg-dark-elevated text-gray-900 dark:text-dark-text-primary focus:border-trading-blue dark:focus:border-dark-accent-blue focus:ring-trading-blue dark:focus:ring-dark-accent-blue" />
                    <p class="text-xs text-gray-500 dark:text-dark-text-secondary mt-1">International Securities Identification Number for ticker resolution</p>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="start-date" class="block text-sm font-medium text-gray-700 dark:text-dark-text-primary mb-1">Start Date</label>
                        <InputDate id="start-date" @bind-Value="_formModel.StartDate"
                                   @onchange="@(async () => await OnFormFieldChanged())"
                                   class="w-full rounded-lg border-gray-300 dark:border-dark-border bg-white dark:bg-dark-elevated text-gray-900 dark:text-dark-text-primary focus:border-trading-blue dark:focus:border-dark-accent-blue focus:ring-trading-blue dark:focus:ring-dark-accent-blue" />
                    </div>
                    <div>
                        <label for="end-date" class="block text-sm font-medium text-gray-700 dark:text-dark-text-primary mb-1">End Date</label>
                        <InputDate id="end-date" @bind-Value="_formModel.EndDate"
                                   @onchange="@(async () => await OnFormFieldChanged())"
                                   class="w-full rounded-lg border-gray-300 dark:border-dark-border bg-white dark:bg-dark-elevated text-gray-900 dark:text-dark-text-primary focus:border-trading-blue dark:focus:border-dark-accent-blue focus:ring-trading-blue dark:focus:ring-dark-accent-blue" />
                    </div>
                </div>

                <button type="submit" disabled="@ProgressService.IsProcessing" class="btn-primary w-full">
                    @if (ProgressService.IsProcessing)
                    {
                        <span>Fetching Data...</span>
                    }
                    else
                    {
                        <span>Fetch Data</span>
                    }
                </button>
            </EditForm>
        </div>

        <!-- Results -->
        @if (_result != null)
        {
            <div class="card">
                <h2 class="text-xl font-semibold text-gray-900 dark:text-dark-text-primary mb-4">Data Summary</h2>

                <dl class="space-y-3">
                    <div>
                        <dt class="text-sm font-medium text-gray-500 dark:text-dark-text-secondary">Ticker</dt>
                        <dd class="text-lg font-semibold text-gray-900 dark:text-dark-text-primary">@_result.Ticker</dd>
                    </div>

                    @if (!string.IsNullOrEmpty(_result.ISIN))
                    {
                        <div>
                            <dt class="text-sm font-medium text-gray-500 dark:text-dark-text-secondary">ISIN</dt>
                            <dd class="text-lg font-semibold text-gray-900 dark:text-dark-text-primary">@_result.ISIN</dd>
                        </div>
                    }

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <dt class="text-sm font-medium text-gray-500 dark:text-dark-text-secondary">Total Records</dt>
                            <dd class="text-2xl font-bold text-gray-900 dark:text-dark-text-primary">@_result.TotalRecords.ToString("N0")</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500 dark:text-dark-text-secondary">New Records</dt>
                            <dd class="text-2xl font-bold text-trading-green dark:text-dark-success">+@_result.NewRecords.ToString("N0")</dd>
                        </div>
                    </div>

                    @if (_result.OldestDate.HasValue && _result.LatestDate.HasValue)
                    {
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <dt class="text-sm font-medium text-gray-500 dark:text-dark-text-secondary">Oldest Date</dt>
                                <dd class="text-sm text-gray-900 dark:text-dark-text-primary">@_result.OldestDate.Value.ToString("yyyy-MM-dd")</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500 dark:text-dark-text-secondary">Latest Date</dt>
                                <dd class="text-sm text-gray-900 dark:text-dark-text-primary">@_result.LatestDate.Value.ToString("yyyy-MM-dd")</dd>
                            </div>
                        </div>
                    }

                    @if (_result.MinPrice.HasValue && _result.MaxPrice.HasValue && _result.LatestClose.HasValue)
                    {
                        <div class="grid grid-cols-3 gap-4">
                            <div>
                                <dt class="text-sm font-medium text-gray-500 dark:text-dark-text-secondary">Min Price</dt>
                                <dd class="text-sm text-gray-900 dark:text-dark-text-primary">@_result.MinPrice.Value.ToString("C2")</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500 dark:text-dark-text-secondary">Max Price</dt>
                                <dd class="text-sm text-gray-900 dark:text-dark-text-primary">@_result.MaxPrice.Value.ToString("C2")</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500 dark:text-dark-text-secondary">Latest Close</dt>
                                <dd class="text-sm font-semibold text-trading-blue dark:text-dark-accent-blue">@_result.LatestClose.Value.ToString("C2")</dd>
                            </div>
                        </div>
                    }
                </dl>
            </div>
        }
    </div>

    @if (_result != null)
    {
        <TradingViewWidget Ticker="@_result.Ticker" />
    }

    @if (_result != null)
    {
        <AiDataAnalysisPanel DataSummary="_result" />
    }
</div>

@code {
    private const string FORM_KEY = "data-fetch-form";

    private DataFetchFormModel _formModel = new();
    private DataSummaryResult? _result;
    private string? _errorMessage;
    private string? _successMessage;

    protected override async Task OnInitializedAsync()
    {
        ProgressService.OnProgressChanged += StateHasChanged;

        // Try to restore saved form state
        DataFetchFormModel? savedForm = await FormState.GetFormStateAsync<DataFetchFormModel>(FORM_KEY);
        if (savedForm != null)
        {
            _formModel = savedForm;
        }
        else
        {
            // Initialize from user preferences
            Models.State.UserPreferences prefs = await PreferencesService.GetPreferencesAsync();
            _formModel = DataFetchFormModel.FromPreferences(prefs, Configuration.Value);
        }
    }

    private async Task OnFormFieldChanged()
    {
        await FormState.SaveFormStateAsync(FORM_KEY, _formModel);
    }

    private async Task HandleFetchData()
    {
        _errorMessage = null;
        _successMessage = null;
        _result = null;

        ProgressService.Reset();

        var progress = new Progress<string>(message =>
        {
            InvokeAsync(() => ProgressService.UpdateProgress(message));
        });

        try
        {
            var command = new FetchDataCommand(
                _formModel.Ticker,
                _formModel.ISIN,
                _formModel.StartDate,
                _formModel.EndDate
            );

            _result = await DataFetchingUseCase.ExecuteAsync(command, progress);
            _successMessage = $"Successfully fetched {_result.NewRecords} new records for {_result.Ticker}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error fetching data: {ex.Message}";
        }
        finally
        {
            await InvokeAsync(() => ProgressService.Reset());
        }
    }

    public void Dispose()
    {
        ProgressService.OnProgressChanged -= StateHasChanged;
    }
}
