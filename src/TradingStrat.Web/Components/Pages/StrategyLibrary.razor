@page "/strategies/library"
@rendermode InteractiveServer
@using TradingStrat.Web.Components.UI.Typography
@using TradingStrat.Web.Components.UI.Buttons
@using TradingStrat.Web.Components.UI.DataDisplay
@using TradingStrat.Web.Components.UI.Overlays.Dialog
@using TradingStrat.Web.Components.UI

<PageTitle>Strategy Library | TradingStrat</PageTitle>

<div class="space-y-6">
    <!-- Breadcrumb Navigation -->
    <BreadcrumbNav Breadcrumbs="@_breadcrumbs" />

    <!-- Page Header -->
    <PageHeader Title="Strategy Library"
                Description="Browse built-in strategies or create your own custom trading strategies">
        <Actions>
            <TradingStrat.Web.Components.UI.Buttons.Button Color="ButtonColor.Blue" OnClick="@NavigateToBuilder">
                <span class="mr-2">+</span> Create Strategy
            </TradingStrat.Web.Components.UI.Buttons.Button>
        </Actions>
    </PageHeader>

    <!-- Tabs -->
    <div class="mb-6 border-b border-gray-200 dark:border-gray-700">
        <nav class="flex space-x-8">
            <button type="button"
                    class="@GetTabClass(StrategyTab.BuiltIn)"
                    @onclick="() => SetActiveTab(StrategyTab.BuiltIn)">
                Built-in Strategies
                <Badge Color="BadgeColor.Gray" Class="ml-2">5</Badge>
            </button>
            <button type="button"
                    class="@GetTabClass(StrategyTab.Custom)"
                    @onclick="() => SetActiveTab(StrategyTab.Custom)">
                My Strategies
                <Badge Color="BadgeColor.Gray" Class="ml-2">@_customStrategies.Count</Badge>
            </button>
        </nav>
    </div>

    <!-- Loading State -->
    @if (_isLoading)
    {
        <LoadingState Message="Loading strategies..." />
    }
    else
    {
        <!-- Built-in Strategies Tab -->
        @if (_activeTab == StrategyTab.BuiltIn)
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var strategy in _builtInStrategies)
                {
                    <div class="bg-white dark:bg-zinc-900 rounded-lg border border-gray-200 dark:border-zinc-800 p-6 hover:border-gray-300 dark:hover:border-zinc-700 transition-colors">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <Heading Level="3" Class="text-lg font-semibold text-gray-900 dark:text-white">
                                    @strategy.Name
                                </Heading>
                                <Badge Color="BadgeColor.Blue" Class="mt-1">@strategy.Category</Badge>
                            </div>
                        </div>

                        <TradingStrat.Web.Components.UI.Typography.Text Class="text-sm text-gray-600 dark:text-gray-400 mb-6 min-h-[3rem]">
                            @strategy.Description
                        </TradingStrat.Web.Components.UI.Typography.Text>

                        <div class="space-y-2 mb-6 text-sm">
                            <div class="flex justify-between">
                                <span class="text-gray-600 dark:text-gray-400">Key:</span>
                                <span class="font-mono text-gray-900 dark:text-white">@strategy.Key</span>
                            </div>
                            @if (strategy.DefaultParameters.Any())
                            {
                                <div class="flex justify-between">
                                    <span class="text-gray-600 dark:text-gray-400">Parameters:</span>
                                    <span class="text-gray-900 dark:text-white">
                                        @string.Join(", ", strategy.DefaultParameters.Select(p => $"{p.Key}={p.Value}"))
                                    </span>
                                </div>
                            }
                        </div>

                        <TradingStrat.Web.Components.UI.Buttons.Button Color="ButtonColor.Blue" OnClick="@(() => NavigateToBacktest(strategy.Key))" Class="w-full">
                            Run Backtest
                        </TradingStrat.Web.Components.UI.Buttons.Button>
                    </div>
                }
            </div>
        }

        <!-- Custom Strategies Tab -->
        @if (_activeTab == StrategyTab.Custom)
        {
            @if (!_customStrategies.Any())
            {
                <div class="text-center py-12">
                    <div class="text-6xl mb-4">📊</div>
                    <Heading Level="3" Class="text-xl font-semibold text-gray-900 dark:text-white mb-2">
                        No Custom Strategies Yet
                    </Heading>
                    <TradingStrat.Web.Components.UI.Typography.Text Class="text-gray-600 dark:text-gray-400 mb-6">
                        Create your first custom strategy to get started
                    </TradingStrat.Web.Components.UI.Typography.Text>
                    <TradingStrat.Web.Components.UI.Buttons.Button Color="ButtonColor.Blue" OnClick="@NavigateToBuilder">
                        <span class="mr-2">+</span> Create Your First Strategy
                    </TradingStrat.Web.Components.UI.Buttons.Button>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    @foreach (var strategy in _customStrategies)
                    {
                        <div class="bg-white dark:bg-zinc-900 rounded-lg border border-gray-200 dark:border-zinc-800 p-6 hover:border-gray-300 dark:hover:border-zinc-700 transition-colors">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <Heading Level="3" Class="text-lg font-semibold text-gray-900 dark:text-white">
                                        @strategy.Name
                                    </Heading>
                                    <Badge Color="BadgeColor.Green" Class="mt-1">@strategy.Category</Badge>
                                </div>
                                <div class="text-xs text-gray-500 dark:text-gray-400">
                                    @strategy.LastUpdatedAt.ToString("MMM d, yyyy")
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(strategy.Description))
                            {
                                <TradingStrat.Web.Components.UI.Typography.Text Class="text-sm text-gray-600 dark:text-gray-400 mb-6 min-h-[3rem]">
                                    @strategy.Description
                                </TradingStrat.Web.Components.UI.Typography.Text>
                            }

                            <div class="space-y-2 mb-6 text-sm">
                                <div class="flex justify-between">
                                    <span class="text-gray-600 dark:text-gray-400">Author:</span>
                                    <span class="text-gray-900 dark:text-white">@strategy.Author</span>
                                </div>
                                <div class="flex justify-between">
                                    <span class="text-gray-600 dark:text-gray-400">Entry Rules:</span>
                                    <span class="text-gray-900 dark:text-white">@strategy.Definition.EntryRules.Count</span>
                                </div>
                                <div class="flex justify-between">
                                    <span class="text-gray-600 dark:text-gray-400">Exit Rules:</span>
                                    <span class="text-gray-900 dark:text-white">@strategy.Definition.ExitRules.Count</span>
                                </div>
                                @if (strategy.TimesUsed > 0)
                                {
                                    <div class="flex justify-between">
                                        <span class="text-gray-600 dark:text-gray-400">Times Used:</span>
                                        <span class="text-gray-900 dark:text-white">@strategy.TimesUsed</span>
                                    </div>
                                }
                                @if (strategy.LastBacktestReturn.HasValue)
                                {
                                    <div class="flex justify-between">
                                        <span class="text-gray-600 dark:text-gray-400">Last Return:</span>
                                        <span class="@(strategy.LastBacktestReturn.Value >= 0 ? "metric-positive" : "metric-negative")">
                                            @strategy.LastBacktestReturn.Value.ToString("P2")
                                        </span>
                                    </div>
                                }
                            </div>

                            <div class="grid grid-cols-2 gap-3">
                                <TradingStrat.Web.Components.UI.Buttons.Button Color="ButtonColor.Zinc" Outline="true" OnClick="@(() => NavigateToEdit(strategy.Id))">
                                    Edit
                                </TradingStrat.Web.Components.UI.Buttons.Button>
                                <TradingStrat.Web.Components.UI.Buttons.Button Color="ButtonColor.Zinc" Outline="true" OnClick="@(() => CloneStrategy(strategy.Id))">
                                    Clone
                                </TradingStrat.Web.Components.UI.Buttons.Button>
                                <TradingStrat.Web.Components.UI.Buttons.Button Color="ButtonColor.Indigo" OnClick="@(() => NavigateToOptimize(strategy.Id))">
                                    Optimize
                                </TradingStrat.Web.Components.UI.Buttons.Button>
                                <TradingStrat.Web.Components.UI.Buttons.Button Color="ButtonColor.Blue" OnClick="@(() => NavigateToBacktestWithCustom(strategy.Id))">
                                    Test
                                </TradingStrat.Web.Components.UI.Buttons.Button>
                            </div>

                            <TradingStrat.Web.Components.UI.Buttons.Button Color="ButtonColor.Red" OnClick="@(() => ShowDeleteDialog(strategy.Id, strategy.Name))" Class="w-full mt-3">
                                Delete
                            </TradingStrat.Web.Components.UI.Buttons.Button>
                        </div>
                    }
                </div>
            }
        }
    }

    @* Delete Confirmation Dialog *@
    <TradingStrat.Web.Components.UI.Overlays.Dialog.Dialog IsOpen="_showDeleteDialog" IsOpenChanged="@((isOpen) => _showDeleteDialog = isOpen)" Size="DialogSize.Small">
        <TradingStrat.Web.Components.UI.Overlays.Dialog.DialogTitle>Delete Strategy</TradingStrat.Web.Components.UI.Overlays.Dialog.DialogTitle>
        <TradingStrat.Web.Components.UI.Overlays.Dialog.DialogDescription>
            Are you sure you want to delete '<strong>@_strategyToDeleteName</strong>'? This action cannot be undone.
        </TradingStrat.Web.Components.UI.Overlays.Dialog.DialogDescription>
        <TradingStrat.Web.Components.UI.Overlays.Dialog.DialogActions>
            <TradingStrat.Web.Components.UI.Buttons.Button Color="ButtonColor.Zinc" Outline="true" OnClick="@CancelDelete">
                Cancel
            </TradingStrat.Web.Components.UI.Buttons.Button>
            <TradingStrat.Web.Components.UI.Buttons.Button Color="ButtonColor.Red" OnClick="@ConfirmDelete">
                Delete
            </TradingStrat.Web.Components.UI.Buttons.Button>
        </TradingStrat.Web.Components.UI.Overlays.Dialog.DialogActions>
    </TradingStrat.Web.Components.UI.Overlays.Dialog.Dialog>
</div>
