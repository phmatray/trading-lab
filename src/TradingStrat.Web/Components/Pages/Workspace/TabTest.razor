@using TradingStrat.Application.Ports.Inbound
@using TradingStrat.Domain.Entities
@using TradingStrat.Domain.Strategies
@using TradingStrat.Web.Models
@inject IBacktestUseCase BacktestUseCase
@inject NotificationService Notifications
@inject ProgressService ProgressService

<div class="space-y-6">
    @if (Strategy == null)
    {
        <div class="card text-center py-12">
            <p class="text-gray-600 dark:text-dark-text-secondary">
                No strategy selected. Please define a strategy first.
            </p>
        </div>
    }
    else
    {
        <div class="card">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-dark-text-primary mb-4">
                Test Strategy
            </h2>
            <p class="text-gray-600 dark:text-dark-text-secondary mb-6">
                Run a backtest to evaluate <strong>@Strategy.Name</strong> performance on historical data.
            </p>

            <!-- Configuration Form -->
            <EditForm Model="@_config" OnValidSubmit="RunBacktest" class="space-y-4">
                <DataAnnotationsValidator />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Ticker -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-dark-text-secondary mb-2">
                            Ticker Symbol
                        </label>
                        <InputText @bind-Value="_config.Ticker"
                                   class="w-full px-4 py-2 border border-gray-300 dark:border-dark-border rounded-lg bg-white dark:bg-dark-bg-secondary text-gray-900 dark:text-dark-text-primary focus:ring-2 focus:ring-trading-blue dark:focus:ring-dark-accent-blue focus:border-transparent"
                                   placeholder="AAPL" />
                        <ValidationMessage For="@(() => _config.Ticker)" class="text-red-600 dark:text-red-400 text-sm mt-1" />
                    </div>

                    <!-- Initial Capital -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-dark-text-secondary mb-2">
                            Initial Capital ($)
                        </label>
                        <InputNumber @bind-Value="_config.InitialCapital"
                                     class="w-full px-4 py-2 border border-gray-300 dark:border-dark-border rounded-lg bg-white dark:bg-dark-bg-secondary text-gray-900 dark:text-dark-text-primary focus:ring-2 focus:ring-trading-blue dark:focus:ring-dark-accent-blue focus:border-transparent" />
                        <ValidationMessage For="@(() => _config.InitialCapital)" class="text-red-600 dark:text-red-400 text-sm mt-1" />
                    </div>

                    <!-- Start Date -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-dark-text-secondary mb-2">
                            Start Date
                        </label>
                        <InputDate @bind-Value="_config.StartDate"
                                   class="w-full px-4 py-2 border border-gray-300 dark:border-dark-border rounded-lg bg-white dark:bg-dark-bg-secondary text-gray-900 dark:text-dark-text-primary focus:ring-2 focus:ring-trading-blue dark:focus:ring-dark-accent-blue focus:border-transparent" />
                        <ValidationMessage For="@(() => _config.StartDate)" class="text-red-600 dark:text-red-400 text-sm mt-1" />
                    </div>

                    <!-- End Date -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-dark-text-secondary mb-2">
                            End Date
                        </label>
                        <InputDate @bind-Value="_config.EndDate"
                                   class="w-full px-4 py-2 border border-gray-300 dark:border-dark-border rounded-lg bg-white dark:bg-dark-bg-secondary text-gray-900 dark:text-dark-text-primary focus:ring-2 focus:ring-trading-blue dark:focus:ring-dark-accent-blue focus:border-transparent" />
                        <ValidationMessage For="@(() => _config.EndDate)" class="text-red-600 dark:text-red-400 text-sm mt-1" />
                    </div>

                    <!-- Commission % -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-dark-text-secondary mb-2">
                            Commission (%)
                        </label>
                        <InputNumber @bind-Value="_config.CommissionPercentage"
                                     class="w-full px-4 py-2 border border-gray-300 dark:border-dark-border rounded-lg bg-white dark:bg-dark-bg-secondary text-gray-900 dark:text-dark-text-primary focus:ring-2 focus:ring-trading-blue dark:focus:ring-dark-accent-blue focus:border-transparent" />
                        <ValidationMessage For="@(() => _config.CommissionPercentage)" class="text-red-600 dark:text-red-400 text-sm mt-1" />
                    </div>

                    <!-- Minimum Commission -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-dark-text-secondary mb-2">
                            Minimum Commission ($)
                        </label>
                        <InputNumber @bind-Value="_config.MinimumCommission"
                                     class="w-full px-4 py-2 border border-gray-300 dark:border-dark-border rounded-lg bg-white dark:bg-dark-bg-secondary text-gray-900 dark:text-dark-text-primary focus:ring-2 focus:ring-trading-blue dark:focus:ring-dark-accent-blue focus:border-transparent" />
                        <ValidationMessage For="@(() => _config.MinimumCommission)" class="text-red-600 dark:text-red-400 text-sm mt-1" />
                    </div>
                </div>

                <div class="flex justify-end pt-4">
                    <button type="submit"
                            disabled="@_isRunning"
                            class="btn-primary disabled:opacity-50 disabled:cursor-not-allowed">
                        @if (_isRunning)
                        {
                            <span class="flex items-center gap-2">
                                <span class="animate-spin rounded-full h-4 w-4 border-b-2 border-white"></span>
                                Running Backtest...
                            </span>
                        }
                        else
                        {
                            <span>Run Backtest</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>

        <!-- Results -->
        @if (_result != null)
        {
            <div class="card">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-dark-text-primary mb-4">
                    Backtest Results
                </h3>

                <!-- Summary Cards -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                    <div class="p-4 bg-gray-50 dark:bg-dark-bg-tertiary rounded-lg">
                        <div class="text-sm text-gray-600 dark:text-dark-text-secondary mb-1">Total Return</div>
                        <div class="text-xl font-bold @(_result.Metrics.TotalReturnPercentage >= 0 ? "text-green-600 dark:text-green-400" : "text-red-600 dark:text-red-400")">
                            @_result.Metrics.TotalReturnPercentage.ToString("+0.00%;-0.00%;0.00%")
                        </div>
                    </div>

                    <div class="p-4 bg-gray-50 dark:bg-dark-bg-tertiary rounded-lg">
                        <div class="text-sm text-gray-600 dark:text-dark-text-secondary mb-1">Sharpe Ratio</div>
                        <div class="text-xl font-bold text-gray-900 dark:text-dark-text-primary">
                            @_result.Metrics.SharpeRatio.ToString("F2")
                        </div>
                    </div>

                    <div class="p-4 bg-gray-50 dark:bg-dark-bg-tertiary rounded-lg">
                        <div class="text-sm text-gray-600 dark:text-dark-text-secondary mb-1">Max Drawdown</div>
                        <div class="text-xl font-bold text-red-600 dark:text-red-400">
                            @_result.Metrics.MaxDrawdown.ToString("F2%")
                        </div>
                    </div>

                    <div class="p-4 bg-gray-50 dark:bg-dark-bg-tertiary rounded-lg">
                        <div class="text-sm text-gray-600 dark:text-dark-text-secondary mb-1">Win Rate</div>
                        <div class="text-xl font-bold text-gray-900 dark:text-dark-text-primary">
                            @_result.Metrics.WinRate.ToString("F1%")
                        </div>
                    </div>
                </div>

                <div class="flex gap-4">
                    <button @onclick="() => OnTestComplete.InvokeAsync(_result)"
                            class="btn-primary">
                        Continue to Deploy →
                    </button>
                    <a href="/backtests" class="btn-secondary">
                        View in Archive
                    </a>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public CustomStrategy? Strategy { get; set; }
    [Parameter] public EventCallback<BacktestResult> OnTestComplete { get; set; }

    private TestConfig _config = new();
    private BacktestResult? _result;
    private bool _isRunning;

    protected override void OnParametersSet()
    {
        if (Strategy != null && string.IsNullOrEmpty(_config.Ticker))
        {
            // Initialize with defaults
            _config.Ticker = "AAPL";
            _config.StartDate = DateTime.Today.AddYears(-2);
            _config.EndDate = DateTime.Today;
        }
    }

    private async Task RunBacktest()
    {
        if (Strategy == null)
        {
            return;
        }

        _isRunning = true;
        _result = null;

        try
        {
            BacktestCommand command = new(
                Ticker: _config.Ticker,
                StrategyType: StrategyType.RSI, // Placeholder
                StrategyParameters: new Dictionary<string, object>(),
                InitialCapital: _config.InitialCapital,
                CommissionPercentage: _config.CommissionPercentage,
                MinimumCommission: _config.MinimumCommission,
                StartDate: _config.StartDate,
                EndDate: _config.EndDate,
                TimeFrame: null,
                TradingStyle: null,
                CustomStrategyId: Strategy.Id
            );

            IProgress<BacktestProgress> progress = new Progress<BacktestProgress>(p =>
            {
                int percentage = p.Total > 0 ? (int)((double)p.Current / p.Total * 100) : 0;
                string message = $"Processing bar {p.Current}/{p.Total} ({p.Trades} trades executed)";
                ProgressService.UpdateProgress(message, percentage);
            });

            _result = await BacktestUseCase.ExecuteAsync(command, progress);

            await Notifications.AddNotificationAsync(
                NotificationType.System,
                NotificationSeverity.Success,
                "Backtest Complete",
                "Backtest completed successfully");
        }
        catch (Exception ex)
        {
            await Notifications.AddNotificationAsync(
                NotificationType.System,
                NotificationSeverity.Error,
                "Backtest Failed",
                $"Backtest failed: {ex.Message}");
        }
        finally
        {
            _isRunning = false;
            ProgressService.Reset();
        }
    }

    private class TestConfig
    {
        public string Ticker { get; set; } = "AAPL";
        public DateTime StartDate { get; set; } = DateTime.Today.AddYears(-2);
        public DateTime EndDate { get; set; } = DateTime.Today;
        public decimal InitialCapital { get; set; } = 10000m;
        public decimal CommissionPercentage { get; set; } = 0.1m;
        public decimal MinimumCommission { get; set; } = 1.0m;
    }
}
