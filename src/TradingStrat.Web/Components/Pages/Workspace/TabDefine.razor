<div class="space-y-6">
    <div class="card">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-dark-text-primary mb-4">
            Define Strategy
        </h2>
        <p class="text-gray-600 dark:text-dark-text-secondary mb-6">
            Create a new strategy or load an existing one from your library.
        </p>

        <!-- Quick Actions -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <a href="/strategies/builder"
               class="block p-6 border-2 border-gray-200 dark:border-dark-border rounded-lg hover:border-trading-blue dark:hover:border-dark-accent-blue transition-colors">
                <div class="flex items-start gap-4">
                    <div class="p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
                        <svg class="w-6 h-6 text-trading-blue dark:text-dark-accent-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-gray-900 dark:text-dark-text-primary mb-1">
                            Create New Strategy
                        </h3>
                        <p class="text-sm text-gray-600 dark:text-dark-text-secondary">
                            Build a custom strategy using the visual rule builder
                        </p>
                    </div>
                </div>
            </a>

            <button @onclick="LoadExistingStrategy"
                    class="block p-6 border-2 border-gray-200 dark:border-dark-border rounded-lg hover:border-trading-blue dark:hover:border-dark-accent-blue transition-colors text-left">
                <div class="flex items-start gap-4">
                    <div class="p-3 bg-green-50 dark:bg-green-900/20 rounded-lg">
                        <svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-gray-900 dark:text-dark-text-primary mb-1">
                            Load from Library
                        </h3>
                        <p class="text-sm text-gray-600 dark:text-dark-text-secondary">
                            Select an existing custom strategy
                        </p>
                    </div>
                </div>
            </button>
        </div>

        @if (_showStrategyLibrary)
        {
            <div class="border-t border-gray-200 dark:border-dark-border pt-6">
                <h3 class="font-semibold text-gray-900 dark:text-dark-text-primary mb-4">
                    Your Strategies
                </h3>

                @if (_strategies == null)
                {
                    <div class="text-center py-8">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-trading-blue dark:border-dark-accent-blue mx-auto"></div>
                        <p class="mt-4 text-gray-600 dark:text-dark-text-secondary">Loading strategies...</p>
                    </div>
                }
                else if (!_strategies.Any())
                {
                    <div class="text-center py-8">
                        <p class="text-gray-600 dark:text-dark-text-secondary">
                            No custom strategies found. Create one using the Strategy Builder.
                        </p>
                    </div>
                }
                else
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        @foreach (CustomStrategyResult strategy in _strategies)
                        {
                            <button @onclick="() => SelectStrategy(strategy.Id)"
                                    class="p-4 border border-gray-200 dark:border-dark-border rounded-lg hover:border-trading-blue dark:hover:border-dark-accent-blue transition-colors text-left">
                                <h4 class="font-semibold text-gray-900 dark:text-dark-text-primary mb-1">
                                    @strategy.Name
                                </h4>
                                <p class="text-sm text-gray-600 dark:text-dark-text-secondary mb-2">
                                    @strategy.Description
                                </p>
                                <div class="flex gap-2 text-xs text-gray-500 dark:text-dark-text-muted">
                                    <span class="px-2 py-1 bg-gray-100 dark:bg-dark-bg-tertiary rounded">
                                        @strategy.Category
                                    </span>
                                    <span class="px-2 py-1 bg-gray-100 dark:bg-dark-bg-tertiary rounded">
                                        Used @strategy.TimesUsed times
                                    </span>
                                </div>
                            </button>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>
