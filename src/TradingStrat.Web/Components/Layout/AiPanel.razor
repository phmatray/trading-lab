@* AiPanel Component - Fixed right panel with AI insights and chat (replaces AiAssistantWidget) *@

<aside class="@GetPanelClasses()"
       data-testid="ai-panel"
       role="complementary"
       aria-label="AI Assistant">
    <div class="h-full flex flex-col bg-white dark:bg-dark-card border-l border-gray-200 dark:border-dark-border">
        <!-- Panel Header -->
        <div class="flex items-center @(IsCollapsed ? "justify-center" : "justify-between") px-4 py-3 bg-trading-blue dark:bg-dark-accent-blue text-white border-b border-gray-200 dark:border-dark-border">
            @if (!IsCollapsed)
            {
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                    </svg>
                    <h3 class="font-semibold">Trading Assistant</h3>
                </div>
            }

            <button @onclick="ToggleCollapse"
                    class="hover:bg-blue-700 dark:hover:bg-blue-500 p-1 rounded transition-colors"
                    aria-label="@(IsCollapsed ? "Expand panel" : "Collapse panel")"
                    type="button">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@(IsCollapsed ? "M15 19l-7-7 7-7" : "M9 5l7 7-7 7")"></path>
                </svg>
            </button>
        </div>

        @if (!IsCollapsed)
        {
            <!-- AI Recommendations Section -->
            <div class="p-4 border-b border-gray-200 dark:border-dark-border space-y-4">
                <!-- Market Regime -->
                <div>
                    <p class="text-xs text-gray-500 dark:text-dark-text-secondary mb-1">Market Regime</p>
                    <div class="flex items-center gap-2">
                        <span class="text-lg font-semibold @GetRegimeColorClass()">@CurrentRegime</span>
                        <span class="text-2xl">@GetRegimeIcon()</span>
                    </div>
                </div>

                <!-- Current Recommendation -->
                @if (!string.IsNullOrEmpty(CurrentRecommendation))
                {
                    <div>
                        <p class="text-xs text-gray-500 dark:text-dark-text-secondary mb-2">Current Recommendation</p>
                        <div class="flex items-center gap-2 mb-2">
                            <span class="font-bold @GetRecommendationColorClass()">@CurrentRecommendation</span>
                            @if (Confidence.HasValue)
                            {
                                <span class="text-sm text-gray-600 dark:text-dark-text-secondary">
                                    @Confidence.Value% confidence
                                </span>
                            }
                        </div>

                        <!-- Confidence Bar -->
                        @if (Confidence.HasValue)
                        {
                            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                                <div class="@GetConfidenceBarClass() h-2 rounded-full transition-all duration-300"
                                     style="width: @Confidence.Value%"></div>
                            </div>
                        }

                        <!-- Reasons -->
                        @if (Reasons != null && Reasons.Any())
                        {
                            <ul class="mt-3 space-y-1 text-sm text-gray-700 dark:text-dark-text-primary">
                                @foreach (var reason in Reasons.Take(3))
                                {
                                    <li class="flex items-start gap-2">
                                        <span class="text-trading-blue mt-0.5">•</span>
                                        <span>@reason</span>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                }
            </div>

            <!-- Chat Section -->
            <div class="flex-1 flex flex-col overflow-hidden">
                <!-- Messages container -->
                <div @ref="_messagesContainer" class="flex-1 overflow-y-auto p-4 space-y-4 bg-gray-50 dark:bg-dark-bg">
                    @foreach (var msg in _messages)
                    {
                        <div class="flex @(msg.IsUser ? "justify-end" : "justify-start") items-end gap-2">
                            @if (!msg.IsUser)
                            {
                                <!-- Robot avatar for assistant -->
                                <div class="flex-shrink-0 w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center shadow-lg">
                                    <span class="text-lg">🤖</span>
                                </div>
                            }
                            <div class="max-w-[80%] @(msg.IsUser ? "bg-trading-blue dark:bg-dark-accent-blue text-white" : "bg-white dark:bg-dark-elevated text-gray-800 dark:text-dark-text-primary border border-gray-200 dark:border-dark-border") rounded-lg px-4 py-2 shadow">
                                <p class="text-sm whitespace-pre-wrap">@msg.Content</p>
                            </div>
                        </div>
                    }

                    @if (_isStreaming && !string.IsNullOrEmpty(_streamingMessage))
                    {
                        <div class="flex justify-start items-end gap-2">
                            <!-- Robot avatar for streaming -->
                            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center shadow-lg">
                                <span class="text-lg">🤖</span>
                            </div>
                            <div class="max-w-[80%] bg-white dark:bg-dark-elevated text-gray-800 dark:text-dark-text-primary border border-gray-200 dark:border-dark-border rounded-lg px-4 py-2 shadow">
                                <p class="text-sm whitespace-pre-wrap">@_streamingMessage</p>
                                <div class="typing-indicator mt-2">
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Input area -->
                <div class="border-t border-gray-200 dark:border-dark-border p-4 bg-white dark:bg-dark-card">
                    <div class="flex gap-2">
                        <input @bind="_userInput"
                               @bind:event="oninput"
                               @onkeypress="HandleKeyPress"
                               type="text"
                               placeholder="Ask about strategies, positions, or market data..."
                               class="flex-1 px-3 py-2 border border-gray-300 dark:border-dark-border rounded-lg focus:outline-none focus:ring-2 focus:ring-trading-blue dark:focus:ring-dark-accent-blue bg-white dark:bg-dark-elevated text-gray-900 dark:text-dark-text-primary placeholder-gray-400 dark:placeholder-dark-text-secondary"
                               disabled="@_isStreaming" />
                        <button @onclick="SendMessageAsync"
                                disabled="@(_isStreaming || string.IsNullOrWhiteSpace(_userInput))"
                                class="px-4 py-2 bg-trading-blue dark:bg-dark-accent-blue text-white rounded-lg hover:bg-blue-700 dark:hover:bg-blue-500 transition-colors disabled:bg-gray-400 dark:disabled:bg-gray-600 disabled:cursor-not-allowed">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                            </svg>
                        </button>
                    </div>
                    <button @onclick="ClearHistoryAsync"
                            class="text-xs text-gray-500 dark:text-dark-text-secondary hover:text-gray-700 dark:hover:text-dark-text-primary mt-2 transition-colors">
                        Clear history
                    </button>
                </div>
            </div>
        }
    </div>
</aside>

