@using TradingStrat.Web.Components.UI.Navigation.Sidebar
@* LeftSidebar Component - Vertical icon-based navigation with Catalyst components *@

<aside class="@GetSidebarClasses()"
       data-testid="left-sidebar"
       role="navigation"
       aria-label="Main navigation">
    <div class="h-full flex flex-col bg-white dark:bg-dark-card border-r border-gray-200 dark:border-dark-border">
        <!-- Navigation Items -->
        <Sidebar Class="flex-1 py-4 px-2 overflow-y-auto">
            @{
                IEnumerable<IGrouping<string, NavItem>> groups = _navItems.GroupBy(i => i.Group);
                bool isFirstGroup = true;
            }

            @foreach (IGrouping<string, NavItem> group in groups)
            {
                @* Group divider (collapsed) or header (expanded) *@
                @if (!isFirstGroup)
                {
                    <SidebarDivider Class="my-2" />
                }

                <SidebarSection>
                    @if (!IsCollapsed)
                    {
                        <SidebarHeading Class="px-2">
                            @group.Key
                        </SidebarHeading>
                    }

                    @* Menu items *@
                    @foreach (var item in group)
                    {
                        <SidebarItem Href="@item.Href"
                                   Current="@IsCurrentRoute(item.Href, item.Match)"
                                   title="@GetTooltipText(item)"
                                   aria-label="@GetTooltipText(item)">
                            <!-- Icon -->
                            <svg data-slot="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                @GetIconPath(item.Icon)
                            </svg>

                            <!-- Label (hidden when collapsed) -->
                            @if (!IsCollapsed)
                            {
                                <span>@item.Label</span>
                            }
                        </SidebarItem>
                    }
                </SidebarSection>

                isFirstGroup = false;
            }
        </Sidebar>

        <!-- Toggle Button -->
        <SidebarFooter>
            <button @onclick="ToggleCollapse"
                    class="w-full flex items-center @(IsCollapsed ? "justify-center" : "justify-between") p-2 text-gray-500 hover:text-gray-700 dark:text-dark-text-secondary dark:hover:text-dark-text-primary rounded transition-colors"
                    aria-label="@(IsCollapsed ? "Expand sidebar" : "Collapse sidebar")"
                    type="button">
                @if (!IsCollapsed)
                {
                    <span class="text-sm">Collapse</span>
                }
                <svg class="w-5 h-5 @(IsCollapsed ? "" : "rotate-180")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path>
                </svg>
            </button>
        </SidebarFooter>
    </div>
</aside>
