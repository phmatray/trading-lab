@inherits LayoutComponentBase
@inject Services.LocalStorageService LocalStorage
@implements IAsyncDisposable

<!-- Skip to main content link for screen readers -->
<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-blue-600 dark:focus:bg-dark-accent-blue focus:text-white focus:rounded">
    Skip to main content
</a>

<div class="min-h-screen bg-gray-50 dark dark:bg-dark-bg flex flex-col">
    <!-- Top Bar (64px fixed) -->
    <TopBar SelectedPortfolioName="@_selectedPortfolioName"
            PortfolioValue="@_portfolioValue"
            YTDPerformance="@_ytdPerformance" />

    <!-- Main Container (below TopBar) -->
    <div class="flex flex-1 overflow-hidden pt-16">
        <!-- Left Sidebar -->
        <LeftSidebar IsCollapsed="_sidebarCollapsed"
                     IsCollapsedChanged="OnSidebarCollapsedChanged" />

        <!-- Main Content Area (flexible width) -->
        <main id="main-content"
              class="flex-1 overflow-y-auto p-6 transition-all duration-300"
              style="margin-left: @(_sidebarCollapsed ? "4rem" : "16rem"); margin-right: @(_aiPanelCollapsed ? "3rem" : "24rem");"
              role="main"
              aria-label="Main content">
            @Body
        </main>

        <!-- Right AI Panel -->
        <AiPanel IsCollapsed="_aiPanelCollapsed"
                 IsCollapsedChanged="OnAiPanelCollapsedChanged"
                 CurrentTicker="@_currentTicker"
                 CurrentContext="@_currentContext"
                 CurrentRegime="@_currentRegime"
                 CurrentRecommendation="@_currentRecommendation"
                 Confidence="@_confidence"
                 Reasons="@_reasons" />
    </div>

    <!-- Notification Toast Container (preserved) -->
    <NotificationToastContainer />
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    // Layout state
    private bool _sidebarCollapsed = false;
    private bool _aiPanelCollapsed = false;

#pragma warning disable CS0649 // Field is never assigned to (placeholder for future implementation)
    // TopBar data (placeholder - will be populated from services)
    private string? _selectedPortfolioName = null;
    private decimal? _portfolioValue = null;
    private decimal? _ytdPerformance = null;

    // AI Panel data (placeholder - will be populated from context)
    private string? _currentTicker = null;
    private string? _currentContext = null;
    private string _currentRegime = "NEUTRAL";
    private string? _currentRecommendation = null;
    private int? _confidence = null;
    private List<string>? _reasons = null;
#pragma warning restore CS0649

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Load collapse states from localStorage (must be in OnAfterRenderAsync for JS interop)
            var sidebarState = await LocalStorage.GetItemAsync<bool?>("layout_sidebar_collapsed");
            if (sidebarState.HasValue && sidebarState.Value != _sidebarCollapsed)
            {
                _sidebarCollapsed = sidebarState.Value;
                StateHasChanged();
            }

            var aiPanelState = await LocalStorage.GetItemAsync<bool?>("layout_aipanel_collapsed");
            if (aiPanelState.HasValue && aiPanelState.Value != _aiPanelCollapsed)
            {
                _aiPanelCollapsed = aiPanelState.Value;
                StateHasChanged();
            }

            // TODO: Load portfolio data from PortfolioStateService
            // TODO: Load AI recommendations from appropriate service
        }
    }

    private async Task OnSidebarCollapsedChanged(bool value)
    {
        _sidebarCollapsed = value;
        await LocalStorage.SetItemAsync("layout_sidebar_collapsed", _sidebarCollapsed);
    }

    private async Task OnAiPanelCollapsedChanged(bool value)
    {
        _aiPanelCollapsed = value;
        await LocalStorage.SetItemAsync("layout_aipanel_collapsed", _aiPanelCollapsed);
    }

    public async ValueTask DisposeAsync()
    {
        // Cleanup if needed
        await Task.CompletedTask;
    }
}
