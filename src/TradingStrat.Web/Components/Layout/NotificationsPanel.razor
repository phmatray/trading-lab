@* NotificationsPanel - Content area for Notifications tab (migrated from NotificationCenter) *@

<div class="flex flex-col h-full overflow-hidden">
    <!-- Action Bar (if notifications exist) -->
    @if (_notifications.Any(n => !n.IsRead))
    {
        <div class="flex items-center justify-end px-4 py-2 border-b border-gray-200 dark:border-dark-border bg-black">
            <button @onclick="MarkAllAsRead"
                    class="text-sm text-white hover:underline"
                    type="button">
                Mark all read
            </button>
        </div>
    }

    <!-- Notifications List -->
    <div class="flex-1 overflow-y-auto divide-y divide-gray-200 dark:divide-dark-border">
        @if (!_notifications.Any())
        {
            <!-- Empty State -->
            <div class="flex flex-col items-center justify-center h-full p-8 text-center">
                <svg class="mx-auto w-12 h-12 text-gray-400 dark:text-dark-text-secondary mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
                <p class="text-sm text-gray-500 dark:text-dark-text-secondary">No notifications yet</p>
            </div>
        }
        else
        {
            @foreach (KeyValuePair<string, List<Notification>> group in GetGroupedNotifications())
            {
                <div>
                    <div class="sticky top-0 bg-gray-50 dark:bg-dark-elevated px-4 py-2 text-xs font-semibold text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">
                        @group.Key
                    </div>
                    @foreach (var notification in group.Value)
                    {
                        <div class="@GetNotificationItemClasses(notification)"
                             data-notification-item
                             data-is-read="@notification.IsRead.ToString().ToLower()"
                             @onclick="() => HandleNotificationClick(notification)">
                            <div class="flex items-start gap-3 p-4 cursor-pointer hover:bg-gray-50 dark:hover:bg-dark-elevated transition-colors">
                                <!-- Icon -->
                                <div class="flex-shrink-0 mt-1">
                                    <div class="@GetNotificationIconClasses(notification)">
                                        @GetNotificationIcon(notification)
                                    </div>
                                </div>

                                <!-- Content -->
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-semibold text-gray-900 dark:text-dark-text-primary">
                                        @notification.Title
                                    </p>
                                    <p class="mt-1 text-sm text-gray-600 dark:text-dark-text-secondary">
                                        @notification.Message
                                    </p>
                                    <p class="mt-1 text-xs text-gray-500 dark:text-dark-text-secondary">
                                        @GetRelativeTime(notification.Timestamp)
                                    </p>
                                    @if (notification.Action is not null)
                                    {
                                        <span class="inline-flex items-center mt-2 text-xs font-medium text-trading-blue dark:text-dark-accent-blue">
                                            @notification.Action.Label
                                            <svg class="ml-1 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                            </svg>
                                        </span>
                                    }
                                </div>

                                <!-- Unread indicator -->
                                @if (!notification.IsRead)
                                {
                                    <div class="flex-shrink-0">
                                        <div class="w-2 h-2 bg-trading-blue dark:bg-dark-accent-blue rounded-full"></div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>

    <!-- Footer -->
    @if (_notifications.Any())
    {
        <div class="p-4 border-t border-gray-200 dark:border-dark-border">
            <button @onclick="ClearAll"
                    class="w-full text-sm text-center text-red-600 dark:text-red-400 hover:text-red-700 dark:hover:text-red-300 font-medium"
                    type="button">
                Clear all notifications
            </button>
        </div>
    }
</div>
