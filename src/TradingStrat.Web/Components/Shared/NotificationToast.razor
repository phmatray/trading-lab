<div class="@ContainerClasses" role="alert" aria-live="assertive" aria-atomic="true" data-testid="notification-toast">
    <div class="flex items-start gap-3">
        <!-- Icon -->
        <div class="flex-shrink-0">
            @if (Notification != null)
            {
                <svg class="@IconClasses" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    @switch (Notification.Severity)
                    {
                        case NotificationSeverity.Success:
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            break;
                        case NotificationSeverity.Warning:
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                            break;
                        case NotificationSeverity.Error:
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            break;
                        default:
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            break;
                    }
                </svg>
            }
        </div>

        <!-- Content -->
        <div class="flex-1 min-w-0">
            @if (Notification != null)
            {
                <p class="text-sm font-semibold @TextClasses">@Notification.Title</p>
                <p class="mt-1 text-sm @TextClasses opacity-90">@Notification.Message</p>

                @if (Notification.Action != null)
                {
                    <button @onclick="HandleActionClick"
                            class="mt-2 text-sm font-medium underline @TextClasses hover:opacity-80 transition-opacity">
                        @Notification.Action.Label
                    </button>
                }
            }
        </div>

        <!-- Close button -->
        <button @onclick="HandleDismiss"
                type="button"
                class="flex-shrink-0 rounded-lg p-1.5 @CloseButtonClasses hover:opacity-80 transition-opacity focus:outline-none focus:ring-2 focus:ring-offset-2"
                aria-label="Dismiss"
                data-testid="dismiss-button">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
        </button>
    </div>
</div>
