@* ConfirmDialog Component - Specialized dialog for confirming dangerous actions *@

<Dialog IsOpen="@IsOpen"
        OnClose="@HandleCancel"
        Title="@Title"
        Width="@Width"
        CloseOnBackdropClick="false">
    <ChildContent>
        <div class="text-center">
            <!-- Icon -->
            <svg class="mx-auto h-12 w-12 @GetIconColor() mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                @if (Type == ConfirmType.Danger)
                {
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                }
                else if (Type == ConfirmType.Warning)
                {
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                }
                else
                {
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                }
            </svg>

            <!-- Message -->
            <p class="text-sm text-gray-600 dark:text-dark-text-secondary mb-6">
                @Message
            </p>
        </div>
    </ChildContent>
    <Footer>
        <div class="flex space-x-3">
            <button @onclick="HandleCancel"
                    disabled="@IsProcessing"
                    type="button"
                    class="flex-1 px-4 py-2 bg-gray-200 dark:bg-dark-elevated text-gray-700 dark:text-dark-text-primary rounded-lg hover:bg-gray-300 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                @CancelText
            </button>
            <button @onclick="HandleConfirm"
                    disabled="@IsProcessing"
                    type="button"
                    class="flex-1 px-4 py-2 @GetConfirmButtonClass() text-white rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                @if (IsProcessing)
                {
                    <span>@ProcessingText</span>
                }
                else
                {
                    <span>@ConfirmText</span>
                }
            </button>
        </div>
    </Footer>
</Dialog>
