<div class="fixed top-4 right-4 z-50 flex flex-col gap-3" aria-live="polite" aria-atomic="false">
    @foreach (var toast in _activeToasts)
    {
        <NotificationToast Notification="@toast"
                          OnDismiss="@(() => RemoveToast(toast))"
                          AutoDismissMs="5000" />
    }
</div>
