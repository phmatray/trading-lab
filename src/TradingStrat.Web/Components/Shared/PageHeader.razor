@* PageHeader Component - Standardized page title, description, and action buttons *@

<div class="flex items-center justify-between" data-testid="page-header">
    <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-dark-text-primary">@Title</h1>
        @if (!string.IsNullOrEmpty(Description))
        {
            <p class="mt-1 text-sm text-gray-600 dark:text-dark-text-secondary">
                @Description
            </p>
        }
    </div>

    @if (Actions is not null)
    {
        <div class="flex items-center gap-3">
            @Actions
        </div>
    }
</div>
