@* Data coverage table showing ticker-by-ticker breakdown *@

<div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-dark-border">
        <thead class="bg-gray-50 dark:bg-dark-bg-tertiary">
            <tr>
                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">
                    Ticker
                </th>
                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">
                    Records
                </th>
                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">
                    Date Range
                </th>
                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">
                    Coverage
                </th>
                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">
                    Status
                </th>
            </tr>
        </thead>
        <tbody class="bg-white dark:bg-dark-bg-secondary divide-y divide-gray-200 dark:divide-dark-border">
            @foreach (var ticker in TickerStatuses)
            {
                <tr class="hover:bg-gray-50 dark:hover:bg-dark-bg-tertiary">
                    <!-- Ticker -->
                    <td class="px-4 py-3 whitespace-nowrap">
                        <div class="text-sm font-medium text-gray-900 dark:text-dark-text-primary">
                            @ticker.Ticker
                        </div>
                        @if (!string.IsNullOrEmpty(ticker.ISIN))
                        {
                            <div class="text-xs text-gray-500 dark:text-dark-text-muted">
                                @ticker.ISIN
                            </div>
                        }
                    </td>

                    <!-- Record Count -->
                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900 dark:text-dark-text-primary">
                        @ticker.RecordCount.ToString("N0")
                    </td>

                    <!-- Date Range -->
                    <td class="px-4 py-3 whitespace-nowrap">
                        @if (ticker.OldestDate is not null && ticker.LatestDate is not null)
                        {
                            <div class="text-sm text-gray-900 dark:text-dark-text-primary">
                                @ticker.OldestDate.Value.ToString("MMM dd, yyyy")
                            </div>
                            <div class="text-xs text-gray-500 dark:text-dark-text-muted">
                                to @ticker.LatestDate.Value.ToString("MMM dd, yyyy")
                            </div>
                        }
                        else
                        {
                            <span class="text-sm text-gray-500 dark:text-dark-text-muted">N/A</span>
                        }
                    </td>

                    <!-- Coverage Percentage -->
                    <td class="px-4 py-3 whitespace-nowrap">
                        <div class="flex items-center">
                            <div class="flex-1">
                                <div class="text-sm font-medium text-gray-900 dark:text-dark-text-primary">
                                    @ticker.CoveragePercentage.ToString("F1")%
                                </div>
                                <div class="mt-1 w-full bg-gray-200 dark:bg-dark-border rounded-full h-1.5">
                                    <div class="@GetCoverageBarColor(ticker.CoveragePercentage) h-1.5 rounded-full"
                                         style="width: @ticker.CoveragePercentage.ToString("F1")%"></div>
                                </div>
                            </div>
                        </div>
                    </td>

                    <!-- Status & Gaps -->
                    <td class="px-4 py-3 whitespace-nowrap">
                        @if (ticker.Gaps.Any())
                        {
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400">
                                <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                                </svg>
                                @ticker.Gaps.Count gap@(ticker.Gaps.Count > 1 ? "s" : "")
                            </span>
                        }
                        else if (ticker.CoveragePercentage >= 95)
                        {
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400">
                                <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                                </svg>
                                Complete
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-900/30 dark:text-gray-400">
                                Partial
                            </span>
                        }
                    </td>
                </tr>

                <!-- Gap Details (Expandable) -->
                @if (ticker.Gaps.Any())
                {
                    <tr class="bg-yellow-50 dark:bg-yellow-900/10">
                        <td colspan="5" class="px-4 py-2">
                            <details class="text-sm">
                                <summary class="cursor-pointer text-gray-700 dark:text-dark-text-secondary font-medium">
                                    View @ticker.Gaps.Count gap@(ticker.Gaps.Count > 1 ? "s" : "") in data
                                </summary>
                                <div class="mt-2 space-y-1">
                                    @foreach (var gap in ticker.Gaps.OrderByDescending(g => g.DaysMissing).Take(5))
                                    {
                                        <div class="text-xs text-gray-600 dark:text-dark-text-muted">
                                            <span class="font-medium">@gap.DaysMissing days missing:</span>
                                            @gap.StartDate.ToString("MMM dd, yyyy") - @gap.EndDate.ToString("MMM dd, yyyy")
                                        </div>
                                    }
                                    @if (ticker.Gaps.Count > 5)
                                    {
                                        <div class="text-xs text-gray-500 dark:text-dark-text-muted italic">
                                            ... and @(ticker.Gaps.Count - 5) more
                                        </div>
                                    }
                                </div>
                            </details>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
