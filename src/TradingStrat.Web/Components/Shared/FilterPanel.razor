@using TradingStrat.Application.Ports.Inbound

<div class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
    <!-- Header with Collapse Toggle -->
    <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 flex items-center gap-2">
            <Icon Name="funnel" Size="IconSize.Small" />
            Filters
        </h3>

        <div class="flex items-center gap-2">
            @if (HasActiveFilters)
            {
                <Button
                    Text="Reset"
                    OnClick="HandleReset"
                    Variant="ButtonVariant.Secondary"
                    Size="ButtonSize.Small"
                    IconName="x-mark"
                />
            }

            <button
                type="button"
                @onclick="ToggleCollapse"
                class="p-1 text-gray-500 hover:text-gray-700 dark:hover:text-gray-300"
                aria-label="@(_isCollapsed ? "Expand filters" : "Collapse filters")"
            >
                <Icon
                    Name="@(_isCollapsed ? "chevron-down" : "chevron-up")"
                    Size="IconSize.Small"
                />
            </button>
        </div>
    </div>

    <!-- Filter Controls (Collapsible) -->
    @if (!_isCollapsed)
    {
        <div class="space-y-4">
            <!-- Status Filter -->
            <div>
                <label for="status-filter" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Status
                </label>
                <select
                    id="status-filter"
                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-2 focus:ring-blue-500"
                    value="@StatusFilter?.ToString()"
                    @onchange="HandleStatusFilterChanged"
                >
                    <option value="">All Statuses</option>
                    <option value="@DataStatusFilter.Complete">Complete</option>
                    <option value="@DataStatusFilter.Partial">Partial</option>
                    <option value="@DataStatusFilter.WithGaps">With Gaps</option>
                </select>
            </div>

            <!-- Coverage Range Filter -->
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Coverage Range
                </label>

                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label for="min-coverage" class="block text-xs text-gray-600 dark:text-gray-400 mb-1">
                            Min %
                        </label>
                        <input
                            id="min-coverage"
                            type="number"
                            min="0"
                            max="100"
                            step="1"
                            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-2 focus:ring-blue-500"
                            value="@MinCoverage"
                            @onchange="HandleMinCoverageChanged"
                            placeholder="0"
                        />
                    </div>

                    <div>
                        <label for="max-coverage" class="block text-xs text-gray-600 dark:text-gray-400 mb-1">
                            Max %
                        </label>
                        <input
                            id="max-coverage"
                            type="number"
                            min="0"
                            max="100"
                            step="1"
                            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-2 focus:ring-blue-500"
                            value="@MaxCoverage"
                            @onchange="HandleMaxCoverageChanged"
                            placeholder="100"
                        />
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    /// <summary>
    /// The selected status filter.
    /// </summary>
    [Parameter]
    public DataStatusFilter? StatusFilter { get; set; }

    /// <summary>
    /// Minimum coverage percentage filter.
    /// </summary>
    [Parameter]
    public decimal? MinCoverage { get; set; }

    /// <summary>
    /// Maximum coverage percentage filter.
    /// </summary>
    [Parameter]
    public decimal? MaxCoverage { get; set; }

    /// <summary>
    /// Callback invoked when any filter changes.
    /// </summary>
    [Parameter]
    public EventCallback<FilterValues> OnFilterChanged { get; set; }

    /// <summary>
    /// Callback invoked when filters are reset.
    /// </summary>
    [Parameter]
    public EventCallback OnReset { get; set; }

    private bool _isCollapsed = false;

    private bool HasActiveFilters =>
        StatusFilter.HasValue || MinCoverage.HasValue || MaxCoverage.HasValue;

    private void ToggleCollapse()
    {
        _isCollapsed = !_isCollapsed;
    }

    private async Task HandleStatusFilterChanged(ChangeEventArgs e)
    {
        DataStatusFilter? newFilter = null;
        if (!string.IsNullOrEmpty(e.Value?.ToString()) &&
            Enum.TryParse<DataStatusFilter>(e.Value.ToString(), out DataStatusFilter parsedFilter))
        {
            newFilter = parsedFilter;
        }

        await OnFilterChanged.InvokeAsync(new FilterValues(newFilter, MinCoverage, MaxCoverage));
    }

    private async Task HandleMinCoverageChanged(ChangeEventArgs e)
    {
        decimal? newMin = null;
        if (decimal.TryParse(e.Value?.ToString(), out decimal parsedMin))
        {
            newMin = parsedMin;
        }

        await OnFilterChanged.InvokeAsync(new FilterValues(StatusFilter, newMin, MaxCoverage));
    }

    private async Task HandleMaxCoverageChanged(ChangeEventArgs e)
    {
        decimal? newMax = null;
        if (decimal.TryParse(e.Value?.ToString(), out decimal parsedMax))
        {
            newMax = parsedMax;
        }

        await OnFilterChanged.InvokeAsync(new FilterValues(StatusFilter, MinCoverage, newMax));
    }

    private async Task HandleReset()
    {
        await OnReset.InvokeAsync();
    }

    /// <summary>
    /// Value object containing all filter values.
    /// </summary>
    public record FilterValues(
        DataStatusFilter? StatusFilter,
        decimal? MinCoverage,
        decimal? MaxCoverage);
}
