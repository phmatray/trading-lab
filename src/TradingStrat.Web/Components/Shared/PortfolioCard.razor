@using TradingStrat.Web.Components.UI.Typography
@using Microsoft.AspNetCore.Components.Web

<div class="bg-white dark:bg-zinc-900 rounded-lg border border-gray-200 dark:border-zinc-800 p-6 hover:border-gray-300 dark:hover:border-zinc-700 transition-colors cursor-pointer focus-within:ring-2 focus-within:ring-trading-blue dark:focus-within:ring-dark-accent-blue"
     role="button"
     tabindex="0"
     @onclick="HandleClick"
     @onkeydown="HandleKeyDown"
     aria-label="View portfolio: @Name">
    <div class="flex justify-between items-start mb-4">
        <div class="flex-1">
            <Heading Level="3" Class="text-lg font-semibold text-gray-900 dark:text-white mb-1">
                @Name
            </Heading>
            @if (!string.IsNullOrEmpty(Description))
            {
                <TradingStrat.Web.Components.UI.Typography.Text Class="text-sm text-gray-600 dark:text-gray-400">
                    @Description
                </TradingStrat.Web.Components.UI.Typography.Text>
            }
        </div>
        <button @onclick="HandleDeleteClick"
                @onclick:stopPropagation="true"
                class="text-gray-400 hover:text-red-600 dark:hover:text-dark-danger transition-colors p-1"
                aria-label="Delete portfolio: @Name"
                title="Delete @Name">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
            </svg>
        </button>
    </div>

    <div class="space-y-3">
        <div class="flex justify-between items-center">
            <span class="text-sm text-gray-600 dark:text-gray-400">Cash Balance</span>
            <span class="text-lg font-semibold text-gray-900 dark:text-white">@Cash.ToString("C2")</span>
        </div>

        <div class="flex justify-between items-center">
            <span class="text-sm text-gray-600 dark:text-gray-400">Positions</span>
            <span class="text-lg font-semibold text-gray-900 dark:text-white">@PositionCount</span>
        </div>

        <div class="pt-3 border-t border-gray-200 dark:border-zinc-800">
            <span class="text-xs text-gray-500 dark:text-gray-400">
                Created @CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
            </span>
        </div>
    </div>
</div>
