@* MetricCardGrid Component - Data-driven grid of metric cards *@

<div class="grid grid-cols-1 @GetGridClass() gap-6" data-testid="metric-card-grid">
    @foreach (var metric in Metrics)
    {
        <div class="card">
            <div class="flex items-center justify-between">
                <div class="flex-1">
                    <!-- Label -->
                    <p class="text-sm font-medium text-gray-600 dark:text-dark-text-secondary mb-1">
                        @metric.Label
                    </p>

                    <!-- Value -->
                    <p class="text-2xl font-bold @GetValueColorClass(metric)">
                        @metric.Value
                    </p>

                    <!-- Subtitle -->
                    @if (!string.IsNullOrEmpty(metric.Subtitle))
                    {
                        <p class="text-xs text-gray-500 dark:text-dark-text-secondary mt-1">
                            @metric.Subtitle
                        </p>
                    }
                </div>

                <!-- Optional Icon -->
                @if (!string.IsNullOrEmpty(metric.Icon))
                {
                    <div class="ml-4">
                        <svg class="w-8 h-8 text-gray-400 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            @GetIconPath(metric.Icon)
                        </svg>
                    </div>
                }
            </div>
        </div>
    }
</div>
