@if (Trades != null && Trades.Count > 0)
{
    <div class="card overflow-x-auto">
        <h3 class="text-lg font-semibold mb-4 dark:text-dark-text-primary">Trade History (@Trades.Count trades)</h3>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-dark-border">
                <thead class="bg-gray-50 dark:bg-dark-elevated">
                    <tr>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Date</th>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Type</th>
                        <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Price</th>
                        <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Quantity</th>
                        <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Commission</th>
                        <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Net Amount</th>
                        <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">P/L</th>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider">Reason</th>
                    </tr>
                </thead>
                <tbody class="bg-white dark:bg-dark-card divide-y divide-gray-200 dark:divide-dark-border">
                    @foreach (var trade in DisplayedTrades)
                    {
                        <tr class="hover:bg-gray-50 dark:hover:bg-dark-elevated transition-colors">
                            <td class="px-4 py-3 text-sm text-gray-900 dark:text-dark-text-primary whitespace-nowrap">@trade.DateTime.ToString("yyyy-MM-dd")</td>
                            <td class="px-4 py-3 whitespace-nowrap">
                                <span class="px-2 py-1 text-xs font-semibold rounded-full @(trade.Type == TradeType.Buy ? "bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400" : "bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-400")">
                                    @trade.Type
                                </span>
                            </td>
                            <td class="px-4 py-3 text-sm text-right text-gray-900 dark:text-dark-text-primary whitespace-nowrap">@trade.Price.ToString("C2")</td>
                            <td class="px-4 py-3 text-sm text-right text-gray-900 dark:text-dark-text-primary whitespace-nowrap">@trade.Quantity</td>
                            <td class="px-4 py-3 text-sm text-right text-gray-600 dark:text-dark-text-secondary whitespace-nowrap">@trade.Commission.ToString("C2")</td>
                            <td class="px-4 py-3 text-sm text-right text-gray-900 dark:text-dark-text-primary whitespace-nowrap">@trade.NetAmount.ToString("C2")</td>
                            <td class="px-4 py-3 text-sm text-right whitespace-nowrap @(trade.ProfitLoss > 0 ? "metric-positive" : "metric-negative")">
                                @(trade.ProfitLoss?.ToString("C2") ?? "-")
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-600 dark:text-dark-text-secondary">
                                <span class="line-clamp-2" title="@trade.Reason">@trade.Reason</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Trades.Count > MaxDisplayTrades)
        {
            <div class="mt-4 text-center">
                <button @onclick="ToggleShowAll" class="btn-secondary">
                    @(ShowAll ? $"Show Less ({MaxDisplayTrades} trades)" : $"Show All ({Trades.Count} trades)")
                </button>
            </div>
        }
    </div>
}
else
{
    <div class="card">
        <p class="text-gray-500 dark:text-dark-text-secondary">No trades executed.</p>
    </div>
}
