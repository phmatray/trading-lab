@* Catalyst UI Kit - Fieldset Component *@

<fieldset class="@GetClasses()" disabled="@Disabled">
    @ChildContent
</fieldset>

@code {
    /// <summary>
    /// If true, disables all form controls within the fieldset.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Additional CSS classes to apply.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Fieldset content (legend, fields, etc.).
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string GetClasses()
    {
        List<string> classes = ["space-y-8"];

        if (!string.IsNullOrWhiteSpace(Class))
        {
            classes.Add(Class);
        }

        return string.Join(" ", classes);
    }
}
