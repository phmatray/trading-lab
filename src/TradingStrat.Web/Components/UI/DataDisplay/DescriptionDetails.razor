@* Catalyst UI Kit - DescriptionDetails Component (value in key-value pair) *@

<dd class="@GetClasses()">
    @ChildContent
</dd>

@code {
    /// <summary>
    /// Additional CSS classes to apply.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Details content (the "value" in the key-value pair).
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string GetClasses()
    {
        List<string> classes =
        [
            "pb-3",
            "pt-1",
            "text-zinc-950",
            "sm:border-t",
            "sm:border-zinc-950/5",
            "sm:py-3",
            "dark:text-white",
            "sm:dark:border-white/5"
        ];

        if (!string.IsNullOrWhiteSpace(Class))
        {
            classes.Add(Class);
        }

        return string.Join(" ", classes);
    }
}
