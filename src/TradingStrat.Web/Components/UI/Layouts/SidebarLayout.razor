@using TradingStrat.Web.Components.UI.Navigation.Navbar
@using TradingStrat.Web.Components.UI.Overlays.Dialog

<div class="relative isolate flex min-h-svh w-full bg-white max-lg:flex-col lg:bg-zinc-100 dark:bg-zinc-900 dark:lg:bg-zinc-950">
    <!-- Sidebar on desktop -->
    <div class="fixed inset-y-0 left-0 w-64 max-lg:hidden">
        @Sidebar
    </div>

    <!-- Sidebar on mobile (Dialog) -->
    <TradingStrat.Web.Components.UI.Overlays.Dialog.Dialog @bind-IsOpen="@_showSidebar" Size="DialogSize.Small">
        <DialogTitle>Navigation</DialogTitle>
        <DialogDescription>
            <div class="flex h-full flex-col">
                @Sidebar
            </div>
        </DialogDescription>
    </TradingStrat.Web.Components.UI.Overlays.Dialog.Dialog>

    <!-- Navbar on mobile -->
    <header class="flex items-center px-4 lg:hidden">
        <div class="py-2.5">
            <NavbarItem OnClick="@(() => _showSidebar = true)" aria-label="Open navigation">
                <svg data-slot="icon" viewBox="0 0 20 20" aria-hidden="true" class="size-5">
                    <path d="M2 6.75C2 6.33579 2.33579 6 2.75 6H17.25C17.6642 6 18 6.33579 18 6.75C18 7.16421 17.6642 7.5 17.25 7.5H2.75C2.33579 7.5 2 7.16421 2 6.75ZM2 13.25C2 12.8358 2.33579 12.5 2.75 12.5H17.25C17.6642 12.5 18 12.8358 18 13.25C18 13.6642 17.6642 14 17.25 14H2.75C2.33579 14 2 13.6642 2 13.25Z" />
                </svg>
            </NavbarItem>
        </div>
        <div class="min-w-0 flex-1">@Navbar</div>
    </header>

    <!-- Content -->
    <main class="flex flex-1 flex-col pb-2 lg:min-w-0 lg:pt-2 lg:pr-2 lg:pl-64">
        <div class="grow p-6 lg:rounded-lg lg:bg-white lg:p-10 lg:shadow-xs lg:ring-1 lg:ring-zinc-950/5 dark:lg:bg-zinc-900 dark:lg:ring-white/10">
            <div class="mx-auto max-w-6xl">@ChildContent</div>
        </div>
    </main>
</div>

@code {
    [Parameter] public RenderFragment? Navbar { get; set; }
    [Parameter] public RenderFragment? Sidebar { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _showSidebar = false;
}
