<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
    <RootNamespace>TradingStrat.Web</RootNamespace>
    <UserSecretsId>9f4a2a43-6122-4fef-a3cd-66febdea5154</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\TradingStrat.Application\TradingStrat.Application.csproj" />
    <ProjectReference Include="..\TradingStrat.Infrastructure\TradingStrat.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Blazor-ApexCharts" />
    <PackageReference Include="Microsoft.AspNetCore.SignalR.Client" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" />
    <PackageReference Include="Serilog.AspNetCore" />
  </ItemGroup>

  <Target Name="BuildTailwind" BeforeTargets="Build">
    <Exec Command="npm run build:css" WorkingDirectory="$(ProjectDir)" Condition="Exists('$(ProjectDir)node_modules')" />
  </Target>

  <Target Name="CopyMonacoEditor" BeforeTargets="Build">
    <!-- Copy Monaco Editor files from node_modules to wwwroot for browser access -->
    <ItemGroup>
      <MonacoFiles Include="node_modules/monaco-editor/min/**/*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(MonacoFiles)"
          DestinationFiles="@(MonacoFiles->'wwwroot/node_modules/monaco-editor/min/%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"
          Condition="Exists('$(ProjectDir)node_modules/monaco-editor')" />
  </Target>

</Project>
