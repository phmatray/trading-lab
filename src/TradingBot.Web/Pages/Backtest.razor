@page "/backtest"
@using TradingBot.Web.Services
@using TradingBot.Core.Models.Backtest
@using TradingBot.Analytics
@inject IBacktestService BacktestService
@inject ILogger<Backtest> Logger

<PageTitle>Backtest Results - TradingBot</PageTitle>

<TbPageHeader Title="Backtest Results"
            Description="View and analyze historical strategy performance" />

@if (isLoading)
{
    <div class="flex items-center justify-center py-12">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
        <div class="flex">
            <svg class="w-5 h-5 text-red-600 dark:text-red-400 mr-2" fill="none" stroke="currentColor"
                 viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="text-red-800 dark:text-red-300">@errorMessage</p>
        </div>
    </div>
}
else if (backtestResults is null || !backtestResults.Any())
{
    <TbCard ContentClass="p-12">
        <div class="text-center">
            <svg class="w-16 h-16 text-gray-400 dark:text-gray-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
            <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">No backtest results available</h3>
            <p class="text-gray-600 dark:text-gray-400 mb-4">Run a backtest using the CLI to see results here</p>
            <div class="bg-gray-100 dark:bg-gray-700 rounded-md p-4 text-left inline-block">
                <code class="text-sm text-gray-800 dark:text-gray-200">
                    dotnet run --project src/TradingBot.Cli -- backtest --strategy momentum --symbol AAPL
                </code>
            </div>
        </div>
    </TbCard>
}
else
{
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Backtest Results List -->
        <div class="lg:col-span-1">
            <TbBacktestResultsList
                Results="@backtestResults"
                SelectedBacktestId="@selectedBacktestId"
                OnBacktestSelected="@HandleBacktestSelected"
                ComparisonMode="@comparisonMode"
                SelectedForComparison="@selectedForComparison"
                OnToggleComparison="@HandleToggleComparison"/>
        </div>

        <!-- Backtest Detail -->
        <div class="lg:col-span-2">
            @if (selectedBacktest is not null)
            {
                <TbBacktestDetail
                    Backtest="@selectedBacktest"
                    ShowComparison="@ShowComparisonTable"
                    ComparisonResults="@GetComparisonResults()"/>
            }
            else
            {
                <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-12 text-center">
                    <svg class="w-12 h-12 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor"
                         viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"></path>
                    </svg>
                    <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">Select a backtest to view
                        details</h3>
                    <p class="text-gray-600 dark:text-gray-400">Choose a backtest from the list on the left</p>
                </div>
            }
        </div>
    </div>

    @if (comparisonMode && selectedForComparison.Count > 1)
    {
        <div class="mt-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Comparison
                    (@selectedForComparison.Count selected)</h2>
                <button @onclick="@ClearComparison"
                        class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600">
                    Clear Selection
                </button>
            </div>
            <!-- Comparison table will be rendered by TbBacktestDetail when ShowComparison is true -->
        </div>
    }
}

@code {
    private List<BacktestResult>? backtestResults;
    private BacktestResult? selectedBacktest;
    private string? selectedBacktestId;
    private bool isLoading = true;
    private string? errorMessage;
    private bool comparisonMode = false;
    private readonly HashSet<string> selectedForComparison = new();

    private bool ShowComparisonTable => comparisonMode && selectedForComparison.Count > 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadBacktestResultsAsync();
    }

    private async Task LoadBacktestResultsAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            backtestResults = await BacktestService.GetBacktestResultsAsync();
            Logger.LogInformation("Loaded {Count} backtest results", backtestResults?.Count ?? 0);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load backtest results");
            errorMessage = "Failed to load backtest results. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleBacktestSelected(string backtestId)
    {
        try
        {
            selectedBacktestId = backtestId;
            selectedBacktest = await BacktestService.GetBacktestByIdAsync(backtestId);
            Logger.LogInformation("Selected backtest {BacktestId}", backtestId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load backtest details for {BacktestId}", backtestId);
            errorMessage = "Failed to load backtest details. Please try again.";
        }
    }

    private void HandleToggleComparison(string backtestId)
    {
        if (selectedForComparison.Contains(backtestId))
        {
            selectedForComparison.Remove(backtestId);
        }
        else
        {
            selectedForComparison.Add(backtestId);
        }

        comparisonMode = selectedForComparison.Count > 0;
        StateHasChanged();
    }

    private void ClearComparison()
    {
        selectedForComparison.Clear();
        comparisonMode = false;
        StateHasChanged();
    }

    private List<BacktestResult> GetComparisonResults()
    {
        if (backtestResults is null)
        {
            return new List<BacktestResult>();
        }

        return backtestResults
            .Where(b => selectedForComparison.Contains(b.BacktestId))
            .ToList();
    }

}
