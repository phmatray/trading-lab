@page "/strategies"
@using Ardalis.Specification
@using TradingBot.Core.Interfaces
@using TradingBot.Core.Models.Strategy
@using TradingBot.Web.Components.Features.WeeklyCashStrategy
@inject IStrategyManagementService StrategyService
@inject IWeeklyCashManagedStrategyRepository WeeklyCashStrategyRepository
@inject NavigationManager Navigation
@inject IToastService ToastService
@inject ILogger<Strategies> Logger

<PageTitle>Strategy Management - TradingBot</PageTitle>

<TbPageHeader Title="Strategy Management"
            Description="View and manage your trading strategies" />

@if (_isLoading)
{
    <div class="flex justify-center items-center py-12">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
    </div>
}
else if (_error != null)
{
    <div class="bg-red-50 border border-red-200 text-red-800 rounded-lg p-4 mb-6">
        <div class="flex items-start">
            <svg class="w-5 h-5 mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                      clip-rule="evenodd"/>
            </svg>
            <div>
                <h3 class="font-semibold">Error Loading Strategies</h3>
                <p class="text-sm mt-1">@_error</p>
            </div>
        </div>
    </div>
}
else if ((_strategies == null || !_strategies.Any()) && (_weeklyCashStrategies == null || !_weeklyCashStrategies.Any()))
{
    <TbCard ContentClass="p-12">
        <div class="text-center">
            <svg class="w-16 h-16 mx-auto text-gray-400 dark:text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
            </svg>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">No strategies configured</h3>
            <p class="text-gray-600 dark:text-gray-400">There are no trading strategies available. Configure strategies using the CLI
                application.</p>
        </div>
    </TbCard>
}
else
{
    @if (_successMessage != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-800 rounded-lg p-4 mb-6">
            <div class="flex items-start">
                <svg class="w-5 h-5 mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd"
                          d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                          clip-rule="evenodd"/>
                </svg>
                <p>@_successMessage</p>
            </div>
        </div>
    }

    @if (_strategies != null && _strategies.Any())
    {
        <div class="mb-8">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-4">Standard Strategies</h2>
            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                @foreach (var strategy in _strategies)
                {
                    <TbStrategyCard
                        Strategy="@strategy"
                        OnStatusChanged="@HandleStatusChanged"
                        OnConfigure="@HandleConfigure"/>
                }
            </div>
        </div>
    }

    @if (_weeklyCashStrategies != null && _weeklyCashStrategies.Any())
    {
        <div>
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">Weekly Cash-Managed Strategies</h2>
                <button @onclick="NavigateToCreateWeeklyCashStrategy"
                        class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    New Strategy
                </button>
            </div>
            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                @foreach (var strategy in _weeklyCashStrategies)
                {
                    <TbCard>
                        <div class="flex items-center justify-between mb-4">
                            <div class="flex items-center gap-3">
                                <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-100">@strategy.Name</h3>
                                @if (strategy.IsEnabled)
                                {
                                    <span class="px-2 py-1 text-xs font-medium text-green-700 bg-green-100 dark:text-green-100 dark:bg-green-800 rounded-full">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="px-2 py-1 text-xs font-medium text-gray-700 bg-gray-100 dark:text-gray-100 dark:bg-gray-800 rounded-full">
                                        Inactive
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="space-y-2 mb-4">
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-600 dark:text-gray-400">ETP Symbol:</span>
                                <span class="font-medium text-gray-900 dark:text-gray-100">@strategy.EtpSymbol</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-600 dark:text-gray-400">Underlying:</span>
                                <span class="font-medium text-gray-900 dark:text-gray-100">@strategy.UnderlyingSymbol</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-600 dark:text-gray-400">Execution Day:</span>
                                <span class="font-medium text-gray-900 dark:text-gray-100">@GetDayOfWeekName(strategy.ExecutionDayOfWeek)</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-600 dark:text-gray-400">Cash Range:</span>
                                <span class="font-medium text-gray-900 dark:text-gray-100">@strategy.MinCashRatio.ToString("P0") - @strategy.MaxCashRatio.ToString("P0")</span>
                            </div>
                        </div>

                        <div class="flex gap-2 pt-4 border-t border-gray-200 dark:border-gray-700">
                            <button @onclick="() => NavigateToStrategyDetails(strategy.Id)"
                                    class="flex-1 px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm rounded-lg transition-colors">
                                View Details
                            </button>
                            <button @onclick="() => NavigateToStrategyConfig(strategy.Id)"
                                    class="flex-1 px-3 py-2 bg-gray-600 hover:bg-gray-700 text-white text-sm rounded-lg transition-colors">
                                Configure
                            </button>
                        </div>
                    </TbCard>
                }
            </div>
        </div>
    }
}

<!-- Configuration Modal -->
<TbModal IsOpen="@_showConfigModal" IsOpenChanged="@((open) => _showConfigModal = open)" Title="Strategy Configuration" ShowCloseButton="true">
    @if (!string.IsNullOrEmpty(_selectedStrategyName))
    {
        <TbStrategyConfigForm
            @ref="_configForm"
            StrategyName="@_selectedStrategyName"
            OnSave="@HandleSaveConfiguration"
            OnReset="@HandleResetToDefaults"
            OnCancel="@HandleCancelConfiguration" />
    }
</TbModal>

@code {
    private List<IStrategy>? _strategies;
    private List<WeeklyCashManagedStrategy>? _weeklyCashStrategies;
    private bool _isLoading = true;
    private string? _error;
    private string? _successMessage;
    private bool _showConfigModal;
    private string? _selectedStrategyName;
    private TbStrategyConfigForm? _configForm;

    protected override async Task OnInitializedAsync()
    {
        await LoadStrategiesAsync();
        await LoadWeeklyCashStrategiesAsync();
    }

    private async Task LoadStrategiesAsync()
    {
        try
        {
            _isLoading = true;
            _error = null;
            _strategies = await StrategyService.GetAllStrategiesAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load strategies: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadWeeklyCashStrategiesAsync()
    {
        try
        {
            // Load all weekly cash strategies (enabled and disabled) for management
            var allStrategies = await WeeklyCashStrategyRepository.GetAllAsync();
            _weeklyCashStrategies = allStrategies.ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load weekly cash strategies");
            _error = $"Failed to load weekly cash strategies: {ex.Message}";
        }
    }

    private async Task HandleStatusChanged(StrategyStatusChangedEventArgs args)
    {
        _successMessage = null;
        _error = null;

        try
        {
            if (args.IsEnabled)
            {
                var result = await StrategyService.EnableStrategyAsync(args.StrategyName);
                if (result)
                {
                    _successMessage = $"Strategy '{args.StrategyName}' has been enabled successfully.";
                }
                else
                {
                    _error = $"Strategy '{args.StrategyName}' not found.";
                }
            }
            else
            {
                var result = await StrategyService.DisableStrategyAsync(args.StrategyName);
                if (result)
                {
                    _successMessage = $"Strategy '{args.StrategyName}' has been disabled successfully.";
                }
                else
                {
                    _error = $"Strategy '{args.StrategyName}' not found.";
                }
            }

            // Reload strategies to reflect changes
            await LoadStrategiesAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to update strategy: {ex.Message}";
        }

        StateHasChanged();
    }

    private void HandleConfigure(string strategyName)
    {
        Logger.LogInformation("Opening configuration modal for strategy: {StrategyName}", strategyName);
        _selectedStrategyName = strategyName;
        _showConfigModal = true;
    }

    private async Task HandleSaveConfiguration(Dictionary<string, object> parameters)
    {
        _error = null;
        _successMessage = null;

        try
        {
            Logger.LogInformation("Saving configuration for strategy: {StrategyName}", _selectedStrategyName);

            var result = await StrategyService.ConfigureStrategyAsync(_selectedStrategyName!, parameters);

            if (result)
            {
                _successMessage = $"Configuration saved successfully for '{_selectedStrategyName}'.";
                ToastService.ShowSuccess("Configuration Saved", _successMessage);

                _showConfigModal = false;
                _selectedStrategyName = null;

                // Reload strategies to reflect changes
                await LoadStrategiesAsync();
            }
            else
            {
                _error = "Failed to save configuration. Please check the parameter values and try again.";
                ToastService.ShowError("Configuration Error", _error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving configuration for strategy: {StrategyName}", _selectedStrategyName);
            _error = $"Failed to save configuration: {ex.Message}";
            ToastService.ShowError("Configuration Error", _error);
        }

        StateHasChanged();
    }

    private async Task HandleResetToDefaults()
    {
        _error = null;
        _successMessage = null;

        try
        {
            Logger.LogInformation("Resetting strategy to defaults: {StrategyName}", _selectedStrategyName);

            var result = await StrategyService.ResetStrategyToDefaultsAsync(_selectedStrategyName!);

            if (result)
            {
                _successMessage = $"Strategy '{_selectedStrategyName}' has been reset to defaults.";
                ToastService.ShowSuccess("Reset Successful", _successMessage);

                // Reload the form to show default values
                if (_configForm != null)
                {
                    await _configForm.ReloadParameters();
                }
            }
            else
            {
                _error = $"Failed to reset strategy '{_selectedStrategyName}'.";
                ToastService.ShowError("Reset Error", _error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error resetting strategy to defaults: {StrategyName}", _selectedStrategyName);
            _error = $"Failed to reset configuration: {ex.Message}";
            ToastService.ShowError("Reset Error", _error);
        }

        StateHasChanged();
    }

    private void HandleCancelConfiguration()
    {
        Logger.LogInformation("Cancelling configuration for strategy: {StrategyName}", _selectedStrategyName);
        _showConfigModal = false;
        _selectedStrategyName = null;
    }

    private void NavigateToCreateWeeklyCashStrategy()
    {
        Navigation.NavigateTo("/weekly-cash-strategy/config");
    }

    private void NavigateToStrategyDetails(Guid strategyId)
    {
        Navigation.NavigateTo($"/weekly-cash-strategy/{strategyId}");
    }

    private void NavigateToStrategyConfig(Guid strategyId)
    {
        Navigation.NavigateTo($"/weekly-cash-strategy/config/{strategyId}");
    }

    private static string GetDayOfWeekName(int dayOfWeek)
    {
        return dayOfWeek switch
        {
            0 => "Sunday",
            1 => "Monday",
            2 => "Tuesday",
            3 => "Wednesday",
            4 => "Thursday",
            5 => "Friday",
            6 => "Saturday",
            _ => "Unknown"
        };
    }

    public class StrategyStatusChangedEventArgs
    {
        public string StrategyName { get; set; } = string.Empty;
        public bool IsEnabled { get; set; }
    }

}
