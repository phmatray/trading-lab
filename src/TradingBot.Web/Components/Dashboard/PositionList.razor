@using TradingBot.Core.Models

<div class="card-trading">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-100">Open Positions</h2>
        @if (LastUpdated.HasValue)
        {
            <span class="text-xs text-gray-500 dark:text-gray-400">
                Updated: @LastUpdated.Value.ToString("HH:mm:ss")
            </span>
        }
    </div>

    @if (Positions is not null && Positions.Any())
    {
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-800">
                    <tr>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Symbol</th>
                        <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Quantity</th>
                        <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Entry</th>
                        <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Current</th>
                        <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">P&L</th>
                        <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">P&L %</th>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Strategy</th>
                    </tr>
                </thead>
                <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
                    @foreach (var position in Positions)
                    {
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-800">
                            <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-gray-100">
                                @position.Symbol
                            </td>
                            <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100 text-right">
                                @position.Quantity.ToString("N2")
                            </td>
                            <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100 text-right">
                                @position.EntryPrice.ToString("C2")
                            </td>
                            <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100 text-right">
                                @position.CurrentPrice.ToString("C2")
                            </td>
                            <td class="px-4 py-3 whitespace-nowrap text-sm text-right @GetPnLColorClass(position.UnrealizedPnL)">
                                @position.UnrealizedPnL.ToString("C2")
                            </td>
                            <td class="px-4 py-3 whitespace-nowrap text-sm text-right @GetPnLColorClass(position.UnrealizedPnL)">
                                @position.UnrealizedPnLPercent.ToString("N2")%
                            </td>
                            <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
                                @(position.StrategyName ?? "Manual")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (Positions is not null && !Positions.Any())
    {
        <div class="flex items-center justify-center py-12 bg-gray-50 dark:bg-gray-800 rounded-lg">
            <p class="text-gray-500 dark:text-gray-400">No open positions</p>
        </div>
    }
    else
    {
        <div class="flex items-center justify-center py-8">
            <p class="text-gray-500 dark:text-gray-400">Loading positions...</p>
        </div>
    }
</div>

@code {
    [Parameter]
    public List<Position>? Positions { get; set; }

    [Parameter]
    public DateTime? LastUpdated { get; set; }

    private string GetPnLColorClass(decimal pnl)
    {
        return pnl switch
        {
            > 0 => "stat-positive",
            < 0 => "stat-negative",
            _ => "text-gray-900 dark:text-gray-100"
        };
    }
}
