@using TradingBot.Core.Interfaces

<div class="card-trading">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-100">Active Strategies</h2>
        @if (Strategies is not null)
        {
            <span class="px-3 py-1 text-xs font-semibold rounded-full bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                @Strategies.Count active
            </span>
        }
    </div>

    @if (Strategies is not null && Strategies.Any())
    {
        <div class="space-y-3">
            @foreach (var strategy in Strategies)
            {
                <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:bg-gray-50 dark:hover:bg-gray-800">
                    <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center space-x-3">
                            <span class="w-3 h-3 bg-green-500 rounded-full"></span>
                            <span class="text-base font-semibold text-gray-900 dark:text-gray-100">
                                @strategy.Name
                            </span>
                        </div>
                        <span class="px-2 py-1 text-xs font-medium rounded bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                            Running
                        </span>
                    </div>
                    <div class="grid grid-cols-2 gap-2 text-sm mt-2">
                        <div>
                            <p class="text-gray-500 dark:text-gray-400">Symbols</p>
                            <p class="text-gray-900 dark:text-gray-100 font-medium">
                                @string.Join(", ", strategy.Symbols)
                            </p>
                        </div>
                        <div class="text-right">
                            <p class="text-gray-500 dark:text-gray-400">Timeframe</p>
                            <p class="text-gray-900 dark:text-gray-100 font-medium">
                                @strategy.Timeframe
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (Strategies is not null && !Strategies.Any())
    {
        <div class="flex items-center justify-center py-12 bg-gray-50 dark:bg-gray-800 rounded-lg">
            <div class="text-center">
                <p class="text-gray-500 dark:text-gray-400 mb-2">No active strategies</p>
                <p class="text-xs text-gray-400 dark:text-gray-500">Enable strategies to start trading</p>
            </div>
        </div>
    }
    else
    {
        <div class="flex items-center justify-center py-8">
            <p class="text-gray-500 dark:text-gray-400">Loading strategies...</p>
        </div>
    }
</div>

@code {
    [Parameter]
    public List<IStrategy>? Strategies { get; set; }
}
