@namespace TradingBot.Web.Components.Organisms
@using TradingBot.Web.Components.Atoms
@using TradingBot.Web.Components.Molecules
@using TradingBot.Web.Services
@inject UIStateService UIState
@inject NavigationManager Navigation
@implements IDisposable

<aside class="@GetSidebarClasses()"
       role="navigation"
       aria-label="Main navigation">
    <div class="flex h-full flex-col bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-700">
        <!-- Header with logo and toggle -->
        <div class="flex items-center justify-between p-4 border-b border-gray-200 dark:border-gray-700">
            @if (!UIState.SidebarCollapsed)
            {
                <h1 class="text-xl font-bold text-gray-900 dark:text-gray-100">TradingBot</h1>
            }
            <button @onclick="ToggleSidebar"
                    class="rounded-lg p-2 hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500"
                    aria-label="@GetToggleAriaLabel()"
                    type="button">
                <Icon Name="@GetToggleIcon()" Class="w-6 h-6 text-gray-600 dark:text-gray-400"/>
            </button>
        </div>

        <!-- Navigation Menu -->
        <nav class="flex-1 space-y-1 px-2 py-4 overflow-y-auto">
            @foreach (var item in MenuItems)
            {
                <MenuItem Href="@item.Href"
                          Label="@item.Label"
                          IconName="@item.Icon"
                          IsCollapsed="@UIState.SidebarCollapsed"
                          MatchMode="@item.MatchMode"/>
            }
        </nav>
    </div>
</aside>

@code {

    private sealed record MenuItemInfo(
        string Label,
        string Href,
        IconName Icon,
        NavLinkMatch MatchMode = NavLinkMatch.Prefix);

    private MenuItemInfo[] MenuItems =>
    [
        new("Dashboard", "/", IconName.Home, NavLinkMatch.All),
        new("Portfolio", "/portfolio", IconName.Briefcase),
        new("Performance", "/performance", IconName.ChartBar),
        new("Strategies", "/strategies", IconName.Beaker),
        new("Backtesting", "/backtest", IconName.ChartLine),
        new("Settings", "/settings", IconName.Cog),
    ];

    protected override void OnInitialized()
    {
        UIState.OnStateChanged += StateHasChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    public void Dispose()
    {
        UIState.OnStateChanged -= StateHasChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    private void ToggleSidebar()
    {
        UIState.ToggleSidebar();
    }

    private string GetSidebarClasses()
    {
        var baseClasses = "fixed inset-y-0 left-0 z-50 transition-all duration-300 ease-in-out";
        var widthClass = UIState.SidebarCollapsed ? "w-16" : "w-64";

        return $"{baseClasses} {widthClass}";
    }

    private IconName GetToggleIcon()
    {
        return UIState.SidebarCollapsed ? IconName.ChevronRight : IconName.ChevronLeft;
    }

    private string GetToggleAriaLabel()
    {
        return UIState.SidebarCollapsed ? "Expand sidebar" : "Collapse sidebar";
    }

}
