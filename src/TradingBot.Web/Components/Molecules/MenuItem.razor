@namespace TradingBot.Web.Components.Molecules
@using TradingBot.Web.Components.Atoms
@inject NavigationManager Navigation

<NavLink href="@Href"
         class="@GetClasses()"
         ActiveClass="@GetActiveClass()"
         Match="@MatchMode"
         aria-current="@(IsActive() ? "page" : null)"
         @onkeydown="HandleKeyDown">
    <Icon Name="@IconName"
          Class="@GetIconClasses()"
          AriaLabel="@(IsCollapsed ? Label : null)"/>
    @if (!IsCollapsed)
    {
        <span class="ml-3 text-sm font-medium">@Label</span>
    }
</NavLink>

@code {

    /// <summary>
    /// Gets or sets the navigation href.
    /// </summary>
    [Parameter]
    public string Href { get; set; } = "/";

    /// <summary>
    /// Gets or sets the menu item label.
    /// </summary>
    [Parameter]
    public string Label { get; set; } = "";

    /// <summary>
    /// Gets or sets the icon name to display.
    /// </summary>
    [Parameter]
    public IconName IconName { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether the sidebar is collapsed.
    /// </summary>
    [Parameter]
    public bool IsCollapsed { get; set; }

    /// <summary>
    /// Gets or sets the NavLink match mode.
    /// </summary>
    [Parameter]
    public NavLinkMatch MatchMode { get; set; } = NavLinkMatch.Prefix;

    private string GetClasses()
    {
        var baseClasses = "flex items-center px-3 py-2 rounded-lg transition-colors duration-200 " +
                          "text-gray-700 dark:text-gray-300 " +
                          "hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-gray-100 " +
                          "focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2";

        var collapsedClasses = IsCollapsed ? "justify-center" : "";

        return $"{baseClasses} {collapsedClasses}".Trim();
    }

    private string GetActiveClass()
    {
        return "bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-200 font-semibold";
    }

    private string GetIconClasses()
    {
        return IsCollapsed ? "w-6 h-6" : "w-5 h-5";
    }

    /// <summary>
    /// Checks if this menu item is currently active based on the current navigation URI.
    /// </summary>
    private bool IsActive()
    {
        var currentPath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var targetPath = Href.TrimStart('/');

        if (MatchMode == NavLinkMatch.All)
        {
            return string.Equals(currentPath, targetPath, StringComparison.OrdinalIgnoreCase);
        }

        // Prefix match
        return currentPath.StartsWith(targetPath, StringComparison.OrdinalIgnoreCase) ||
               (string.IsNullOrEmpty(currentPath) && string.IsNullOrEmpty(targetPath));
    }

    /// <summary>
    /// Handles keyboard navigation events.
    /// Enter or Space activates the menu item.
    /// Arrow keys can be used for navigation within the menu (handled by NavigationSidebar).
    /// </summary>
    private void HandleKeyDown(KeyboardEventArgs e)
    {
        // NavLink already handles Enter key natively, but we explicitly support it for clarity
        // Space key also activates the link (standard <a> behavior)
        if (e.Key is "Enter" or " " or "Spacebar")
        {
            Navigation.NavigateTo(Href);
        }
    }

}
