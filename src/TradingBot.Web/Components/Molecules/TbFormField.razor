@namespace TradingBot.Web.Components.Molecules

<div class="@GetContainerClasses()">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label for="@InputId" class="@GetLabelClasses()">
            @Label
            @if (IsRequired)
            {
                <span class="text-red-500" aria-label="required">*</span>
            }
        </label>
    }

    <div class="@GetInputContainerClasses()">
        @InputContent
    </div>

    @if (!string.IsNullOrEmpty(HelpText) && string.IsNullOrEmpty(ErrorMessage))
    {
        <p id="@($"{InputId}-help")" class="@GetHelpTextClasses()">
            @HelpText
        </p>
    }

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <p id="@($"{InputId}-error")" class="@GetErrorClasses()" role="alert">
            @ErrorMessage
        </p>
    }
</div>

@code {
    /// <summary>
    /// Gets or sets the unique identifier for the input element.
    /// </summary>
    [Parameter]
    public string InputId { get; set; } = Guid.NewGuid().ToString();

    /// <summary>
    /// Gets or sets the label text.
    /// </summary>
    [Parameter]
    public string? Label { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether the field is required.
    /// </summary>
    [Parameter]
    public bool IsRequired { get; set; }

    /// <summary>
    /// Gets or sets the help text displayed below the input.
    /// </summary>
    [Parameter]
    public string? HelpText { get; set; }

    /// <summary>
    /// Gets or sets the error message to display.
    /// </summary>
    [Parameter]
    public string? ErrorMessage { get; set; }

    /// <summary>
    /// Gets or sets the input content (Input, Select, Toggle, etc.).
    /// </summary>
    [Parameter]
    public RenderFragment? InputContent { get; set; }

    /// <summary>
    /// Gets or sets additional CSS classes for the container.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    private string GetContainerClasses()
    {
        var baseClasses = "form-field";
        var customClasses = Class ?? string.Empty;
        return $"{baseClasses} {customClasses}".Trim();
    }

    private string GetLabelClasses()
    {
        return "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1";
    }

    private string GetInputContainerClasses()
    {
        return "relative";
    }

    private string GetHelpTextClasses()
    {
        return "mt-1 text-sm text-gray-500 dark:text-gray-400";
    }

    private string GetErrorClasses()
    {
        return "mt-1 text-sm text-red-600 dark:text-red-400";
    }
}
