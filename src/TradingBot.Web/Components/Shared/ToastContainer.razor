  <copyright file="ToastContainer.razor" company="TradingBot">
  Copyright (c) TradingBot. All rights reserved.
  </copyright>
*@

@using TradingBot.Web.Services
@implements IDisposable
@inject IToastService ToastService

<div class="fixed top-4 right-4 z-50 space-y-2" role="region" aria-label="Notifications" aria-live="polite">
    @foreach (var toast in _toasts)
    {
        <div class="@GetToastClasses(toast.Type) rounded-lg shadow-lg p-4 min-w-[320px] max-w-md animate-slide-in-right"
             role="alert"
             aria-atomic="true">
            <div class="flex items-start">
                <div class="flex-shrink-0">
                    @GetIcon(toast.Type)
                </div>
                <div class="ml-3 flex-1">
                    @if (!string.IsNullOrEmpty(toast.Title))
                    {
                        <p class="text-sm font-medium">
                            @toast.Title
                        </p>
                    }
                    <p class="@(string.IsNullOrEmpty(toast.Title) ? "text-sm" : "text-sm mt-1")">
                        @toast.Message
                    </p>
                </div>
                <div class="ml-4 flex-shrink-0 flex">
                    <button @onclick="() => RemoveToast(toast.Id)"
                            class="inline-flex rounded-md hover:opacity-75 focus:outline-none focus:ring-2 focus:ring-offset-2"
                            aria-label="Close notification">
                        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd"
                                  d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                                  clip-rule="evenodd"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private readonly List<ToastMessage> _toasts = new();
    private readonly Dictionary<string, System.Timers.Timer> _timers = new();

    protected override void OnInitialized()
    {
        ToastService.OnToastAdded += HandleToastAdded;
    }

    private void HandleToastAdded(object? sender, ToastMessage toast)
    {
        InvokeAsync(() =>
        {
            _toasts.Add(toast);
            StateHasChanged();

            // Auto-dismiss timer
            var timer = new System.Timers.Timer(toast.DurationMs);
            timer.Elapsed += (_, _) => RemoveToast(toast.Id);
            timer.AutoReset = false;
            timer.Start();
            _timers[toast.Id] = timer;
        });
    }

    private void RemoveToast(string toastId)
    {
        InvokeAsync(() =>
        {
            var toast = _toasts.FirstOrDefault(t => t.Id == toastId);
            if (toast != null)
            {
                _toasts.Remove(toast);

                if (_timers.TryGetValue(toastId, out var timer))
                {
                    timer.Stop();
                    timer.Dispose();
                    _timers.Remove(toastId);
                }

                StateHasChanged();
            }
        });
    }

    private static string GetToastClasses(ToastType type)
    {
        return type switch
        {
            ToastType.Success => "bg-green-50 dark:bg-green-900/20 text-green-800 dark:text-green-200 border-l-4 border-green-500",
            ToastType.Error => "bg-red-50 dark:bg-red-900/20 text-red-800 dark:text-red-200 border-l-4 border-red-500",
            ToastType.Warning => "bg-yellow-50 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-200 border-l-4 border-yellow-500",
            ToastType.Info => "bg-blue-50 dark:bg-blue-900/20 text-blue-800 dark:text-blue-200 border-l-4 border-blue-500",
            _ => "bg-gray-50 dark:bg-gray-800 text-gray-800 dark:text-gray-200",
        };
    }

    private static RenderFragment GetIcon(ToastType type)
    {
        return type switch
        {
            ToastType.Success => @<svg class="h-5 w-5 text-green-500" fill="none" stroke="currentColor"
                                       viewBox="0 0 24 24">
                                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                           d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                 </svg>,
            ToastType.Error => @<svg class="h-5 w-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                         d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                               </svg>,
            ToastType.Warning => @<svg class="h-5 w-5 text-yellow-500" fill="none" stroke="currentColor"
                                       viewBox="0 0 24 24">
                                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                           d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                 </svg>,
            ToastType.Info => @<svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                              </svg>,
            _ => @<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>,
        };
    }

    public void Dispose()
    {
        ToastService.OnToastAdded -= HandleToastAdded;

        foreach (var timer in _timers.Values)
        {
            timer.Stop();
            timer.Dispose();
        }

        _timers.Clear();
    }

}
