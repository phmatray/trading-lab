@namespace TradingBot.Web.Components.Atoms

@typeparam TValue

<select id="@Id"
        value="@CurrentValueAsString"
        @onchange="HandleChange"
        class="@GetSelectClasses()"
        disabled="@IsDisabled"
        aria-invalid="@(HasError ? "true" : null)"
        aria-describedby="@GetAriaDescribedBy()"
        aria-required="@(IsRequired ? "true" : null)">
    @if (ShowPlaceholder && !string.IsNullOrEmpty(Placeholder))
    {
        <option value="" disabled selected>@Placeholder</option>
    }
    @ChildContent
</select>

@code {
    /// <summary>
    /// Gets or sets the unique identifier for the select element.
    /// </summary>
    [Parameter]
    public string Id { get; set; } = Guid.NewGuid().ToString();

    /// <summary>
    /// Gets or sets the selected value.
    /// </summary>
    [Parameter]
    public TValue? Value { get; set; }

    /// <summary>
    /// Gets or sets the event callback for value changes.
    /// </summary>
    [Parameter]
    public EventCallback<TValue?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the placeholder text.
    /// </summary>
    [Parameter]
    public string? Placeholder { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether to show the placeholder.
    /// </summary>
    [Parameter]
    public bool ShowPlaceholder { get; set; } = true;

    /// <summary>
    /// Gets or sets a value indicating whether the select is disabled.
    /// </summary>
    [Parameter]
    public bool IsDisabled { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether the select has an error.
    /// </summary>
    [Parameter]
    public bool HasError { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether the select is required.
    /// </summary>
    [Parameter]
    public bool IsRequired { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether there is help text associated with this select.
    /// </summary>
    [Parameter]
    public bool HasHelpText { get; set; }

    /// <summary>
    /// Gets or sets additional CSS classes.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Gets or sets the child content (option elements).
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string? CurrentValueAsString
    {
        get => Value?.ToString();
        set
        {
            if (TryParseValue(value, out var parsedValue))
            {
                _ = ValueChanged.InvokeAsync(parsedValue);
            }
        }
    }

    private string GetSelectClasses()
    {
        var baseClasses = "block w-full rounded-lg border px-4 py-2 text-base " +
                          "focus:outline-none focus:ring-2 focus:ring-offset-2 " +
                          "disabled:opacity-50 disabled:cursor-not-allowed " +
                          "transition-colors appearance-none " +
                          "bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHZpZXdCb3g9IjAgMCAyMCAyMCIgZmlsbD0ibm9uZSIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj4KPHBhdGggZD0iTTUgNy41TDEwIDEyLjVMMTUgNy41IiBzdHJva2U9IiM2QjcyODAiIHN0cm9rZS13aWR0aD0iMS41IiBzdHJva2UtbGluZWNhcD0icm91bmQiIHN0cm9rZS1saW5lam9pbj0icm91bmQiLz4KPC9zdmc+Cg==')] " +
                          "bg-[length:1.5rem_1.5rem] bg-[right_0.5rem_center] bg-no-repeat pr-10";

        var stateClasses = HasError
            ? "border-red-300 dark:border-red-700 bg-red-50 dark:bg-red-900/20 " +
              "text-red-900 dark:text-red-100 focus:border-red-500 focus:ring-red-500"
            : "border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 " +
              "text-gray-900 dark:text-gray-100 focus:border-blue-500 focus:ring-blue-500";

        var customClasses = Class ?? string.Empty;

        return $"{baseClasses} {stateClasses} {customClasses}".Trim();
    }

    /// <summary>
    /// Gets the aria-describedby attribute value linking to help text and/or error messages.
    /// </summary>
    private string? GetAriaDescribedBy()
    {
        var ids = new List<string>();

        if (HasHelpText)
        {
            ids.Add($"{Id}-help");
        }

        if (HasError)
        {
            ids.Add($"{Id}-error");
        }

        return ids.Any() ? string.Join(" ", ids) : null;
    }

    private void HandleChange(ChangeEventArgs e)
    {
        CurrentValueAsString = e.Value?.ToString();
    }

    private bool TryParseValue(string? value, out TValue? result)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            result = default;
            return true;
        }

        var targetType = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);

        try
        {
            if (targetType == typeof(string))
            {
                result = (TValue)(object)value;
                return true;
            }
            else if (targetType.IsEnum && Enum.TryParse(targetType, value, ignoreCase: true, out var enumValue))
            {
                result = (TValue)enumValue;
                return true;
            }
            else if (targetType == typeof(int) && int.TryParse(value, out var intValue))
            {
                result = (TValue)(object)intValue;
                return true;
            }

            result = default;
            return false;
        }
        catch
        {
            result = default;
            return false;
        }
    }
}
