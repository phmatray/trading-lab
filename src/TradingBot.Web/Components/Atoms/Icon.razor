@namespace TradingBot.Web.Components.Atoms

@code {

    /// <summary>
    /// Gets or sets the icon name to display.
    /// </summary>
    [Parameter]
    public IconName Name { get; set; }

    /// <summary>
    /// Gets or sets the icon variant (Outline or Solid).
    /// </summary>
    [Parameter]
    public IconVariant Variant { get; set; } = IconVariant.Outline;

    /// <summary>
    /// Gets or sets additional CSS classes to apply.
    /// </summary>
    [Parameter]
    public string Class { get; set; } = "w-6 h-6";

    /// <summary>
    /// Gets or sets the aria-label for accessibility.
    /// If null, the icon is decorative (aria-hidden="true").
    /// </summary>
    [Parameter]
    public string? AriaLabel { get; set; }

}

@if (AriaLabel != null)
{
    <svg class="@Class" fill="@GetFill()" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
         aria-label="@AriaLabel" role="img">
        @GetIconPath()
    </svg>
}
else
{
    <svg class="@Class" fill="@GetFill()" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
         aria-hidden="true">
        @GetIconPath()
    </svg>
}

