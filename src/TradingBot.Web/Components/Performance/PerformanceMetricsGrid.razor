@using TradingBot.Core.Models.Portfolio

<div class="bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-700">
    <h2 class="text-xl font-semibold text-white mb-4">Performance Metrics</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Total Return -->
        <div class="stat-card">
            <div class="stat-label">Total Return</div>
            <div class="stat-value @GetColorClass(Metrics.TotalReturn)">
                @Metrics.TotalReturn.ToString("F2")%
            </div>
            <div class="stat-sublabel">
                Annualized: @Metrics.AnnualizedReturn.ToString("F2")%
            </div>
        </div>

        <!-- Win Rate -->
        <div class="stat-card">
            <div class="stat-label">Win Rate</div>
            <div class="stat-value @GetColorClass(Metrics.WinRate - 50)">
                @Metrics.WinRate.ToString("F1")%
            </div>
            <div class="stat-sublabel">
                @Metrics.WinningTrades wins / @Metrics.LosingTrades losses
            </div>
        </div>

        <!-- Sharpe Ratio -->
        <div class="stat-card">
            <div class="stat-label">Sharpe Ratio</div>
            <div class="stat-value @GetColorClass(Metrics.SharpeRatio)">
                @Metrics.SharpeRatio.ToString("F2")
            </div>
            <div class="stat-sublabel">
                Risk-adjusted return
            </div>
        </div>

        <!-- Sortino Ratio -->
        <div class="stat-card">
            <div class="stat-label">Sortino Ratio</div>
            <div class="stat-value @GetColorClass(Metrics.SortinoRatio)">
                @Metrics.SortinoRatio.ToString("F2")
            </div>
            <div class="stat-sublabel">
                Downside risk-adjusted
            </div>
        </div>

        <!-- Calmar Ratio -->
        <div class="stat-card">
            <div class="stat-label">Calmar Ratio</div>
            <div class="stat-value @GetColorClass(Metrics.CalmarRatio)">
                @Metrics.CalmarRatio.ToString("F2")
            </div>
            <div class="stat-sublabel">
                Return / Max Drawdown
            </div>
        </div>

        <!-- Max Drawdown -->
        <div class="stat-card">
            <div class="stat-label">Max Drawdown</div>
            <div class="stat-value @GetColorClass(-Metrics.MaxDrawdown)">
                -@Metrics.MaxDrawdown.ToString("F2")%
            </div>
            <div class="stat-sublabel">
                Peak to trough decline
            </div>
        </div>

        <!-- Profit Factor -->
        <div class="stat-card">
            <div class="stat-label">Profit Factor</div>
            <div class="stat-value @GetColorClass(Metrics.ProfitFactor - 1)">
                @Metrics.ProfitFactor.ToString("F2")
            </div>
            <div class="stat-sublabel">
                Gross profit / Gross loss
            </div>
        </div>

        <!-- Average Win -->
        <div class="stat-card">
            <div class="stat-label">Average Win</div>
            <div class="stat-value @GetColorClass(Metrics.AverageWin)">
                @Metrics.AverageWin.ToString("C2")
            </div>
            <div class="stat-sublabel">
                Per winning trade
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public PerformanceMetrics Metrics { get; set; } = null!;

    private string GetColorClass(decimal value)
    {
        if (value > 0)
        {
            return "stat-positive";
        }
        else if (value < 0)
        {
            return "stat-negative";
        }
        else
        {
            return "text-gray-600";
        }
    }

}
