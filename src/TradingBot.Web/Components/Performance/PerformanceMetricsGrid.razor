@using TradingBot.Core.Models.Portfolio

<div class="bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-700">
    <h2 class="text-xl font-semibold text-white mb-4">Performance Metrics</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Total Return -->
        <div class="stat-card">
            <div class="stat-label">Total Return</div>
            <div class="stat-value @GetColorClass(Metrics.TotalReturn)">
                @Metrics.TotalReturn.ToString("F2")%
            </div>
            <div class="stat-sublabel">
                Annualized: @Metrics.AnnualizedReturn.ToString("F2")%
            </div>
        </div>

        <!-- Win Rate -->
        <div class="stat-card">
            <div class="stat-label">Win Rate</div>
            <div class="stat-value @GetColorClass(Metrics.WinRate - 50)">
                @Metrics.WinRate.ToString("F1")%
            </div>
            <div class="stat-sublabel">
                @Metrics.WinningTrades wins / @Metrics.LosingTrades losses
            </div>
        </div>

        <!-- Sharpe Ratio -->
        <div class="stat-card">
            <div class="stat-label flex items-center gap-1">
                Sharpe Ratio
                <InfoTooltip Position="TooltipPosition.Top" IsVisible="false">
                    <Trigger>
                        <button class="text-gray-400 hover:text-gray-300 focus:outline-none" aria-label="Help: Sharpe Ratio">
                            <TbIcon Name="IconName.InformationCircle" Class="w-4 h-4" />
                        </button>
                    </Trigger>
                    <Content>
                        <div class="text-xs">
                            <p class="font-semibold">Sharpe Ratio</p>
                            <p class="mt-1">Measures risk-adjusted returns by comparing portfolio returns to risk-free rate.</p>
                            <p class="mt-1 text-gray-300">Higher is better. &gt;1 is good, &gt;2 is very good, &gt;3 is excellent.</p>
                        </div>
                    </Content>
                </InfoTooltip>
            </div>
            <div class="stat-value @GetColorClass(Metrics.SharpeRatio)">
                @Metrics.SharpeRatio.ToString("F2")
            </div>
            <div class="stat-sublabel">
                Risk-adjusted return
            </div>
        </div>

        <!-- Sortino Ratio -->
        <div class="stat-card">
            <div class="stat-label flex items-center gap-1">
                Sortino Ratio
                <InfoTooltip Position="TooltipPosition.Top" IsVisible="false">
                    <Trigger>
                        <button class="text-gray-400 hover:text-gray-300 focus:outline-none" aria-label="Help: Sortino Ratio">
                            <TbIcon Name="IconName.InformationCircle" Class="w-4 h-4" />
                        </button>
                    </Trigger>
                    <Content>
                        <div class="text-xs">
                            <p class="font-semibold">Sortino Ratio</p>
                            <p class="mt-1">Similar to Sharpe but only penalizes downside volatility, not upside.</p>
                            <p class="mt-1 text-gray-300">Higher is better. Typically higher than Sharpe ratio.</p>
                        </div>
                    </Content>
                </InfoTooltip>
            </div>
            <div class="stat-value @GetColorClass(Metrics.SortinoRatio)">
                @Metrics.SortinoRatio.ToString("F2")
            </div>
            <div class="stat-sublabel">
                Downside risk-adjusted
            </div>
        </div>

        <!-- Calmar Ratio -->
        <div class="stat-card">
            <div class="stat-label flex items-center gap-1">
                Calmar Ratio
                <InfoTooltip Position="TooltipPosition.Top" IsVisible="false">
                    <Trigger>
                        <button class="text-gray-400 hover:text-gray-300 focus:outline-none" aria-label="Help: Calmar Ratio">
                            <TbIcon Name="IconName.InformationCircle" Class="w-4 h-4" />
                        </button>
                    </Trigger>
                    <Content>
                        <div class="text-xs">
                            <p class="font-semibold">Calmar Ratio</p>
                            <p class="mt-1">Annual return divided by maximum drawdown. Measures return vs worst-case scenario.</p>
                            <p class="mt-1 text-gray-300">Higher is better. &gt;3 is good, &gt;5 is excellent.</p>
                        </div>
                    </Content>
                </InfoTooltip>
            </div>
            <div class="stat-value @GetColorClass(Metrics.CalmarRatio)">
                @Metrics.CalmarRatio.ToString("F2")
            </div>
            <div class="stat-sublabel">
                Return / Max Drawdown
            </div>
        </div>

        <!-- Max Drawdown -->
        <div class="stat-card">
            <div class="stat-label flex items-center gap-1">
                Max Drawdown
                <InfoTooltip Position="TooltipPosition.Top" IsVisible="false">
                    <Trigger>
                        <button class="text-gray-400 hover:text-gray-300 focus:outline-none" aria-label="Help: Max Drawdown">
                            <TbIcon Name="IconName.InformationCircle" Class="w-4 h-4" />
                        </button>
                    </Trigger>
                    <Content>
                        <div class="text-xs">
                            <p class="font-semibold">Maximum Drawdown</p>
                            <p class="mt-1">Largest peak-to-trough decline in portfolio value. Indicates worst loss period.</p>
                            <p class="mt-1 text-gray-300">Lower is better. &lt;10% is good, &lt;20% is acceptable.</p>
                        </div>
                    </Content>
                </InfoTooltip>
            </div>
            <div class="stat-value @GetColorClass(-Metrics.MaxDrawdown)">
                -@Metrics.MaxDrawdown.ToString("F2")%
            </div>
            <div class="stat-sublabel">
                Peak to trough decline
            </div>
        </div>

        <!-- Profit Factor -->
        <div class="stat-card">
            <div class="stat-label">Profit Factor</div>
            <div class="stat-value @GetColorClass(Metrics.ProfitFactor - 1)">
                @Metrics.ProfitFactor.ToString("F2")
            </div>
            <div class="stat-sublabel">
                Gross profit / Gross loss
            </div>
        </div>

        <!-- Average Win -->
        <div class="stat-card">
            <div class="stat-label">Average Win</div>
            <div class="stat-value @GetColorClass(Metrics.AverageWin)">
                @Metrics.AverageWin.ToString("C2")
            </div>
            <div class="stat-sublabel">
                Per winning trade
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public PerformanceMetrics Metrics { get; set; } = null!;

    private string GetColorClass(decimal value)
    {
        if (value > 0)
        {
            return "stat-positive";
        }
        else if (value < 0)
        {
            return "stat-negative";
        }
        else
        {
            return "text-gray-600";
        }
    }

}
