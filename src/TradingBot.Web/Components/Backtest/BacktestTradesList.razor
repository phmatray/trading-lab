@using TradingBot.Core.Models.Trading

<div class="space-y-6">
    <!-- Top 5 Winning Trades -->
    <div>
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-3">Top 5 Winning Trades</h3>
        @if (TopWinners.Any())
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                    <thead class="bg-gray-50 dark:bg-gray-900">
                        <tr>
                            <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Date</th>
                            <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Symbol</th>
                            <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Side</th>
                            <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Entry</th>
                            <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Exit</th>
                            <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">P&L</th>
                            <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Return %</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                        @foreach (var trade in TopWinners)
                        {
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                                <td class="px-3 py-3 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
                                    @trade.EntryTime.ToString("MMM dd")
                                </td>
                                <td class="px-3 py-3 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
                                    @trade.Symbol
                                </td>
                                <td class="px-3 py-3 whitespace-nowrap text-sm">
                                    @if (trade.Side.Name == "Buy")
                                    {
                                        <span class="text-green-600 dark:text-green-400">Long</span>
                                    }
                                    else
                                    {
                                        <span class="text-red-600 dark:text-red-400">Short</span>
                                    }
                                </td>
                                <td class="px-3 py-3 whitespace-nowrap text-sm text-right text-gray-900 dark:text-white">
                                    @trade.EntryPrice.ToString("C2")
                                </td>
                                <td class="px-3 py-3 whitespace-nowrap text-sm text-right text-gray-900 dark:text-white">
                                    @trade.ExitPrice.ToString("C2")
                                </td>
                                <td class="px-3 py-3 whitespace-nowrap text-sm text-right font-semibold text-green-600 dark:text-green-400">
                                    @trade.RealizedPnL.ToString("C0")
                                </td>
                                <td class="px-3 py-3 whitespace-nowrap text-sm text-right font-semibold text-green-600 dark:text-green-400">
                                    @trade.RealizedPnLPercent.ToString("F2")%
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-sm text-gray-500 dark:text-gray-400">No winning trades</p>
        }
    </div>

    <!-- Top 5 Losing Trades -->
    <div>
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-3">Top 5 Losing Trades</h3>
        @if (TopLosers.Any())
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                    <thead class="bg-gray-50 dark:bg-gray-900">
                        <tr>
                            <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Date</th>
                            <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Symbol</th>
                            <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Side</th>
                            <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Entry</th>
                            <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Exit</th>
                            <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">P&L</th>
                            <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Return %</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                        @foreach (var trade in TopLosers)
                        {
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                                <td class="px-3 py-3 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
                                    @trade.EntryTime.ToString("MMM dd")
                                </td>
                                <td class="px-3 py-3 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
                                    @trade.Symbol
                                </td>
                                <td class="px-3 py-3 whitespace-nowrap text-sm">
                                    @if (trade.Side.Name == "Buy")
                                    {
                                        <span class="text-green-600 dark:text-green-400">Long</span>
                                    }
                                    else
                                    {
                                        <span class="text-red-600 dark:text-red-400">Short</span>
                                    }
                                </td>
                                <td class="px-3 py-3 whitespace-nowrap text-sm text-right text-gray-900 dark:text-white">
                                    @trade.EntryPrice.ToString("C2")
                                </td>
                                <td class="px-3 py-3 whitespace-nowrap text-sm text-right text-gray-900 dark:text-white">
                                    @trade.ExitPrice.ToString("C2")
                                </td>
                                <td class="px-3 py-3 whitespace-nowrap text-sm text-right font-semibold text-red-600 dark:text-red-400">
                                    @trade.RealizedPnL.ToString("C0")
                                </td>
                                <td class="px-3 py-3 whitespace-nowrap text-sm text-right font-semibold text-red-600 dark:text-red-400">
                                    @trade.RealizedPnLPercent.ToString("F2")%
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-sm text-gray-500 dark:text-gray-400">No losing trades</p>
        }
    </div>
</div>

@code {
    [Parameter]
    public List<Trade> Trades { get; set; } = new();

    private List<Trade> TopWinners => Trades
        .Where(t => t.RealizedPnL > 0)
        .OrderByDescending(t => t.RealizedPnL)
        .Take(5)
        .ToList();

    private List<Trade> TopLosers => Trades
        .Where(t => t.RealizedPnL < 0)
        .OrderBy(t => t.RealizedPnL)
        .Take(5)
        .ToList();
}
