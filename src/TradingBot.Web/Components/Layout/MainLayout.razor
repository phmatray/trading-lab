@inherits LayoutComponentBase

<ToastContainer />

<div class="min-h-screen bg-gray-50">
    <!-- Header -->
    <header class="bg-white shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center py-4">
                <div class="flex items-center">
                    <h1 class="text-2xl font-bold text-gray-900">TradingBot</h1>
                    <span class="ml-3 text-sm text-gray-500">Web Dashboard</span>
                </div>

                <!-- Connection Status Indicator -->
                <div class="flex items-center space-x-2">
                    <div id="connection-status" class="flex items-center">
                        <span class="inline-flex h-3 w-3 rounded-full bg-green-500"></span>
                        <span class="ml-2 text-sm text-gray-600">Connected</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="flex">
        <!-- Navigation Sidebar -->
        <NavMenu />

        <!-- Main Content -->
        <main class="flex-1 px-4 py-6 sm:px-6 lg:px-8">
            <div class="max-w-7xl mx-auto">
                @Body
            </div>
        </main>
    </div>
</div>
