@page "/help"
@using TradingBot.Web.Components.Molecules


<PageTitle>Help & Support - TradingBot</PageTitle>

<div class="max-w-4xl mx-auto py-8 px-4">
    <TbPageHeader
        Title="Help & Support"
        Description="Find answers to common questions and learn how to use TradingBot effectively." />

    <div class="mt-8 space-y-8">
        <!-- Quick Start Guide -->
        <section>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Quick Start Guide</h2>
            <TbCard>
                <div class="space-y-4">
                    <div class="flex items-start gap-3">
                        <div class="flex-shrink-0 w-8 h-8 bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 rounded-full flex items-center justify-center font-bold">
                            1
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-900 dark:text-white">Configure Your Settings</h3>
                            <p class="text-gray-600 dark:text-gray-300 mt-1">
                                Navigate to <a href="/settings" class="text-blue-600 dark:text-blue-400 hover:underline">Settings</a> to customize your theme, dashboard refresh interval, and notification preferences.
                            </p>
                        </div>
                    </div>

                    <div class="flex items-start gap-3">
                        <div class="flex-shrink-0 w-8 h-8 bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 rounded-full flex items-center justify-center font-bold">
                            2
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-900 dark:text-white">Review Your Portfolio</h3>
                            <p class="text-gray-600 dark:text-gray-300 mt-1">
                                Check your <a href="/portfolio" class="text-blue-600 dark:text-blue-400 hover:underline">Portfolio</a> to see your current positions, open orders, and account balance.
                            </p>
                        </div>
                    </div>

                    <div class="flex items-start gap-3">
                        <div class="flex-shrink-0 w-8 h-8 bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 rounded-full flex items-center justify-center font-bold">
                            3
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-900 dark:text-white">Manage Trading Strategies</h3>
                            <p class="text-gray-600 dark:text-gray-300 mt-1">
                                Visit <a href="/strategies" class="text-blue-600 dark:text-blue-400 hover:underline">Strategies</a> to enable or disable trading strategies and configure their parameters.
                            </p>
                        </div>
                    </div>

                    <div class="flex items-start gap-3">
                        <div class="flex-shrink-0 w-8 h-8 bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 rounded-full flex items-center justify-center font-bold">
                            4
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-900 dark:text-white">Monitor Performance</h3>
                            <p class="text-gray-600 dark:text-gray-300 mt-1">
                                Track your trading performance on the <a href="/performance" class="text-blue-600 dark:text-blue-400 hover:underline">Performance</a> page with detailed metrics and charts.
                            </p>
                        </div>
                    </div>
                </div>
            </TbCard>
        </section>

        <!-- Frequently Asked Questions -->
        <section>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Frequently Asked Questions</h2>
            <div class="space-y-4">
                <!-- FAQ Item 1 -->
                <TbCard>
                    <details class="group">
                        <summary class="flex items-center justify-between cursor-pointer list-none">
                            <h3 class="font-semibold text-gray-900 dark:text-white">How do I change the theme from light to dark mode?</h3>
                            <span class="transition group-open:rotate-180">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </span>
                        </summary>
                        <div class="mt-3 text-gray-600 dark:text-gray-300">
                            <p>To switch between light and dark themes:</p>
                            <ol class="list-decimal list-inside mt-2 space-y-1">
                                <li>Navigate to <a href="/settings" class="text-blue-600 dark:text-blue-400 hover:underline">Settings</a> using the left sidebar</li>
                                <li>Find the "Theme" section</li>
                                <li>Select either "Light" or "Dark" from the dropdown</li>
                                <li>Click "Save Changes" to apply the new theme</li>
                            </ol>
                            <p class="mt-2">Your theme preference will be saved and applied automatically on future visits.</p>
                        </div>
                    </details>
                </TbCard>

                <!-- FAQ Item 2 -->
                <TbCard>
                    <details class="group">
                        <summary class="flex items-center justify-between cursor-pointer list-none">
                            <h3 class="font-semibold text-gray-900 dark:text-white">What is the dashboard refresh interval and how do I change it?</h3>
                            <span class="transition group-open:rotate-180">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </span>
                        </summary>
                        <div class="mt-3 text-gray-600 dark:text-gray-300">
                            <p>The dashboard refresh interval controls how often real-time data updates on your dashboard.</p>
                            <p class="mt-2">To change the refresh interval:</p>
                            <ol class="list-decimal list-inside mt-2 space-y-1">
                                <li>Go to <a href="/settings" class="text-blue-600 dark:text-blue-400 hover:underline">Settings</a></li>
                                <li>Find the "Dashboard Refresh Interval" field</li>
                                <li>Enter a value between 1 and 300 seconds (recommended: 5-30 seconds)</li>
                                <li>Click "Save Changes"</li>
                            </ol>
                            <p class="mt-2"><strong>Note:</strong> A shorter interval provides more real-time data but may increase server load.</p>
                        </div>
                    </details>
                </TbCard>

                <!-- FAQ Item 3 -->
                <TbCard>
                    <details class="group">
                        <summary class="flex items-center justify-between cursor-pointer list-none">
                            <h3 class="font-semibold text-gray-900 dark:text-white">How do I enable or disable trading strategies?</h3>
                            <span class="transition group-open:rotate-180">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </span>
                        </summary>
                        <div class="mt-3 text-gray-600 dark:text-gray-300">
                            <p>To manage your trading strategies:</p>
                            <ol class="list-decimal list-inside mt-2 space-y-1">
                                <li>Navigate to the <a href="/strategies" class="text-blue-600 dark:text-blue-400 hover:underline">Strategies</a> page</li>
                                <li>Find the strategy you want to enable or disable</li>
                                <li>Toggle the switch next to the strategy name</li>
                                <li>The strategy will be enabled/disabled immediately</li>
                            </ol>
                            <p class="mt-2"><strong>Warning:</strong> Disabling a strategy will stop it from generating new trading signals.</p>
                        </div>
                    </details>
                </TbCard>

                <!-- FAQ Item 4 -->
                <TbCard>
                    <details class="group">
                        <summary class="flex items-center justify-between cursor-pointer list-none">
                            <h3 class="font-semibold text-gray-900 dark:text-white">What do the performance metrics mean?</h3>
                            <span class="transition group-open:rotate-180">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </span>
                        </summary>
                        <div class="mt-3 text-gray-600 dark:text-gray-300">
                            <p>Key performance metrics explained:</p>
                            <ul class="list-disc list-inside mt-2 space-y-2">
                                <li><strong>Total P&L:</strong> Total profit or loss across all trades</li>
                                <li><strong>Win Rate:</strong> Percentage of profitable trades</li>
                                <li><strong>Sharpe Ratio:</strong> Risk-adjusted return measure (higher is better, >1 is good)</li>
                                <li><strong>Max Drawdown:</strong> Largest peak-to-trough decline in portfolio value</li>
                                <li><strong>Average Trade:</strong> Average profit/loss per trade</li>
                            </ul>
                            <p class="mt-2">Visit the <a href="/performance" class="text-blue-600 dark:text-blue-400 hover:underline">Performance</a> page for detailed metrics.</p>
                        </div>
                    </details>
                </TbCard>

                <!-- FAQ Item 5 -->
                <TbCard>
                    <details class="group">
                        <summary class="flex items-center justify-between cursor-pointer list-none">
                            <h3 class="font-semibold text-gray-900 dark:text-white">How do I customize notification preferences?</h3>
                            <span class="transition group-open:rotate-180">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </span>
                        </summary>
                        <div class="mt-3 text-gray-600 dark:text-gray-300">
                            <p>To control which notifications you receive:</p>
                            <ol class="list-decimal list-inside mt-2 space-y-1">
                                <li>Go to <a href="/settings" class="text-blue-600 dark:text-blue-400 hover:underline">Settings</a></li>
                                <li>Scroll to the "Notification Preferences" section</li>
                                <li>Toggle switches for each notification type (Success, Error, Info, Warning)</li>
                                <li>Adjust the "Notification Duration" (2-10 seconds)</li>
                                <li>Click "Save Changes" to apply your preferences</li>
                            </ol>
                            <p class="mt-2">Disabled notification types will not appear as toast messages.</p>
                        </div>
                    </details>
                </TbCard>

                <!-- FAQ Item 6 -->
                <TbCard>
                    <details class="group">
                        <summary class="flex items-center justify-between cursor-pointer list-none">
                            <h3 class="font-semibold text-gray-900 dark:text-white">How do I collapse the navigation sidebar?</h3>
                            <span class="transition group-open:rotate-180">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </span>
                        </summary>
                        <div class="mt-3 text-gray-600 dark:text-gray-300">
                            <p>The left sidebar can be collapsed to save screen space:</p>
                            <ol class="list-decimal list-inside mt-2 space-y-1">
                                <li>Look for the toggle button at the top of the sidebar (three horizontal lines)</li>
                                <li>Click the button to collapse the sidebar to icon-only mode</li>
                                <li>Click again to expand the sidebar back to full width</li>
                            </ol>
                            <p class="mt-2"><strong>Note:</strong> The sidebar always starts expanded when you load the page. This setting is not persisted across sessions.</p>
                        </div>
                    </details>
                </TbCard>
            </div>
        </section>

        <!-- Keyboard Shortcuts -->
        <section>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Keyboard Shortcuts</h2>
            <TbCard>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
