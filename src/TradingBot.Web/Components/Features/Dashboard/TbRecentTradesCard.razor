@namespace TradingBot.Web.Components.Features.Dashboard
@using TradingBot.Web.Components.Atoms
@using TradingBot.Web.Components.Molecules
@using TradingBot.Core.Models

<TbCard>
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-100">Recent Trades</h2>
        @if (LastUpdated.HasValue)
        {
            <span class="text-xs text-gray-500 dark:text-gray-400">
                Updated: @LastUpdated.Value.ToString("HH:mm:ss")
            </span>
        }
    </div>

    @if (Trades is not null && Trades.Any())
    {
        <div class="space-y-3">
            @foreach (var trade in Trades)
            {
                <div
                    class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:bg-gray-50 dark:hover:bg-gray-800">
                    <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center space-x-3">
                            <span class="text-lg font-bold text-gray-900 dark:text-gray-100">@trade.Symbol</span>
                            <TbBadge Variant="@GetSideBadgeVariant(trade.Side)">
                                @trade.Side.Name
                            </TbBadge>
                        </div>
                        <span class="text-sm font-bold @GetPnLColorClass(trade.RealizedPnL)">
                            @trade.RealizedPnL.ToString("C2")
                        </span>
                    </div>
                    <div class="grid grid-cols-3 gap-2 text-sm">
                        <div>
                            <p class="text-gray-500 dark:text-gray-400">Qty</p>
                            <p class="text-gray-900 dark:text-gray-100 font-medium">@trade.Quantity.ToString("N2")</p>
                        </div>
                        <div>
                            <p class="text-gray-500 dark:text-gray-400">Entry/Exit</p>
                            <p class="text-gray-900 dark:text-gray-100 font-medium">
                                @trade.EntryPrice.ToString("C2") / @trade.ExitPrice.ToString("C2")
                            </p>
                        </div>
                        <div class="text-right">
                            <p class="text-gray-500 dark:text-gray-400">Date</p>
                            <p class="text-gray-900 dark:text-gray-100 font-medium">@trade.ExitTime.ToString("MM/dd HH:mm")</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (Trades is not null && !Trades.Any())
    {
        <div class="flex items-center justify-center py-12 bg-gray-50 dark:bg-gray-800 rounded-lg">
            <p class="text-gray-500 dark:text-gray-400">No recent trades</p>
        </div>
    }
    else
    {
        <div class="flex items-center justify-center py-8">
            <p class="text-gray-500 dark:text-gray-400">Loading trades...</p>
        </div>
    }
</TbCard>

@code {
    [Parameter] public List<Trade>? Trades { get; set; }

    [Parameter] public DateTime? LastUpdated { get; set; }

    private string GetPnLColorClass(decimal pnl)
    {
        return pnl switch
        {
            > 0 => "stat-positive",
            < 0 => "stat-negative",
            _ => "text-gray-900 dark:text-gray-100"
        };
    }

    private BadgeVariant GetSideBadgeVariant(OrderSide side)
    {
        return side.Name.ToUpperInvariant() switch
        {
            "BUY" => BadgeVariant.Success,
            "SELL" => BadgeVariant.Error,
            _ => BadgeVariant.Default
        };
    }

}
