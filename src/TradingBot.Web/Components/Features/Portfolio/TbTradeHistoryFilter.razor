<div >
    <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-4">Filter Trade History</h3>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        @* Start Date Filter *@
        <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                Start Date
            </label>
            <input
                type="date"
                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                @bind="filter.StartDate"
                @bind:event="oninput"
                max="@DateTime.Now.ToString("yyyy-MM-dd")"/>
            @if (!string.IsNullOrEmpty(startDateError))
            {
                <p class="text-red-500 text-xs mt-1">@startDateError</p>
            }
        </div>

        @* End Date Filter *@
        <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                End Date
            </label>
            <input
                type="date"
                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                @bind="filter.EndDate"
                @bind:event="oninput"
                max="@DateTime.Now.ToString("yyyy-MM-dd")"/>
            @if (!string.IsNullOrEmpty(endDateError))
            {
                <p class="text-red-500 text-xs mt-1">@endDateError</p>
            }
        </div>

        @* Symbol Filter *@
        <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                Symbol (Optional)
            </label>
            <input
                type="text"
                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent uppercase"
                placeholder="e.g., SPY, AAPL"
                @bind="filter.Symbol"
                @bind:event="oninput"
                maxlength="10"/>
            @if (!string.IsNullOrEmpty(symbolError))
            {
                <p class="text-red-500 text-xs mt-1">@symbolError</p>
            }
        </div>

        @* Strategy Filter *@
        <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                Strategy (Optional)
            </label>
            <input
                type="text"
                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                placeholder="e.g., Momentum"
                @bind="filter.StrategyName"
                @bind:event="oninput"
                maxlength="50"/>
        </div>
    </div>

    <div class="flex gap-3 mt-4">
        <button
            @onclick="ApplyFilter"
            disabled="@(!IsFilterValid)"
            class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            Apply Filters
        </button>
        <button
            @onclick="ResetFilter"
            class="px-4 py-2 bg-gray-300 dark:bg-gray-600 text-gray-700 dark:text-gray-200 rounded-lg hover:bg-gray-400 dark:hover:bg-gray-500 transition-colors">
            Reset
        </button>
    </div>
</div>

@code {
    [Parameter] public EventCallback<PortfolioHistoryFilter> OnFilterChanged { get; set; }

    private PortfolioHistoryFilter filter = new();
    private string? startDateError;
    private string? endDateError;
    private string? symbolError;

    private bool IsFilterValid => string.IsNullOrEmpty(startDateError)
                                  && string.IsNullOrEmpty(endDateError)
                                  && string.IsNullOrEmpty(symbolError);

    protected override void OnInitialized()
    {
        // Set default date range to last 30 days
        filter.EndDate = DateTime.Now;
        filter.StartDate = DateTime.Now.AddDays(-30);
    }

    private async Task ApplyFilter()
    {
        if (!ValidateFilter())
        {
            return;
        }

        await OnFilterChanged.InvokeAsync(filter);
    }

    private async Task ResetFilter()
    {
        filter = new PortfolioHistoryFilter
        {
            StartDate = DateTime.Now.AddDays(-30),
            EndDate = DateTime.Now
        };

        ClearErrors();
        await OnFilterChanged.InvokeAsync(filter);
    }

    private bool ValidateFilter()
    {
        ClearErrors();
        var isValid = true;

        // Validate date range
        if (filter.StartDate.HasValue && filter.EndDate.HasValue)
        {
            if (filter.StartDate > filter.EndDate)
            {
                endDateError = "End date must be after start date";
                isValid = false;
            }

            if (filter.EndDate > DateTime.Now)
            {
                endDateError = "End date cannot be in the future";
                isValid = false;
            }

            var daysDiff = (filter.EndDate.Value - filter.StartDate.Value).TotalDays;
            if (daysDiff > 365)
            {
                startDateError = "Date range cannot exceed 1 year";
                isValid = false;
            }
        }

        // Validate symbol format (uppercase letters only, optional)
        if (!string.IsNullOrWhiteSpace(filter.Symbol) &&
            !System.Text.RegularExpressions.Regex.IsMatch(filter.Symbol, @"^[A-Z]{1,10}$"))
        {
            symbolError = "Symbol must be 1-10 uppercase letters";
            isValid = false;
        }

        return isValid;
    }

    private void ClearErrors()
    {
        startDateError = null;
        endDateError = null;
        symbolError = null;
    }

}
