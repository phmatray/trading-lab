@using static TradingBot.Web.Pages.Strategies

<div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 border-2 @GetBorderClass()">
    <div class="flex items-start justify-between mb-4">
        <div class="flex-1">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-1">@Strategy.Name</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">@Strategy.Type</p>
        </div>
        <div class="ml-4">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold @GetStatusClass()">
                <span class="w-2 h-2 rounded-full mr-2 @GetStatusDotClass()"></span>
                @(Strategy.IsEnabled ? "Active" : "Disabled")
            </span>
        </div>
    </div>

    <div class="space-y-3 mb-4">
        <div class="flex items-center text-sm">
            <svg class="w-4 h-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
            </svg>
            <span class="text-gray-700 dark:text-gray-300">
                <strong>Symbols:</strong> @string.Join(", ", Strategy.Symbols)
            </span>
        </div>

        <div class="flex items-center text-sm">
            <svg class="w-4 h-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="text-gray-700 dark:text-gray-300">
                <strong>Timeframe:</strong> @Strategy.Timeframe
            </span>
        </div>
    </div>

    <div class="pt-4 border-t border-gray-200 dark:border-gray-700">
        <TbStrategyStatusToggle
            Strategy="@Strategy"
            OnToggle="@HandleToggle"/>
    </div>
</div>

@code {
    [Parameter] public IStrategy Strategy { get; set; } = null!;

    [Parameter] public EventCallback<StrategyStatusChangedEventArgs> OnStatusChanged { get; set; }

    private string GetBorderClass()
    {
        return Strategy.IsEnabled
            ? "border-green-500"
            : "border-gray-300 dark:border-gray-600";
    }

    private string GetStatusClass()
    {
        return Strategy.IsEnabled
            ? "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200"
            : "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200";
    }

    private string GetStatusDotClass()
    {
        return Strategy.IsEnabled
            ? "bg-green-500 animate-pulse"
            : "bg-red-500";
    }

    private async Task HandleToggle(bool isEnabled)
    {
        await OnStatusChanged.InvokeAsync(new StrategyStatusChangedEventArgs
        {
            StrategyName = Strategy.Name,
            IsEnabled = isEnabled
        });
    }

}
