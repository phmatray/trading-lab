<div class="card-trading hover:shadow-lg transition-shadow">
    <div class="flex items-start justify-between mb-3">
        <div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100">@Position.Symbol</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">@Position.StrategyName</p>
        </div>
        <span class="px-2 py-1 rounded-full text-xs font-medium @GetSideClass(Position.Side)">
            @Position.Side.Name
        </span>
    </div>

    <div class="grid grid-cols-2 gap-3 mb-4">
        <div>
            <p class="text-xs text-gray-500 dark:text-gray-400">Quantity</p>
            <p class="text-sm font-semibold text-gray-900 dark:text-gray-100">@Position.Quantity.ToString("N2")</p>
        </div>
        <div>
            <p class="text-xs text-gray-500 dark:text-gray-400">Entry Price</p>
            <p class="text-sm font-semibold text-gray-900 dark:text-gray-100">@Position.EntryPrice.ToString("C2")</p>
        </div>
        <div>
            <p class="text-xs text-gray-500 dark:text-gray-400">Current Price</p>
            <p class="text-sm font-semibold text-gray-900 dark:text-gray-100">@Position.CurrentPrice.ToString("C2")</p>
        </div>
        <div>
            <p class="text-xs text-gray-500 dark:text-gray-400">Unrealized P&L</p>
            <p class="text-sm font-semibold @GetPnLColorClass(Position.UnrealizedPnL)">
                @Position.UnrealizedPnL.ToString("C2")
            </p>
        </div>
    </div>

    <div class="mb-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
        <div class="flex justify-between items-center mb-1">
            <span class="text-xs text-gray-600 dark:text-gray-400">Estimated Proceeds</span>
            <span
                class="text-sm font-semibold text-gray-900 dark:text-gray-100">@EstimatedProceeds.ToString("C2")</span>
        </div>
        <div class="flex justify-between items-center">
            <span class="text-xs text-gray-600 dark:text-gray-400">P&L %</span>
            <span class="text-sm font-semibold @GetPnLColorClass(Position.UnrealizedPnL)">
                @PnLPercentage.ToString("N2")%
            </span>
        </div>
    </div>

    <button
        @onclick="HandleClosePosition"
        class="w-full px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-medium">
        Close Position
    </button>

    <div class="mt-2 text-xs text-gray-500 dark:text-gray-400">
        Opened: @Position.OpenedAt.ToString("yyyy-MM-dd HH:mm")
    </div>
</div>

@code {
    [Parameter] public required Position Position { get; set; }

    [Parameter] public EventCallback OnCloseRequested { get; set; }

    private decimal EstimatedProceeds =>
        Position.CurrentPrice * Position.Quantity;

    private decimal PnLPercentage =>
        Position.EntryPrice != 0
            ? ((Position.CurrentPrice - Position.EntryPrice) / Position.EntryPrice) * 100m
            : 0m;

    private async Task HandleClosePosition()
    {
        await OnCloseRequested.InvokeAsync();
    }

    private string GetSideClass(OrderSide side)
    {
        return side.Name == "Buy"
            ? "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200"
            : "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200";
    }

    private string GetPnLColorClass(decimal pnl)
    {
        return pnl switch
        {
            > 0 => "stat-positive",
            < 0 => "stat-negative",
            _ => "text-gray-900 dark:text-gray-100"
        };
    }

}
