{
  "Trading": {
    "DefaultTicker": "TEST",
    "DefaultIsin": "TEST_ISIN",
    "Database": {
      "Provider": "SQLite",
      "ConnectionString": "Data Source=test-trading.db"
    },
    "Backtest": {
      "InitialCapital": 10000,
      "CommissionPercentage": 0.001,
      "MinimumCommission": 1.0,
      "DefaultPeriodYears": 1
    },
    "MachineLearning": {
      "MinTrainingBars": 50,
      "DefaultThresholds": {
        "BuyThreshold": 0.01,
        "SellThreshold": -0.01
      },
      "ModelParameters": {
        "NumberOfLeaves": 31,
        "MinimumExampleCountPerLeaf": 20,
        "LearningRate": 0.1,
        "NumberOfTrees": 50
      }
    },
    "Export": {
      "OutputDirectory": "./test-exports",
      "DateFormat": "yyyyMMdd_HHmmss"
    },
    "YahooFinance": {
      "TimeoutSeconds": 10,
      "MaxRetries": 1
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}
