# EditorConfig for test projects
# Relaxed rules for unit tests

root = false

[*.cs]
# Disable documentation requirements for test methods
dotnet_diagnostic.SA1600.severity = none

# Disable XML documentation header requirements
dotnet_diagnostic.SA1633.severity = none

# Allow test methods without documentation
dotnet_diagnostic.CS1591.severity = none

# Disable xUnit cancellation token warnings for simpler test code
dotnet_diagnostic.xUnit1051.severity = suggestion
