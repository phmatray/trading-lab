<div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-800">
        <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Symbol
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Side
            </th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Quantity
            </th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Entry Price
            </th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Current Price
            </th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Unrealized P&L
            </th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                P&L %
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Strategy
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Opened
            </th>
            <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Actions
            </th>
        </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
        @if (Positions.Any())
        {
            @foreach (var position in Positions.OrderByDescending(p => p.OpenedAt))
            {
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                    <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-gray-100">
                        @position.Symbol
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-sm">
                        <span class="px-2 py-1 rounded-full text-xs font-medium @GetSideClass(position.Side)">
                            @position.Side.Name
                        </span>
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-sm text-right text-gray-900 dark:text-gray-100">
                        @position.Quantity.ToString("N2")
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-sm text-right text-gray-900 dark:text-gray-100">
                        @position.EntryPrice.ToString("C2")
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-sm text-right text-gray-900 dark:text-gray-100">
                        @position.CurrentPrice.ToString("C2")
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-sm text-right font-semibold @GetPnLColorClass(position.UnrealizedPnL)">
                        @position.UnrealizedPnL.ToString("C2")
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-sm text-right font-semibold @GetPnLColorClass(position.UnrealizedPnL)">
                        @GetPnLPercentage(position).ToString("N2")%
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-700 dark:text-gray-300">
                        @position.StrategyName
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-700 dark:text-gray-300">
                        @position.OpenedAt.ToString("yyyy-MM-dd HH:mm")
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-center">
                        <TbButton
                            Variant="ButtonVariant.Danger"
                            Size="ButtonSize.Small"
                            OnClick="@(() => HandleClosePosition(position))"
                            IsDisabled="@IsClosing">
                            Close
                        </TbButton>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="10" class="px-4 py-8 text-center text-gray-500 dark:text-gray-400">
                    No open positions
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@code {
    /// <summary>
    /// Gets or sets the list of open positions to display.
    /// </summary>
    [Parameter]
    public required List<Position> Positions { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether a close operation is in progress.
    /// </summary>
    [Parameter]
    public bool IsClosing { get; set; }

    /// <summary>
    /// Gets or sets the callback when user clicks close position button.
    /// </summary>
    [Parameter]
    public EventCallback<Position> OnCloseRequested { get; set; }

    private async Task HandleClosePosition(Position position)
    {
        await OnCloseRequested.InvokeAsync(position);
    }

    private decimal GetPnLPercentage(Position position)
    {
        return position.EntryPrice != 0
            ? ((position.CurrentPrice - position.EntryPrice) / position.EntryPrice) * 100m
            : 0m;
    }

    private string GetSideClass(OrderSide side)
    {
        return side.Name == "Buy"
            ? "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200"
            : "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200";
    }

    private string GetPnLColorClass(decimal pnl)
    {
        return pnl switch
        {
            > 0 => "stat-positive",
            < 0 => "stat-negative",
            _ => "text-gray-900 dark:text-gray-100"
        };
    }
}
