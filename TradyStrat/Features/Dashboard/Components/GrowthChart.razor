@using TradyStrat.Features.Dashboard
<div class="chart-wrap">
    <div class="lbl"><span class="section-roman">I.</span>Capital growth · trajectory toward goal</div>
    <div class="growth-chart-wrap">
        <svg @ref="_svgRef" viewBox="0 0 1200 240" preserveAspectRatio="none" class="chart"
             role="img" aria-labelledby="gc-title gc-desc">
            <title id="gc-title">Capital growth toward goal</title>
            <desc id="gc-desc">Capital trajectory vs. required-CAGR plan curve.</desc>

            <defs>
                <linearGradient id="vault-grad" x1="0" x2="0" y1="0" y2="1">
                    <stop offset="0%" stop-color="#C49A56" stop-opacity="0.35" />
                    <stop offset="100%" stop-color="#C49A56" stop-opacity="0" />
                </linearGradient>
            </defs>

            <g class="grid">
                <line x1="0" y1="40" x2="1200" y2="40"/>
                <line x1="0" y1="100" x2="1200" y2="100"/>
                <line x1="0" y1="160" x2="1200" y2="160"/>
                <line x1="0" y1="220" x2="1200" y2="220"/>
            </g>

            @* Required-CAGR plan curve. Path is set by JS for the visible window. *@
            <path class="plan-curve" id="@($"{_id}-planPath")" d=""/>

            @* Actual capital, area + line. *@
            <path class="area" id="@($"{_id}-areaPath")" d=""/>
            <path class="line" id="@($"{_id}-linePath")" d="" pathLength="1"/>

            @* "Now" hairline (positioned by JS) *@
            <line class="now" id="@($"{_id}-nowLine")" y1="0" y2="220"/>

            @* Plan-vs-actual gap at today (positioned by JS) *@
            <line class="plan-gap" id="@($"{_id}-planGap")"/>
            <circle class="plan-gap-cap" id="@($"{_id}-planGapCap")" r="1.6"/>

            @* Today dot (positioned by JS) *@
            <circle class="today-dot" id="@($"{_id}-todayDot")" r="3.8"/>
        </svg>

        @* HTML text overlay (avoids preserveAspectRatio="none" stretching) *@
        <div class="chart-text" id="@($"{_id}-chartText")">
            <span class="y-label" id="@($"{_id}-yLabel75")" style="top:16.67%"></span>
            <span class="y-label" id="@($"{_id}-yLabel50")" style="top:41.67%"></span>
            <span class="y-label" id="@($"{_id}-yLabel25")" style="top:66.67%"></span>

            <span class="goal-label" id="@($"{_id}-goalLabel")"></span>

            <span class="today-value" id="@($"{_id}-todayValue")"></span>
            <span class="today-chip" id="@($"{_id}-todayChip")"></span>

            <span class="x-axis x-start" id="@($"{_id}-xStart")"></span>
            <span class="x-axis x-mid"   id="@($"{_id}-xMid")"></span>
            <span class="x-axis x-end"   id="@($"{_id}-xEnd")"></span>
        </div>
    </div>
</div>
