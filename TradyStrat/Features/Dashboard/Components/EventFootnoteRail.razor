@using System.Globalization
@using TradyStrat.Common.Domain

@if (Events is { Count: > 0 })
{
    <section class="footnotes" aria-label="Capital event footnotes">
        @foreach (var e in Events)
        {
            <div class="footnote">
                <div class="num">@e.RomanId</div>
                <div class="when">@e.Date.ToString("MMM yyyy", CultureInfo.InvariantCulture)</div>
                <div class="body"><em>@e.Headline</em> @e.Body</div>
            </div>
        }
    </section>
}

@code {
    [Parameter, EditorRequired] public IReadOnlyList<CapitalEvent> Events { get; set; } = [];
}
