@using TradyStrat.Application.Dashboard
@using TradyStrat.Application.Formatting
<header class="rail-head">
    <h2 class="rail-label section-heading"><span class="section-roman">VII.</span>Holdings</h2>
</header>
<div class="rail">
    <div class="cell">
        <div class="lbl">Position</div>
        <div class="val"><span class="num">@NumberFormat.Qty(Snap.Shares)</span> sh</div>
        <div class="sub">avg @NumberFormat.Price(Snap.AvgCostEur, "€")
                         · P&amp;L @PnL(Snap.UnrealizedPnLEur, Snap.CurrentValueEur)</div>
    </div>
    @foreach (var t in Tickers)
    {
        <div class="cell">
            <div class="tk">@t.Ticker <span class="tk-kind @(IsHeld(t) ? "" : "watch")">@(IsHeld(t) ? "held" : "watch")</span></div>
            <div class="val">
                <span class="num">@FormatPrimary(t)</span>
                @if (t.DeltaPct is { } dp)
                {
                    <span class="delta @(dp >= 0 ? "" : "dn") num" title="change today">@(dp >= 0 ? "↑" : "↓") @FormatDelta(dp)</span>
                }
            </div>
            @if (t.PriceEur is { } eur && t.Currency != "EUR")
            {
                <div class="sub">≈ @NumberFormat.Price(eur, "€")</div>
            }
            @if (t.Spark.Count >= 2)
            {
                <div class="cell-spark">@((MarkupString)Sparkline.Render(t.Spark, 140, 28))</div>
            }
            @{
                var st = StateFor(t);
            }
            @if (st is SuggestionState.Pending)
            {
                <div class="rail-call rail-call--pending" title="AI call in flight">
                    <span class="call-pending-dot" aria-hidden="true">•</span>
                    <span class="rationale">Awaiting AI…</span>
                </div>
            }
            else if (st is SuggestionState.Failed)
            {
                <div class="rail-call rail-call--failed" title="AI call failed">
                    <span class="call-failed-mark" aria-hidden="true">!</span>
                    <span class="rationale">AI call failed</span>
                </div>
            }
            else if (st is SuggestionState.Ready ready)
            {
                var call = ready.Suggestion;
                <div class="rail-call">
                    <span class="action @(call.Action.ToString().ToLowerInvariant())">@call.Action</span>
                    <span class="rationale">@TruncateRationale(call.Rationale, 80)</span>
                </div>
            }
        </div>
    }
</div>
