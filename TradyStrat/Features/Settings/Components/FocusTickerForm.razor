@using System.Globalization

<section class="settings-section">
    <h2>Focus ticker</h2>
    <div class="grid">
        <label class="field">
            <span class="lbl">Ticker</span>
            <select @bind="_ticker" @bind:after="OnChanged">
                @foreach (var ticker in _tickers)
                {
                    <option value="@ticker">@ticker</option>
                }
            </select>
        </label>
    </div>
    <div class="actions">
        <button class="btn" @onclick="SaveAsync" disabled="@(_busy || _tickers.Count == 0)">@(_busy ? "Saving…" : "Save")</button>
        @if (!string.IsNullOrEmpty(_msg))
        {
            <span class="msg @(_isError ? "err" : "ok")">@_msg</span>
        }
        @if (_lastUpdated is { } t)
        {
            <span class="meta">last updated @t.ToLocalTime().ToString("dd MMM yyyy HH:mm", CultureInfo.InvariantCulture)</span>
        }
    </div>
</section>
