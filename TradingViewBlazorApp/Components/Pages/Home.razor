@page "/"
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<FluentGrid>
    <FluentGridItem xs="12">
        <ErrorBoundary>
            <Ticker Settings="@SettingsTicker"/>
        </ErrorBoundary>
    </FluentGridItem>
    <FluentGridItem xs="12">
        <h1>NASDAQ:MSFT</h1>
    </FluentGridItem>
    <FluentGridItem xs="12" md="6">
        <ErrorBoundary>
            <FundamentalData Settings="@SettingsFundamentalData"/>
        </ErrorBoundary>
    </FluentGridItem>
    <FluentGridItem xs="12" md="6">
        <ErrorBoundary>
            <MiniChart Settings="@SettingsMiniChart"/>
        </ErrorBoundary>
        <ErrorBoundary>
            <TechnicalAnalysis Settings="@SettingsTechnicalAnalysis" style="margin-top: 24px;"/>
        </ErrorBoundary>
    </FluentGridItem>
    <FluentGridItem xs="12">
        <ErrorBoundary>
            <AdvancedRealTimeChart Settings="@SettingsAdvancedRealTimeChart"/>
        </ErrorBoundary>
    </FluentGridItem>
</FluentGrid>

<EditForm Model="@SettingsAdvancedRealTimeChart">
    <div class="row">
        <div class="col">
            <label>Width</label>
            <InputText @bind-Value="@SettingsAdvancedRealTimeChart!.Width" class="form-control"/>
        </div>
        <div class="col">
            <label>Height</label>
            <InputText @bind-Value="@SettingsAdvancedRealTimeChart.Height" class="form-control"/>
        </div>
    </div>
    <div class="row">
        <div class="col">
            <div class="form-group">
                <label>Theme</label>
                <InputSelect @bind-Value="@SettingsAdvancedRealTimeChart.Theme" class="form-control">
                    <option value="TradingViewTheme.Light">Light</option>
                    <option value="TradingViewTheme.Dark">Dark</option>
                </InputSelect>
            </div>
        </div>
        <div class="col">
        </div>
    </div>
    <div class="form-group">
        <label>Default Interval</label>
        <InputText @bind-Value="@SettingsAdvancedRealTimeChart.Interval" class="form-control"/>
    </div>
    @* <div class="form-group"> *@
    @*     <label> *@
    @*         Timezone *@
    @*         <InputSelect @bind-Value="@settings.Timezone" class="form-control"> *@
    @*             <option value="TimeZoneInfo.Utc">UTC</option> *@
    @*             <option value="TimeZoneInfo.Local">Local</option> *@
    @*         </InputSelect> *@
    @*     </label> *@
    @* </div> *@
    <div class="form-group">
        <label>
            Locale:
            <InputText @bind-Value="@SettingsAdvancedRealTimeChart.Locale" class="form-control"/>
        </label>
    </div>
    <div class="form-group">
        <label>
            Enable Publishing:
            <InputCheckbox @bind-Value="@SettingsAdvancedRealTimeChart.EnablePublishing"/>
        </label>
    </div>
    <div class="form-group">
        <label>
            Allow Symbol Change:
            <InputCheckbox @bind-Value="@SettingsAdvancedRealTimeChart.AllowSymbolChange"/>
        </label>
    </div>
    <div class="form-group">
        <label>
            With Date Ranges:
            <InputCheckbox @bind-Value="@SettingsAdvancedRealTimeChart.WithDateRanges"/>
        </label>
    </div>
    <div class="form-group">
        <label>
            Hide Side Toolbar:
            <InputCheckbox @bind-Value="@SettingsAdvancedRealTimeChart.HideSideToolbar"/>
        </label>
    </div>
    <FluentButton Appearance="@Appearance.Accent" Type="ButtonType.Reset">Reset</FluentButton>
    <FluentButton Appearance="@Appearance.Accent" Type="ButtonType.Submit">Apply</FluentButton>
</EditForm>

@code
{
    [SupplyParameterFromForm] 
    public AdvancedRealTimeChartSettings? SettingsAdvancedRealTimeChart { get; set; }

    private FundamentalDataSettings? SettingsFundamentalData { get; set; }
    private MiniChartSettings? SettingsMiniChart { get; set; }
    private TechnicalAnalysisSettings? SettingsTechnicalAnalysis { get; set; }
    private TickerSettings? SettingsTicker { get; set; }
    
    protected override void OnInitialized()
    {
        const string symbol = "NASDAQ:MSFT";
        
        SettingsAdvancedRealTimeChart ??= new AdvancedRealTimeChartSettings { Symbol = symbol, Width = "100%" };
        SettingsFundamentalData       ??= new FundamentalDataSettings       { Symbol = symbol, Width = "100%" };
        SettingsMiniChart             ??= new MiniChartSettings             { Symbol = symbol, Width = "100%" };
        SettingsTechnicalAnalysis     ??= new TechnicalAnalysisSettings     { Symbol = symbol, Width = "100%" };
        SettingsTicker                ??= new TickerSettings();
    }
}
