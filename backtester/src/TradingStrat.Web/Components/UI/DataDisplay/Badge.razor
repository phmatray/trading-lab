@using TradingStrat.Web.Components.UI

@* Catalyst UI Kit - Badge Component *@

<span class="@GetClasses()">
    @ChildContent
</span>

@code {
    /// <summary>
    /// Badge color variant.
    /// </summary>
    [Parameter]
    public BadgeColor Color { get; set; } = BadgeColor.Gray;

    /// <summary>
    /// Additional CSS classes to apply.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Badge content.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string GetClasses()
    {
        List<string> classes =
        [
            "inline-flex",
            "items-center",
            "gap-x-1.5",
            "rounded-md",
            "px-1.5",
            "py-0.5",
            "text-xs/5",
            "font-medium",
            "sm:text-xs/5",
            "forced-colors:outline"
        ];

        // Add color-specific classes
        string colorClass = Color switch
        {
            BadgeColor.Blue => CatalystStyles.BadgeBlue,
            BadgeColor.Red => CatalystStyles.BadgeRed,
            BadgeColor.Green => CatalystStyles.BadgeGreen,
            BadgeColor.Yellow => CatalystStyles.BadgeYellow,
            BadgeColor.Gray => CatalystStyles.BadgeGray,
            _ => CatalystStyles.BadgeGray
        };

        classes.Add(colorClass);

        if (!string.IsNullOrWhiteSpace(Class))
        {
            classes.Add(Class);
        }

        return string.Join(" ", classes);
    }
}
