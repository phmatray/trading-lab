@using TradingStrat.Web.Components.UI.Typography

<td class="@GetClasses()" @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(RowConfig?.Href))
    {
        <Link Href="@RowConfig.Href"
              Target="@RowConfig.Target"
              aria-label="@RowConfig.Title"
              Class="absolute inset-0 focus:outline-hidden"
              data-row-link />
    }
    @ChildContent
</td>

@code {
    [CascadingParameter] private TableConfig? Config { get; set; }
    [CascadingParameter] private TableRowConfig? RowConfig { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string GetClasses()
    {
        var classes = new List<string>();

        if (!string.IsNullOrEmpty(Class))
            classes.Add(Class);

        // Base styles
        classes.Add("relative");
        classes.Add("px-4");
        classes.Add("first:pl-(--gutter,--spacing(2))");
        classes.Add("last:pr-(--gutter,--spacing(2))");

        // Border (not when striped)
        if (Config?.Striped != true)
        {
            classes.Add("border-b");
            classes.Add("border-zinc-950/5");
            classes.Add("dark:border-white/5");
        }

        // Grid mode
        if (Config?.Grid == true)
        {
            classes.Add("border-l");
            classes.Add("border-l-zinc-950/5");
            classes.Add("first:border-l-0");
            classes.Add("dark:border-l-white/5");
        }

        // Dense mode
        classes.Add(Config?.Dense == true ? "py-2.5" : "py-4");

        // Bleed mode
        if (Config?.Bleed != true)
        {
            classes.Add("sm:first:pl-1");
            classes.Add("sm:last:pr-1");
        }

        return string.Join(" ", classes);
    }
}
