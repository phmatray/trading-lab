<CascadingValue Value="@RowConfig">
    <tr class="@GetClasses()" @attributes="AdditionalAttributes">
        @ChildContent
    </tr>
</CascadingValue>

@code {
    [CascadingParameter] private TableConfig? Config { get; set; }

    [Parameter] public string? Href { get; set; }
    [Parameter] public string? Target { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private TableRowConfig RowConfig => new(Href, Target, Title);

    private string GetClasses()
    {
        var classes = new List<string>();

        if (!string.IsNullOrEmpty(Class))
            classes.Add(Class);

        if (!string.IsNullOrEmpty(Href))
        {
            classes.Add("has-[[data-row-link][data-focus]]:outline-2");
            classes.Add("has-[[data-row-link][data-focus]]:-outline-offset-2");
            classes.Add("has-[[data-row-link][data-focus]]:outline-blue-500");
            classes.Add("dark:focus-within:bg-white/2.5");
        }

        if (Config?.Striped == true)
        {
            classes.Add("even:bg-zinc-950/2.5");
            classes.Add("dark:even:bg-white/2.5");
        }

        if (!string.IsNullOrEmpty(Href) && Config?.Striped == true)
        {
            classes.Add("hover:bg-zinc-950/5");
            classes.Add("dark:hover:bg-white/5");
        }

        if (!string.IsNullOrEmpty(Href) && Config?.Striped != true)
        {
            classes.Add("hover:bg-zinc-950/2.5");
            classes.Add("dark:hover:bg-white/2.5");
        }

        return string.Join(" ", classes);
    }
}
