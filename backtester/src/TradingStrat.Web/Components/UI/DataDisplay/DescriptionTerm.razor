@* Catalyst UI Kit - DescriptionTerm Component (key in key-value pair) *@

<dt class="@GetClasses()">
    @ChildContent
</dt>

@code {
    /// <summary>
    /// Additional CSS classes to apply.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Term content (the "key" in the key-value pair).
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string GetClasses()
    {
        List<string> classes =
        [
            "col-start-1",
            "border-t",
            "border-zinc-950/5",
            "pt-3",
            "text-zinc-500",
            "first:border-none",
            "sm:border-t",
            "sm:border-zinc-950/5",
            "sm:py-3",
            "dark:border-white/5",
            "dark:text-zinc-400",
            "sm:dark:border-white/5"
        ];

        if (!string.IsNullOrWhiteSpace(Class))
        {
            classes.Add(Class);
        }

        return string.Join(" ", classes);
    }
}
