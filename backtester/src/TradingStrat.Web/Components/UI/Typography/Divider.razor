@* Catalyst UI Kit - Divider Component *@

<hr class="@GetClasses()" />

@code {
    /// <summary>
    /// Additional CSS classes to apply.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    private string GetClasses()
    {
        List<string> classes =
        [
            "my-8",
            "border-t",
            "border-zinc-950/10",
            "dark:border-white/10"
        ];

        if (!string.IsNullOrWhiteSpace(Class))
        {
            classes.Add(Class);
        }

        return string.Join(" ", classes);
    }
}
