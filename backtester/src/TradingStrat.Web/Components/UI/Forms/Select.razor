@* Catalyst UI Kit - Select Component *@

<select class="@GetClasses()"
        disabled="@Disabled"
        @onchange="HandleChange"
        @attributes="GetSelectAttributes()">
    @ChildContent
</select>

@code {
    /// <summary>
    /// If true, allows multiple selection.
    /// </summary>
    [Parameter]
    public bool Multiple { get; set; }

    /// <summary>
    /// If true, renders in invalid state (error styling).
    /// </summary>
    [Parameter]
    public bool Invalid { get; set; }

    /// <summary>
    /// If true, disables the select.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Additional CSS classes to apply.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Select options (option elements).
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Change event callback.
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    /// <summary>
    /// Additional HTML attributes.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string GetClasses()
    {
        List<string> classes =
        [
            "block",
            "w-full",
            "appearance-none",
            "rounded-lg",
            "border",
            "px-[calc(theme(spacing.3)-1px)]",
            "py-[calc(theme(spacing.2)-1px)]",
            "text-base/6",
            "sm:text-sm/6"
        ];

        // Background with dropdown arrow (single select only)
        if (!Multiple)
        {
            classes.Add("bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTYiIGhlaWdodD0iMTYiIHZpZXdCb3g9IjAgMCAxNiAxNiIgZmlsbD0ibm9uZSIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cGF0aCBkPSJNNCA2TDggMTBMMTIgNiIgc3Ryb2tlPSIjNjM2MzYzIiBzdHJva2Utd2lkdGg9IjIiIHN0cm9rZS1saW5lY2FwPSJyb3VuZCIgc3Ryb2tlLWxpbmVqb2luPSJyb3VuZCIvPjwvc3ZnPg==')]");
            classes.Add("bg-[length:1rem_1rem]");
            classes.Add("bg-[right_0.5rem_center]");
            classes.Add("bg-no-repeat");
            classes.Add("pr-8");
        }

        // Default border and focus states
        if (Invalid)
        {
            classes.Add(CatalystStyles.InputInvalid);
        }
        else
        {
            classes.Add("border-zinc-950/10");
            classes.Add("data-[hover]:border-zinc-950/20");
            classes.Add("dark:border-white/10");
            classes.Add("dark:data-[hover]:border-white/20");
        }

        // Background and text
        classes.Add("bg-transparent");
        classes.Add("dark:bg-white/5");
        classes.Add("text-zinc-950");
        classes.Add("dark:text-white");

        // Focus state
        classes.Add("focus:outline");
        classes.Add("focus:outline-2");
        classes.Add("focus:-outline-offset-1");
        classes.Add("focus:outline-blue-500");

        // Disabled state
        if (Disabled)
        {
            classes.Add("disabled:border-zinc-950/20");
            classes.Add("dark:disabled:border-white/15");
            classes.Add("dark:disabled:bg-white/[2.5%]");
            classes.Add("disabled:opacity-50");
        }

        if (!string.IsNullOrWhiteSpace(Class))
        {
            classes.Add(Class);
        }

        return string.Join(" ", classes);
    }

    private async Task HandleChange(ChangeEventArgs e)
    {
        if (OnChange.HasDelegate)
        {
            await OnChange.InvokeAsync(e);
        }
    }

    private Dictionary<string, object> GetSelectAttributes()
    {
        Dictionary<string, object> attributes = new(AdditionalAttributes ?? new Dictionary<string, object>());

        if (Multiple)
        {
            attributes["multiple"] = "multiple";
        }

        return attributes;
    }
}
