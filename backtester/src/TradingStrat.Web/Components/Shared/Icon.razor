@* Simple SVG icon wrapper for consistency - supports HeroIcons by name *@

<svg class="@GetIconClasses()" fill="@Fill" stroke="@Stroke" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Name))
    {
        @((MarkupString)GetIconPath(Name))
    }
    else
    {
        @ChildContent
    }
</svg>

@code {
    [Parameter] public string? Name { get; set; }
    [Parameter] public IconSize Size { get; set; } = IconSize.Medium;
    [Parameter] public string Fill { get; set; } = "none";
    [Parameter] public string Stroke { get; set; } = "currentColor";
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? CustomClasses { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string GetIconClasses()
    {
        var classes = new List<string>();

        classes.Add(Size switch
        {
            IconSize.Small => "w-4 h-4",
            IconSize.Medium => "w-5 h-5",
            IconSize.Large => "w-6 h-6",
            IconSize.Hero => "w-12 h-12",
            _ => "w-5 h-5"
        });

        if (!string.IsNullOrEmpty(Class))
        {
            classes.Add(Class);
        }

        if (!string.IsNullOrEmpty(CustomClasses))
        {
            classes.Add(CustomClasses);
        }

        return string.Join(" ", classes);
    }

    private string GetIconPath(string name) => name.ToLower() switch
    {
        "search" or "magnifying-glass" => "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z\" />",
        "x-mark" => "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M6 18 18 6M6 6l12 12\" />",
        "funnel" => "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z\" />",
        "chevron-down" => "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"m19.5 8.25-7.5 7.5-7.5-7.5\" />",
        "chevron-up" => "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"m4.5 15.75 7.5-7.5 7.5 7.5\" />",
        "chevron-left" => "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M15.75 19.5 8.25 12l7.5-7.5\" />",
        "chevron-right" => "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"m8.25 4.5 7.5 7.5-7.5 7.5\" />",
        "chevron-up-down" => "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M8.25 15 12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9\" />",
        "inbox" => "<path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 3.75H6.912a2.25 2.25 0 0 0-2.15 1.588L2.35 13.177a2.25 2.25 0 0 0-.1.661V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 0 0-2.15-1.588H15M2.25 13.5h3.86a2.25 2.25 0 0 1 2.012 1.244l.256.512a2.25 2.25 0 0 0 2.013 1.244h3.218a2.25 2.25 0 0 0 2.013-1.244l.256-.512a2.25 2.25 0 0 1 2.013-1.244h3.859M12 3v8.25m0 0-3-3m3 3 3-3\" />",
        _ => "" // Unknown icon
    };
}
