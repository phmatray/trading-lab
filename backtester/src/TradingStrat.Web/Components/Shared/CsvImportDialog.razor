@if (IsOpen)
{
    <div class="fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <!-- Backdrop -->
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 dark:bg-gray-900 dark:bg-opacity-75 transition-opacity"></div>

        <!-- Modal -->
        <div class="flex items-center justify-center min-h-screen p-4">
            <div class="relative bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-2xl w-full">
                <!-- Header -->
                <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 dark:border-gray-700">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white" id="modal-title">
                        Import Tickers from CSV
                    </h3>
                    <button
                        type="button"
                        @onclick="HandleClose"
                        class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300"
                        aria-label="Close"
                    >
                        <Icon Name="x-mark" Size="IconSize.Medium" />
                    </button>
                </div>

                <!-- Body -->
                <div class="px-6 py-4 space-y-4">
                    <!-- Instructions -->
                    <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4">
                        <h4 class="text-sm font-medium text-blue-900 dark:text-blue-200 mb-2">
                            CSV Format
                        </h4>
                        <ul class="text-sm text-blue-800 dark:text-blue-300 space-y-1 list-disc list-inside">
                            <li>One ticker per line (e.g., AAPL, GOOGL, MSFT)</li>
                            <li>Or comma-separated on a single line (e.g., AAPL,GOOGL,MSFT)</li>
                            <li>File can be .csv or .txt format</li>
                        </ul>
                    </div>

                    <!-- File Upload -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                            Select CSV File
                        </label>
                        <InputFile
                            OnChange="HandleFileSelected"
                            accept=".csv,.txt"
                            class="block w-full text-sm text-gray-900 dark:text-white border border-gray-300 dark:border-gray-600 rounded-lg cursor-pointer bg-gray-50 dark:bg-gray-700 focus:outline-none"
                        />
                    </div>

                    <!-- Preview -->
                    @if (_previewTickers.Any())
                    {
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                                Preview (@_previewTickers.Count tickers)
                            </label>
                            <div class="bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg p-4 max-h-48 overflow-y-auto">
                                <div class="flex flex-wrap gap-2">
                                    @foreach (string ticker in _previewTickers.Take(20))
                                    {
                                        <span class="px-2 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 text-xs font-medium rounded">
                                            @ticker
                                        </span>
                                    }
                                    @if (_previewTickers.Count > 20)
                                    {
                                        <span class="px-2 py-1 bg-gray-200 dark:bg-gray-700 text-gray-600 dark:text-gray-400 text-xs font-medium rounded">
                                            +@(_previewTickers.Count - 20) more
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Errors -->
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
                            <p class="text-sm text-red-800 dark:text-red-300">
                                @_errorMessage
                            </p>
                        </div>
                    }
                </div>

                <!-- Footer -->
                <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-gray-200 dark:border-gray-700">
                    <Button
                        Text="Cancel"
                        OnClick="HandleClose"
                        Variant="ButtonVariant.Secondary"
                        Size="ButtonSize.Medium"
                    />
                    <Button
                        Text="Import"
                        OnClick="HandleImport"
                        Variant="ButtonVariant.Primary"
                        Size="ButtonSize.Medium"
                        Disabled="@(!_previewTickers.Any())"
                    />
                </div>
            </div>
        </div>
    </div>
}
