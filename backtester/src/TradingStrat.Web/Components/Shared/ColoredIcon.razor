@* Colored SVG Icon Component *@
<svg data-slot="icon"
     fill="none"
     stroke="currentColor"
     viewBox="0 0 24 24"
     class="@GetIconClasses()"
     aria-hidden="@(!string.IsNullOrEmpty(AriaLabel) ? "false" : "true")"
     aria-label="@AriaLabel">
    @GetIconPath()
</svg>

@code {
    [Parameter] public string Icon { get; set; } = "home";
    [Parameter] public IconCategory Category { get; set; } = IconCategory.Default;
    [Parameter] public IconSize Size { get; set; } = IconSize.Medium;
    [Parameter] public string? CustomColor { get; set; }
    [Parameter] public string? AriaLabel { get; set; }

    private string GetIconClasses()
    {
        var sizeClass = Size switch
        {
            IconSize.Small => "w-4 h-4",
            IconSize.Medium => "w-5 h-5",
            IconSize.Large => "w-6 h-6",
            IconSize.Hero => "w-12 h-12",
            _ => "w-5 h-5"
        };

        var colorClass = CustomColor ?? Category switch
        {
            IconCategory.Workspace => "text-category-workspace",
            IconCategory.Strategy => "text-category-strategy",
            IconCategory.Data => "text-category-data",
            IconCategory.Portfolio => "text-category-portfolio",
            IconCategory.System => "text-category-system",
            _ => "text-gray-600 dark:text-dark-text-secondary"
        };

        return $"{sizeClass} {colorClass}";
    }

