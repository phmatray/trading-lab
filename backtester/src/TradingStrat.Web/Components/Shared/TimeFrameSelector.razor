<div class="flex items-center gap-3">
    <label for="timeframe-selector" class="text-sm font-medium text-gray-700 dark:text-gray-300">
        @Label
    </label>

    <select
        id="timeframe-selector"
        class="px-4 py-2 text-sm font-medium border border-gray-300 rounded-lg bg-white dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
        value="@SelectedTimeFrame?.Unit.ToString()"
        @onchange="HandleTimeFrameChanged"
        aria-label="@Label"
    >
        @foreach (TimeFrameUnit unit in AvailableTimeFrames)
        {
            <option value="@unit.ToString()">
                @GetTimeFrameDisplayName(unit)
            </option>
        }
    </select>
</div>
