@* Top strategies table component *@
@using TradingStrat.Web.Components.UI.DataDisplay.Table

@if (Strategies is null || !Strategies.Any())
{
    <div class="text-center py-8 text-gray-500 dark:text-dark-text-tertiary">
        <svg class="w-12 h-12 mx-auto mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
        </svg>
        <p>No backtest results yet</p>
        <p class="text-sm mt-1">Run some backtests to see top performers here</p>
    </div>
}
else
{
    <Table Dense Striped>
        <TableHead>
            <TableRow>
                <TableHeader>Strategy</TableHeader>
                <TableHeader>Return</TableHeader>
                <TableHeader>Sharpe</TableHeader>
                <TableHeader>Trades</TableHeader>
            </TableRow>
        </TableHead>
        <TableBody>
            @foreach (var strategy in Strategies)
            {
                <TableRow>
                    <TableCell>
                        <div class="text-sm font-medium text-gray-900 dark:text-dark-text-primary">
                            @strategy.StrategyName
                        </div>
                        <div class="text-xs text-gray-500 dark:text-dark-text-tertiary">
                            @strategy.Ticker
                        </div>
                    </TableCell>
                    <TableCell>
                        <span class="@(strategy.TotalReturn >= 0 ? "text-green-600 dark:text-green-400" : "text-red-600 dark:text-red-400") text-sm font-medium">
                            @(strategy.TotalReturn >= 0 ? "+" : "")@strategy.TotalReturn.ToString("F2")%
                        </span>
                    </TableCell>
                    <TableCell Class="text-sm text-gray-900 dark:text-dark-text-primary">
                        @strategy.SharpeRatio.ToString("F2")
                    </TableCell>
                    <TableCell Class="text-sm text-gray-500 dark:text-dark-text-secondary">
                        @strategy.TotalTrades
                    </TableCell>
                </TableRow>
            }
        </TableBody>
    </Table>
}
