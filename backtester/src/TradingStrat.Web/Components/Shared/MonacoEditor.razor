@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

@if (_state == MonacoEditorState.Failed)
{
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
        <h4 class="font-semibold text-red-800 dark:text-red-200 mb-2">Monaco Editor Failed to Load</h4>
        <p class="text-red-700 dark:text-red-300 text-sm">@_errorMessage</p>
        <button @onclick="InitializeEditorWithRetryAsync"
                class="mt-2 px-3 py-1 bg-red-600 hover:bg-red-700 text-white rounded text-sm">
            Retry
        </button>
    </div>
}
else if (_state == MonacoEditorState.Initializing)
{
    <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4">
        <p class="text-blue-700 dark:text-blue-300 text-sm">Loading Monaco editor...</p>
    </div>
}

<div id="@_editorContainerId"
     class="monaco-editor-container border border-gray-300 dark:border-gray-600 rounded-lg overflow-hidden"
     style="height: @(Height)px; @(_state == MonacoEditorState.Ready ? "" : "display: none;")"></div>

@code {
    [Parameter]
    public string Code { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> CodeChanged { get; set; }

    [Parameter]
    public int Height { get; set; } = 500;

    [Parameter]
    public bool ReadOnly { get; set; }

    [Parameter]
    public EventCallback<string> OnInitializationError { get; set; }

    private readonly string _editorContainerId = $"monaco-editor-{Guid.NewGuid():N}";
    private IJSObjectReference? _moduleReference;
    private DotNetObjectReference<MonacoEditor>? _dotNetReference;
    private bool _isInitialized;
    private MonacoEditorState _state = MonacoEditorState.NotInitialized;
    private string? _errorMessage;
    private const int MaxRetries = 3;

    private enum MonacoEditorState { NotInitialized, Initializing, Ready, Failed }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _state == MonacoEditorState.NotInitialized)
        {
            await InitializeEditorWithRetryAsync();
        }
    }

    private async Task InitializeEditorWithRetryAsync()
    {
        _state = MonacoEditorState.Initializing;
        StateHasChanged();

        for (int attempt = 1; attempt <= MaxRetries; attempt++)
        {
            try
            {
                Console.WriteLine($"[MonacoEditor] Initialization attempt {attempt}/{MaxRetries}");

                // CRITICAL: Add delay to ensure DOM is ready
                await Task.Delay(attempt * 100);

                // Verify container exists in DOM
                bool containerExists = await JSRuntime.InvokeAsync<bool>(
                    "eval", $"!!document.getElementById('{_editorContainerId}')");

                if (!containerExists)
                {
                    throw new InvalidOperationException(
                        $"Container '{_editorContainerId}' not found in DOM");
                }

                await InitializeEditorAsync();
                _state = MonacoEditorState.Ready;
                Console.WriteLine($"[MonacoEditor] Successfully initialized on attempt {attempt}");
                StateHasChanged();
                return;
            }
            catch (Exception ex)
            {
                _errorMessage = $"Attempt {attempt} failed: {ex.Message}";
                Console.WriteLine($"[MonacoEditor] {_errorMessage}");

                if (attempt < MaxRetries)
                {
                    await Task.Delay((int)Math.Pow(2, attempt) * 100); // Exponential backoff
                }
                else
                {
                    _state = MonacoEditorState.Failed;
                    await OnInitializationError.InvokeAsync(_errorMessage);
                    StateHasChanged();
                }
            }
        }
    }

    private async Task InitializeEditorAsync()
    {
        try
        {
            // Load the monaco-editor-helper module
            _moduleReference = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./js/monaco-editor-helper.js");

            // Create .NET reference for callbacks
            _dotNetReference = DotNetObjectReference.Create(this);

            // Initialize Monaco Editor using the exported monacoEditorHelper
            await _moduleReference.InvokeVoidAsync(
                "monacoEditorHelper.initializeEditor",
                _editorContainerId,
                Code,
                _dotNetReference,
                Height);

            // Set read-only state if needed
            if (ReadOnly)
            {
                await _moduleReference.InvokeVoidAsync("monacoEditorHelper.setReadOnly", true);
            }

            _isInitialized = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to initialize Monaco Editor: {ex.Message}");
        }
    }

    [JSInvokable]
    public async Task OnCodeChanged(string newCode)
    {
        Code = newCode;
        await CodeChanged.InvokeAsync(newCode);
    }

    public async Task SetCodeAsync(string code)
    {
        if (_isInitialized && _moduleReference != null)
        {
            await _moduleReference.InvokeVoidAsync("monacoEditorHelper.setCode", code);
        }
    }

    public async Task SetReadOnlyAsync(bool readOnly)
    {
        if (_isInitialized && _moduleReference != null)
        {
            await _moduleReference.InvokeVoidAsync("monacoEditorHelper.setReadOnly", readOnly);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_moduleReference != null)
        {
            try
            {
                await _moduleReference.InvokeVoidAsync("monacoEditorHelper.disposeEditor");
                await _moduleReference.DisposeAsync();
            }
            catch
            {
                // Ignore disposal errors
            }
        }

        _dotNetReference?.Dispose();
    }
}
