@* AiPanel Component - Fixed right panel with AI insights and chat (replaces AiAssistantWidget) *@

<aside class="@GetPanelClasses()"
       data-testid="ai-panel"
       role="complementary"
       aria-label="AI Assistant">
    <div class="h-full flex flex-col bg-white dark:bg-dark-card border-l border-gray-200 dark:border-dark-border">
        <!-- Panel Header -->
        <div class="flex items-center @(IsCollapsed ? "justify-center" : "justify-between") px-4 py-3 bg-trading-blue dark:bg-dark-accent-blue text-white border-b border-gray-200 dark:border-dark-border">
            @if (!IsCollapsed)
            {
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                    </svg>
                    <h3 class="font-semibold">Trading Assistant</h3>
                </div>
            }

            <button @onclick="ToggleCollapse"
                    class="hover:bg-blue-700 dark:hover:bg-blue-500 p-1 rounded transition-colors"
                    aria-label="@(IsCollapsed ? "Expand panel" : "Collapse panel")"
                    type="button">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@(IsCollapsed ? "M15 19l-7-7 7-7" : "M9 5l7 7-7 7")"></path>
                </svg>
            </button>
        </div>

        @if (!IsCollapsed)
        {
            <!-- Mode Toggle -->
            <div class="flex border-b border-gray-200 dark:border-dark-border">
                <button @onclick="@(() => OnModeChanged(PanelMode.Chat))"
                        class="flex-1 px-4 py-2 text-sm font-medium transition-colors @(_panelMode == PanelMode.Chat ? "bg-trading-blue dark:bg-dark-accent-blue text-white" : "text-gray-600 dark:text-dark-text-secondary hover:bg-gray-100 dark:hover:bg-dark-elevated")"
                        type="button">
                    Chat
                </button>
                <button @onclick="@(() => OnModeChanged(PanelMode.Analysis))"
                        class="flex-1 px-4 py-2 text-sm font-medium transition-colors @(_panelMode == PanelMode.Analysis ? "bg-trading-blue dark:bg-dark-accent-blue text-white" : "text-gray-600 dark:text-dark-text-secondary hover:bg-gray-100 dark:hover:bg-dark-elevated")"
                        type="button">
                    Analysis
                </button>
            </div>

            @if (_panelMode == PanelMode.Chat)
            {
                <!-- Chat Mode -->
                <!-- Chat Section -->
            <div class="flex-1 flex flex-col overflow-hidden">
                <!-- Messages container -->
                <div @ref="_messagesContainer" class="flex-1 overflow-y-auto p-4 space-y-4 bg-gray-50 dark:bg-dark-bg">
                    @foreach (var msg in _messages)
                    {
                        <div class="flex @(msg.IsUser ? "justify-end" : "justify-start") items-end gap-2">
                            @if (!msg.IsUser)
                            {
                                <!-- Robot avatar for assistant -->
                                <div class="flex-shrink-0 w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center shadow-lg">
                                    <span class="text-lg">🤖</span>
                                </div>
                            }
                            <div class="max-w-[80%] @(msg.IsUser ? "bg-trading-blue dark:bg-dark-accent-blue text-white" : "bg-white dark:bg-dark-elevated text-gray-800 dark:text-dark-text-primary border border-gray-200 dark:border-dark-border") rounded-lg px-4 py-2 shadow">
                                <p class="text-sm whitespace-pre-wrap">@msg.Content</p>
                            </div>
                        </div>
                    }

                    @if (_isStreaming && !string.IsNullOrEmpty(_streamingMessage))
                    {
                        <div class="flex justify-start items-end gap-2">
                            <!-- Robot avatar for streaming -->
                            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center shadow-lg">
                                <span class="text-lg">🤖</span>
                            </div>
                            <div class="max-w-[80%] bg-white dark:bg-dark-elevated text-gray-800 dark:text-dark-text-primary border border-gray-200 dark:border-dark-border rounded-lg px-4 py-2 shadow">
                                <p class="text-sm whitespace-pre-wrap">@_streamingMessage</p>
                                <div class="typing-indicator mt-2">
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Input area -->
                <div class="border-t border-gray-200 dark:border-dark-border p-4 bg-white dark:bg-dark-card">
                    <div class="flex gap-2">
                        <input @bind="_userInput"
                               @bind:event="oninput"
                               @onkeypress="HandleKeyPress"
                               type="text"
                               placeholder="Ask about strategies, positions, or market data..."
                               class="flex-1 px-3 py-2 border border-gray-300 dark:border-dark-border rounded-lg focus:outline-none focus:ring-2 focus:ring-trading-blue dark:focus:ring-dark-accent-blue bg-white dark:bg-dark-elevated text-gray-900 dark:text-dark-text-primary placeholder-gray-400 dark:placeholder-dark-text-secondary"
                               disabled="@_isStreaming" />
                        <button @onclick="SendMessageAsync"
                                disabled="@(_isStreaming || string.IsNullOrWhiteSpace(_userInput))"
                                class="px-4 py-2 bg-trading-blue dark:bg-dark-accent-blue text-white rounded-lg hover:bg-blue-700 dark:hover:bg-blue-500 transition-colors disabled:bg-gray-400 dark:disabled:bg-gray-600 disabled:cursor-not-allowed">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                            </svg>
                        </button>
                    </div>
                    <button @onclick="ClearHistoryAsync"
                            class="text-xs text-gray-500 dark:text-dark-text-secondary hover:text-gray-700 dark:hover:text-dark-text-primary mt-2 transition-colors">
                        Clear history
                    </button>
                </div>
            </div>
            }
            else
            {
                <!-- Analysis Mode -->
                <div class="flex-1 flex flex-col overflow-hidden">
                    <!-- Ticker Input Section -->
                    <div class="p-4 border-b border-gray-200 dark:border-dark-border bg-white dark:bg-dark-card">
                        <div class="flex gap-2">
                            <input @bind="_selectedTicker"
                                   @bind:event="oninput"
                                   type="text"
                                   placeholder="Enter ticker (e.g., AAPL)"
                                   class="flex-1 px-3 py-2 border border-gray-300 dark:border-dark-border rounded-lg focus:outline-none focus:ring-2 focus:ring-trading-blue dark:focus:ring-dark-accent-blue bg-white dark:bg-dark-elevated text-gray-900 dark:text-dark-text-primary placeholder-gray-400 dark:placeholder-dark-text-secondary uppercase"
                                   disabled="@_isAnalyzing" />
                            <button @onclick="AnalyzeTickerAsync"
                                    disabled="@(_isAnalyzing || string.IsNullOrWhiteSpace(_selectedTicker))"
                                    class="px-4 py-2 bg-trading-blue dark:bg-dark-accent-blue text-white rounded-lg hover:bg-blue-700 dark:hover:bg-blue-500 transition-colors disabled:bg-gray-400 dark:disabled:bg-gray-600 disabled:cursor-not-allowed whitespace-nowrap">
                                @if (_isAnalyzing)
                                {
                                    <span>Analyzing...</span>
                                }
                                else
                                {
                                    <span>Analyze</span>
                                }
                            </button>
                        </div>

                        @if (!string.IsNullOrEmpty(_analysisError))
                        {
                            <div class="mt-2 text-sm text-red-600 dark:text-red-400">
                                @_analysisError
                            </div>
                        }
                    </div>

                    <!-- Analysis Results Container -->
                    <div class="flex-1 overflow-y-auto p-4 space-y-4 bg-gray-50 dark:bg-dark-bg">
                        @if (_tickerAnalysis != null)
                        {
                            <!-- Summary Card -->
                            <div class="bg-white dark:bg-dark-elevated border border-gray-200 dark:border-dark-border rounded-lg p-4 shadow">
                                <h4 class="text-sm font-semibold text-gray-700 dark:text-dark-text-secondary mb-2">Summary</h4>
                                <div class="space-y-2">
                                    <div class="flex justify-between items-center">
                                        <span class="text-xs text-gray-500 dark:text-dark-text-secondary">Current Price</span>
                                        <span class="text-sm font-semibold text-gray-900 dark:text-dark-text-primary">@_tickerAnalysis.CurrentPrice.ToString("C2")</span>
                                    </div>
                                    <div class="flex justify-between items-center">
                                        <span class="text-xs text-gray-500 dark:text-dark-text-secondary">Daily Change</span>
                                        <span class="text-sm font-semibold @(_tickerAnalysis.DailyChangePercent >= 0 ? "metric-positive" : "metric-negative")">
                                            @(_tickerAnalysis.DailyChangePercent >= 0 ? "+" : "")@_tickerAnalysis.DailyChangePercent.ToString("F2")%
                                        </span>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-800 dark:text-dark-text-primary mt-3">@_tickerAnalysis.Summary</p>
                            </div>

                            <!-- Recommendation Card -->
                            <div class="bg-white dark:bg-dark-elevated border border-gray-200 dark:border-dark-border rounded-lg p-4 shadow">
                                <h4 class="text-sm font-semibold text-gray-700 dark:text-dark-text-secondary mb-2">Recommendation</h4>
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="px-3 py-1 rounded-full text-xs font-semibold @GetRecommendationColorClass()">
                                        @_tickerAnalysis.Recommendation
                                    </span>
                                </div>
                            </div>

                            <!-- Actionable Insights -->
                            @if (_tickerAnalysis.ActionableInsights.Count > 0)
                            {
                                <div class="bg-white dark:bg-dark-elevated border border-gray-200 dark:border-dark-border rounded-lg p-4 shadow">
                                    <h4 class="text-sm font-semibold text-gray-700 dark:text-dark-text-secondary mb-2">Actionable Insights</h4>
                                    <ul class="list-disc list-inside space-y-1">
                                        @foreach (var insight in _tickerAnalysis.ActionableInsights)
                                        {
                                            <li class="text-sm text-gray-800 dark:text-dark-text-primary">@insight</li>
                                        }
                                    </ul>
                                </div>
                            }

                            <!-- Confidence Bar -->
                            <div class="bg-white dark:bg-dark-elevated border border-gray-200 dark:border-dark-border rounded-lg p-4 shadow">
                                <div class="flex justify-between items-center mb-2">
                                    <h4 class="text-sm font-semibold text-gray-700 dark:text-dark-text-secondary">Confidence</h4>
                                    <span class="text-sm font-semibold text-gray-900 dark:text-dark-text-primary">@_tickerAnalysis.Confidence%</span>
                                </div>
                                <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                                    <div class="@GetConfidenceBarClass() h-2 rounded-full transition-all duration-500"
                                         style="width: @(_tickerAnalysis.Confidence)%"></div>
                                </div>
                            </div>

                            <!-- Add to Portfolio Button -->
                            <button @onclick="() => { /* TODO: Navigate to add position */ }"
                                    class="w-full px-4 py-2 bg-green-600 dark:bg-green-700 text-white rounded-lg hover:bg-green-700 dark:hover:bg-green-600 transition-colors font-semibold">
                                Add to Portfolio
                            </button>
                        }
                        else if (!_isAnalyzing)
                        {
                            <!-- Empty State -->
                            <div class="flex flex-col items-center justify-center h-full text-center p-8">
                                <svg class="w-16 h-16 text-gray-400 dark:text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                                </svg>
                                <h3 class="text-lg font-semibold text-gray-700 dark:text-dark-text-secondary mb-2">No Analysis Yet</h3>
                                <p class="text-sm text-gray-500 dark:text-dark-text-secondary">Enter a ticker symbol and click Analyze to get AI-powered market insights</p>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</aside>

