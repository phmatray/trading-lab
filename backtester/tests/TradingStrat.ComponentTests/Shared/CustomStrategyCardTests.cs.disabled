    [Fact]
    public void CustomStrategyCard_HasCorrectStyling()
    {
        // Arrange & Act
        var cut = RenderComponent<CustomStrategyCard>(parameters => parameters
            .Add(p => p.Name, "Test")
            .Add(p => p.Category, "Test")
            .Add(p => p.Author, "Test")
            .Add(p => p.LastUpdatedAt, DateTime.Now)
            .Add(p => p.EntryRulesCount, 1)
            .Add(p => p.ExitRulesCount, 1));

        // Assert
        var card = cut.Find(".bg-white");
        var classes = card.GetAttribute("class");

        classes.ShouldContain("dark:bg-zinc-900");
        classes.ShouldContain("rounded-lg");
        classes.ShouldContain("border");
        classes.ShouldContain("hover:border-gray-300");
    }

    [Fact]
    public void CustomStrategyCard_ActionButtons_LayoutIn2x2Grid()
    {
        // Arrange & Act
        var cut = RenderComponent<CustomStrategyCard>(parameters => parameters
            .Add(p => p.Name, "Test")
            .Add(p => p.Category, "Test")
            .Add(p => p.Author, "Test")
            .Add(p => p.LastUpdatedAt, DateTime.Now)
            .Add(p => p.EntryRulesCount, 1)
            .Add(p => p.ExitRulesCount, 1));

        // Assert
        var grid = cut.Find(".grid.grid-cols-2");
        grid.ShouldNotBeNull();
        grid.GetAttribute("class").ShouldContain("gap-3");
    }

    [Fact]
    public void CustomStrategyCard_DeleteButton_IsFullWidth()
    {
        // Arrange & Act
        var cut = RenderComponent<CustomStrategyCard>(parameters => parameters
            .Add(p => p.Name, "Test")
            .Add(p => p.Category, "Test")
            .Add(p => p.Author, "Test")
            .Add(p => p.LastUpdatedAt, DateTime.Now)
            .Add(p => p.EntryRulesCount, 1)
            .Add(p => p.ExitRulesCount, 1));

        // Assert
        var buttons = cut.FindComponents<TradingStrat.Web.Components.UI.Buttons.Button>();
        var deleteButton = buttons.First(b => b.Instance.Color == TradingStrat.Web.Components.UI.ButtonColor.Red);
        deleteButton.Instance.Class.ShouldContain("w-full");
    }
